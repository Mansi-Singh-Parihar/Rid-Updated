<link rel="stylesheet" href="/nokari/css/common/navbar.css">
<link rel="stylesheet" href="/nokari/css/common/footer.css">
<link rel="stylesheet" href="/nokari/css/pages/examdetail.css">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;0,9..144,700;1,9..144,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<%- include('common/navbar') %>

<div class="ed-page">

<% if (!stats && !guide) { %>
  <div class="ed-empty-state">
    <div class="ed-empty-icon">📋</div>
    <h2>Exam details not available yet</h2>
    <p>We're working on it. Check back soon.</p>
    <a href="/examcalendar" class="btn-back-empty">← Back to Calendar</a>
  </div>
<% } else { %>

<!-- ══════════════ HERO BAND ══════════════ -->
<div class="ed-hero-band">
  <div class="ed-wrap">

    

    <div class="ed-hero-inner">
      <div class="ed-hero-left">
        <!-- Category + badges -->
        <div class="ed-badges">
          <% const cat = (stats?.category || guide?.category || '').toLowerCase().replace(/ /g,''); %>
          <% if (cat) { %>
            <span class="badge badge-<%= cat %>"><%= stats?.category || guide?.category %></span>
          <% } %>
          <% if (stats?.officialSite) { %><span class="badge badge-official"><svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Latest Updates</span><% } %>
        </div>

        <h1 class="ed-title"><%= stats?.title || guide?.slug?.replace(/-/g,' ').replace(/\b\w/g,l=>l.toUpperCase()) %></h1>

        <p class="ed-org-line">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          <%= stats?.organization || 'Government of India' %>
        </p>

      <!-- Quick Action Links in hero -->
      <div class="ed-hero-actions">
      <%
        const applyHref = (stats?.source === 'job') ? (stats?.applyLink || guide?.applyLink) : stats?.applyLink;
        const officialHref = stats?.officialSite || guide?.officialSite;
        const pdfHref = (stats?.source !== 'result') ? (stats?.notificationLink || guide?.notificationPdfLink) : null;        
        const admitHref = (stats?.source !== 'result') ? stats?.downloadLink : null;
        const resultHref   = stats?.resultLink;
        const meritHref    = stats?.meritListLink;
      %>

        <% if (applyHref) { %>
          <a href="<%= applyHref %>" target="_blank" class="hero-btn hero-btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Apply Now
          </a>
        <% } %>

        <% if (officialHref) { %>
          <a href="<%= officialHref %>" target="_blank" class="hero-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
            Official Site
          </a>
        <% } %>

        <% if (pdfHref) { %>
          <a href="<%= pdfHref %>" target="_blank" class="hero-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Notification PDF
          </a>
        <% } %>

        <% if (admitHref) { %>
          <a href="<%= admitHref %>" target="_blank" class="hero-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Admit Card
          </a>
        <% } %>

        <% if (resultHref) { %>
          <a href="<%= resultHref %>" target="_blank" class="hero-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
            View Result
          </a>
        <% } %>

        <% if (meritHref) { %>
          <a href="<%= meritHref %>" target="_blank" class="hero-btn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Merit List
          </a>
        <% } %>

      </div>
      </div>

      <!-- Stats Panel -->
      <% if (stats) { %>
      <div class="ed-stats-panel">
        <% if (stats.totalPosts) { %>
        <div class="stat-item">
          <div class="stat-icon stat-blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div>
            <div class="stat-num"><%= stats.totalPosts.toLocaleString('en-IN') %></div>
            <div class="stat-lbl">Total Vacancies</div>
          </div>
        </div>
        <% } %>
        <% if (stats.fee?.general) { %>
        <div class="stat-item">
          <div class="stat-icon stat-green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <div>
            <div class="stat-num">₹<%= stats.fee.general %></div>
            <div class="stat-lbl">Application Fee</div>
          </div>
        </div>
        <% } %>
        <% if (stats.examDate) { %>
        <div class="stat-item">
          <div class="stat-icon stat-amber">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <div>
            <div class="stat-num stat-text-amber"><%= stats.examDate %></div>
            <div class="stat-lbl">Exam Date</div>
          </div>
        </div>
        <% } %>
        <% if (stats.applyLastDate) { %>
        <div class="stat-item">
          <div class="stat-icon stat-red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="stat-num stat-text-red"><%= new Date(stats.applyLastDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></div>
            <div class="stat-lbl">Last Date to Apply</div>
          </div>
        </div>
        <% } %>
        <% if (stats.ageMin && stats.ageMax) { %>
        <div class="stat-item">
          <div class="stat-icon stat-purple">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <div class="stat-num"><%= stats.ageMin %>–<%= stats.ageMax %> yrs</div>
            <div class="stat-lbl">Age Limit</div>
          </div>
        </div>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- ══════════════ BODY ══════════════ -->
<div class="ed-wrap ed-body">

  <!-- Sticky TOC strip -->
  <div class="ed-toc-strip" id="tocStrip">
    <div class="ed-toc-inner">
      <% if (guide?.overview) { %><a href="#sec-overview" class="toc-link active">Overview</a><% } %>
      <% if (guide?.stages?.length) { %><a href="#sec-structure" class="toc-link">Structure</a><% } %>
      <% if (guide?.roadmap?.length) { %><a href="#sec-roadmap" class="toc-link">Roadmap</a><% } %>
      <% if (guide?.syllabus?.length) { %><a href="#sec-syllabus" class="toc-link">Syllabus</a><% } %>
      <a href="#sec-eligibility" class="toc-link">Eligibility</a>
      <% if (guide?.books?.length) { %><a href="#sec-books" class="toc-link">Books</a><% } %>
      <% if (stats?.importantDates?.length) { %><a href="#sec-dates" class="toc-link">Dates</a><% } %>
    </div>
  </div>

  <div class="ed-layout">
    <!-- ════ MAIN CONTENT ════ -->
    <main class="ed-content">

      <!-- Guide alert -->
      <% if (!guide) { %>
      <div class="ed-notice">
        <div class="ed-notice-icon">📋</div>
        <div>
          <strong>Detailed guide coming soon</strong>
          <p>Our team is preparing a full preparation guide for this exam. Bookmark this page.</p>
        </div>
      </div>
      <% } %>

      <!-- ── 01 Overview ── -->
      <% if (guide?.overview) { %>
      <section class="ed-section" id="sec-overview">
        <div class="sec-header">
          <span class="sec-num">01</span>
          <h2 class="sec-title">Overview</h2>
        </div>
        <div class="ed-prose"><%- guide.overview.replace(/\n\n/g,'</p><p>').replace(/^/,'<p>').replace(/$/,'</p>') %></div>
        <% if (guide.alertNote) { %>
        <div class="ed-callout ed-callout-warn">
          <span class="callout-icon">⚠️</span>
          <div><strong>Important:</strong> <%= guide.alertNote %></div>
        </div>
        <% } %>
      </section>
      <% } %>

      <!-- ── 02 Exam Structure ── -->
      <% if (guide?.stages?.length) { %>
      <section class="ed-section" id="sec-structure">
        <div class="sec-header">
          <span class="sec-num">02</span>
          <h2 class="sec-title">Selection Process</h2>
        </div>
        <div class="ed-table-wrap">
          <table class="ed-table">
            <thead>
              <tr>
                <th>Stage</th><th>Type</th><th>Papers</th><th>Marks</th><th>Nature</th>
              </tr>
            </thead>
            <tbody>
              <% guide.stages.forEach((stage,i) => { %>
              <tr>
                <td>
                  <span class="stage-badge stage-<%= i+1 %>"><%= i+1 %></span>
                  <strong><%= stage.name %></strong>
                </td>
                <td><%= stage.stageType %></td>
                <td><%= stage.papers %></td>
                <td><strong><%= stage.totalMarks %></strong></td>
                <td><span class="nature-pill nature-<%= stage.nature?.toLowerCase().replace(/ /g,'-') %>"><%= stage.nature %></span></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% if (guide.structureNote) { %>
        <div class="ed-callout ed-callout-success">
          <span class="callout-icon">✅</span>
          <div><%= guide.structureNote %></div>
        </div>
        <% } %>
      </section>
      <% } %>

      <!-- ── 03 Roadmap ── -->
      <% if (guide?.roadmap?.length) { %>
      <section class="ed-section" id="sec-roadmap">
        <div class="sec-header">
          <span class="sec-num">03</span>
          <h2 class="sec-title">Preparation Roadmap</h2>
        </div>
        <div class="ed-roadmap">
          <% guide.roadmap.forEach((step, i) => { %>
          <div class="rd-step">
            <div class="rd-left">
              <div class="rd-num"><%= step.step || (i+1) %></div>
              <% if (i < guide.roadmap.length - 1) { %><div class="rd-line"></div><% } %>
            </div>
            <div class="rd-body">
              <div class="rd-title"><%= step.title %></div>
              <div class="rd-desc"><%= step.desc %></div>
              <% if (step.tag) { %><span class="rd-tag"><%= step.tag %></span><% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- ── 04 Syllabus ── -->
      <% if (guide?.syllabus?.length) { %>
      <section class="ed-section" id="sec-syllabus">
        <div class="sec-header">
          <span class="sec-num">04</span>
          <h2 class="sec-title">Paper-wise Syllabus</h2>
        </div>
        <div class="ed-syllabus">
          <% guide.syllabus.forEach((paper, idx) => { %>
          <div class="syl-paper <%= idx === 0 ? 'open' : '' %>" data-paper="<%= idx %>">
            <div class="syl-head">
              <div class="syl-name">
                <span class="syl-dot dot-<%= paper.colorClass || 'default' %>"></span>
                <%= paper.paperName %>
              </div>
              <div class="syl-right">
                <% if (paper.marks) { %><span class="syl-marks"><%= paper.marks %> marks</span><% } %>
                <svg class="syl-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </div>
            </div>
            <div class="syl-body">
              <div class="syl-topics">
                <% (paper.topics || []).forEach(topic => { %>
                  <span class="syl-chip"><%= topic %></span>
                <% }) %>
              </div>
            </div>
          </div>
          <% }) %>
        </div>
        <% if (guide.tips) { %>
        <div class="ed-callout ed-callout-info" style="margin-top:20px">
          <span class="callout-icon">💡</span>
          <div><strong>Pro Tip:</strong> <%= guide.tips %></div>
        </div>
        <% } %>
      </section>
      <% } %>

      <!-- ── 05 ELIGIBILITY (moved to main) ── -->
      <% const elig = guide?.eligibility; %>
      <section class="ed-section" id="sec-eligibility">
        <div class="sec-header">
          <span class="sec-num">05</span>
          <h2 class="sec-title">Eligibility Criteria</h2>
        </div>
        <div class="elig-grid">
          <% if (elig?.nationality) { %>
          <div class="elig-card">
            <div class="elig-card-icon">🌐</div>
            <div class="elig-card-label">Nationality</div>
            <div class="elig-card-val"><%= elig.nationality %></div>
          </div>
          <% } %>
          <% if ((elig?.ageMin && elig?.ageMax) || (stats?.ageMin && stats?.ageMax)) { %>
          <div class="elig-card">
            <div class="elig-card-icon">🎂</div>
            <div class="elig-card-label">Age Limit</div>
            <div class="elig-card-val"><%= elig?.ageMin || stats?.ageMin %>–<%= elig?.ageMax || stats?.ageMax %> years</div>
            <% if (elig?.ageRelaxNote) { %>
            <div class="elig-card-note"><%= elig.ageRelaxNote %></div>
            <% } %>
          </div>
          <% } %>
          <% if (elig?.education) { %>
          <div class="elig-card elig-card-wide">
            <div class="elig-card-icon">🎓</div>
            <div class="elig-card-label">Educational Qualification</div>
            <div class="elig-card-val"><%= elig.education %></div>
          </div>
          <% } %>
          <% if (elig?.attemptsGen) { %>
          <div class="elig-card">
            <div class="elig-card-icon">🔄</div>
            <div class="elig-card-label">Attempts (General)</div>
            <div class="elig-card-val"><%= elig.attemptsGen %></div>
          </div>
          <% } %>
          <% if (elig?.attemptsOBC) { %>
          <div class="elig-card">
            <div class="elig-card-icon">🔄</div>
            <div class="elig-card-label">Attempts (OBC)</div>
            <div class="elig-card-val"><%= elig.attemptsOBC %></div>
          </div>
          <% } %>
          <% if (elig?.attemptsScSt) { %>
          <div class="elig-card">
            <div class="elig-card-icon">🔄</div>
            <div class="elig-card-label">Attempts (SC/ST)</div>
            <div class="elig-card-val"><%= elig.attemptsScSt %></div>
          </div>
          <% } %>
          <% if (stats?.fee) { %>
          <div class="elig-card">
            <div class="elig-card-icon">💳</div>
            <div class="elig-card-label">Application Fee</div>
            <div class="elig-card-val">₹<%= stats.fee.general %> <% if (stats.fee.scSt !== undefined) { %><span style="font-size:12px;font-weight:400;opacity:.65">/ SC·ST Free</span><% } %></div>
          </div>
          <% } %>
        </div>
      </section>

      <!-- ── 06 Books ── -->
      <% if (guide?.books?.length) { %>
      <section class="ed-section" id="sec-books">
        <div class="sec-header">
          <span class="sec-num">06</span>
          <h2 class="sec-title">Recommended Books</h2>
        </div>
        <div class="ed-books">
          <% guide.books.forEach(book => { %>
          <div class="book-card">
            <div class="book-spine" style="background:<%= book.color || '#6366f1' %>"></div>
            <div class="book-info">
              <div class="book-title"><%= book.title %></div>
              <div class="book-author"><%= book.author %></div>
              <div class="book-sub"><%= book.subject %></div>
            </div>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- ── 07 Important Dates ── -->
      <% if (stats?.importantDates?.length) { %>
      <section class="ed-section" id="sec-dates">
        <div class="sec-header">
          <span class="sec-num">07</span>
          <h2 class="sec-title">Key Dates & Timeline</h2>
        </div>
        <div class="ed-timeline">
          <% stats.importantDates.forEach((d, i) => { %>
          <div class="tl-row tl-<%= d.status %>">
            <div class="tl-dot-wrap">
              <div class="tl-dot"></div>
              <% if (i < stats.importantDates.length - 1) { %><div class="tl-line"></div><% } %>
            </div>
            <div class="tl-body">
              <div class="tl-event"><%= d.event %></div>
              <div class="tl-date">
                <% if (d.isString) { %>
                  <%= d.date %>
                <% } else if (d.date) { %>
                  <%= new Date(d.date).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %>
                <% } else { %>
                  TBA
                <% } %>
              </div>
            </div>
            <% if (d.status === 'active') { %><span class="tl-live">ACTIVE</span><% } %>
            <% if (d.status === 'upcoming') { %><span class="tl-upcoming">UPCOMING</span><% } %>
          </div>
          <% }) %>
        </div>
      </section>
      <% } %>

    </main>

    <!-- ════ SIDEBAR ════ -->
    <aside class="ed-sidebar">

      <!-- Quick Links Card -->
    <div class="sb-card sb-card-links">
      <div class="sb-card-head">Quick Links</div>
      <div class="sb-card-body">
        <%
          const applyHref2 = (stats?.source === 'job') ? (stats?.applyLink || guide?.applyLink) : stats?.applyLink;
          const officialHref2 = stats?.officialSite || guide?.officialSite;
          const pdfHref2 = (stats?.source !== 'result') ? (stats?.notificationLink || guide?.notificationPdfLink) : null;
          const admitHref2 = (stats?.source !== 'result') ? stats?.downloadLink : null;
          const resultHref2   = stats?.resultLink;
          const meritHref2    = stats?.meritListLink;
        %>

        <% if (applyHref2) { %>
        <a href="<%= applyHref2 %>" target="_blank" class="sb-link sb-link-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Apply Online
          <svg class="sb-arr" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <% } %>

        <% if (officialHref2) { %>
        <a href="<%= officialHref2 %>" target="_blank" class="sb-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Official Website
        </a>
        <% } %>

        <% if (pdfHref2) { %>
        <a href="<%= pdfHref2 %>" target="_blank" class="sb-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Notification PDF
        </a>
        <% } %>

        <% if (admitHref2) { %>
        <a href="<%= admitHref2 %>" target="_blank" class="sb-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          Download Admit Card
        </a>
        <% } %>

        <% if (resultHref2) { %>
        <a href="<%= resultHref2 %>" target="_blank" class="sb-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
          View Result
        </a>
        <% } %>

        <% if (meritHref2) { %>
        <a href="<%= meritHref2 %>" target="_blank" class="sb-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          Merit List
        </a>
        <% } %>

      </div>
    </div>

      <!-- TOC -->
      <div class="sb-card">
        <div class="sb-card-head">On This Page</div>
        <div class="sb-card-body sb-toc-body">
          <nav class="sb-toc">
            <% if (guide?.overview) { %><a href="#sec-overview"   class="sb-toc-link active"><span>01</span> Overview</a><% } %>
            <% if (guide?.stages?.length) { %><a href="#sec-structure" class="sb-toc-link"><span>02</span> Exam Structure</a><% } %>
            <% if (guide?.roadmap?.length) { %><a href="#sec-roadmap"   class="sb-toc-link"><span>03</span> Preparation Roadmap</a><% } %>
            <% if (guide?.syllabus?.length) { %><a href="#sec-syllabus"  class="sb-toc-link"><span>04</span> Syllabus</a><% } %>
            <a href="#sec-eligibility" class="sb-toc-link"><span>05</span> Eligibility</a>
            <% if (guide?.books?.length) { %><a href="#sec-books"     class="sb-toc-link"><span>06</span> Books</a><% } %>
            <% if (stats?.importantDates?.length) { %><a href="#sec-dates"     class="sb-toc-link"><span>07</span> Key Dates</a><% } %>
          </nav>
        </div>
      </div>

      <!-- At-a-glance card -->
      <% if (stats) { %>
      <div class="sb-card sb-glance">
        <div class="sb-card-head">At a Glance</div>
        <div class="sb-card-body">
          <% if (stats.totalPosts) { %>
          <div class="glance-row">
            <span class="glance-k">Vacancies</span>
            <span class="glance-v glance-blue"><%= stats.totalPosts.toLocaleString('en-IN') %></span>
          </div>
          <% } %>
          <% if (stats.examDate) { %>
          <div class="glance-row">
            <span class="glance-k">Exam Date</span>
            <span class="glance-v glance-amber"><%= stats.examDate %></span>
          </div>
          <% } %>
          <% if (stats.applyLastDate) { %>
          <div class="glance-row">
            <span class="glance-k">Apply By</span>
            <span class="glance-v glance-red"><%= new Date(stats.applyLastDate).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></span>
          </div>
          <% } %>
          <% if (stats.ageMin && stats.ageMax) { %>
          <div class="glance-row">
            <span class="glance-k">Age</span>
            <span class="glance-v"><%= stats.ageMin %>–<%= stats.ageMax %> yrs</span>
          </div>
          <% } %>
          <% if (stats.fee?.general) { %>
          <div class="glance-row">
            <span class="glance-k">Fee</span>
            <span class="glance-v">₹<%= stats.fee.general %></span>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>

    </aside>
  </div>
</div>

<% } %>
</div>

<%- include('common/footer') %>
<script src="/nokari/js/examdetail.js"></script>