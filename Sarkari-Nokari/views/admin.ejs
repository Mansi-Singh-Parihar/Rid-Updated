      </div>
      <div class="ff">
        <label><i class="fas fa-calendar-check"></i> Result Date <span class="req">*</span></label>
        <input type="date" id="result_date">
      </div>
    </div>

    <!-- RESULT DETAILS -->
    <div class="fdiv">Result Details</div>
    <div class="fgrid g3">
      <div class="ff">
        <label><i class="fas fa-list-ol"></i> Result Type</label>
        <select id="result_type">
          <option value="">Select type…</option>
          <option>Prelims Result</option>
          <option>Mains Result</option>
          <option>Skill Test Result</option>
          <option>Final Result</option>
          <option>Scorecard</option>
          <option>Merit List</option>
          <option>Interview List</option>
          <option>Cut Off Marks</option>
        </select>
      </div>
      <div class="ff">
        <label><i class="fas fa-users"></i> Total Posts</label>
        <input type="number" id="result_totalposts" placeholder="e.g., 7510">
      </div>
    </div>

    <!-- SELECTION PROCESS -->
    <div class="fdiv">Selection Process</div>
    <div class="fgrid g1">
      <div class="ff">
        <label><i class="fas fa-list-ol"></i> Selection Steps (comma separated)</label>
        <input type="text" id="result_selection" placeholder="e.g., Written Test, Interview, Document Verification">
        <small style="color:#888; margin-top:4px; display:block;">Separate each step with a comma</small>
      </div>
    </div>

    <!-- LINKS -->
    <div class="fdiv">Links</div>
    <div class="fgrid g3">
      <div class="ff">
        <label><i class="fas fa-external-link-alt"></i> Result Link <span class="req">*</span></label>
        <input type="url" id="result_link" placeholder="https://ssc.nic.in/result/2024">
      </div>
      <div class="ff">
        <label><i class="fas fa-globe"></i> Official Site</label>
        <input type="url" id="result_officialsite" placeholder="https://ssc.nic.in">
      </div>
      <div class="ff">
        <label><i class="fas fa-file-pdf"></i> Merit List Link (optional)</label>
        <input type="url" id="result_meritlink" placeholder="https://ssc.nic.in/merit-list.pdf">
      </div>
    </div>
    <!-- STATE -->
<div class="fdiv">State</div>
<div class="fgrid g1">
  <div class="ff">
    <label><i class="fas fa-map-marker-alt"></i> State</label>
      <input
        type="text"
        id="result_state"
        placeholder="State short code (mp, up, central)"
      >
  </div>
</div>

    <!-- BUTTONS -->
    <div class="btn-row">
      <button class="btn btn-pub" onclick="addResult()">
        <i class="fas fa-paper-plane"></i> Publish Result
      </button>
      <button class="btn btn-clr" onclick="clearResultForm()">
        <i class="fas fa-undo"></i> Clear Fields
      </button>
    </div>

  </div>

  <!-- LIST -->
<div class="list-card">
  <div class="list-head">
    <div class="list-head-left">
      <div class="list-head-icon"><i class="fas fa-trash-alt"></i></div>
      Existing Result Entries
    </div>
    <span class="entry-count" id="results-count">0 entries</span>
  </div>
  <!-- SEARCH BAR -->
  <div class="list-search">
    <i class="fas fa-search list-search-icon"></i>
