        function getCommentStyle(langId) {
          // Returns the lineComment token used by CodeMirror comment addon
          const map = {
            py: "#", // Python  → # comment
            js: "//", // JS      → // comment
            cpp: "//", // C++     → // comment
            c: "//", // C       → // comment
            java: "//", // Java    → // comment
            cs: "//", // C#      → // comment
          };
          return map[langId] || "//";
