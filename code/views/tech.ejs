        // ── Execute code ──────────────────────────────────────────────
        async function executeCode(e) {
          e.preventDefault();

          const btn = e.currentTarget;
          const qid = btn.dataset.qid;
          const langId = btn.dataset.lang;
          const outputDiv = document.getElementById(`output-${qid}`);

