          text-align: center;
        }
        .social-links {
          justify-content: center;
        }
        .pagination-controls {
          flex-direction: column;
          gap: 10px;
        }
        .pagination-btn {
          width: 100%;
        }
      }
      @media (max-width: 768px) {
        .footer {
          padding: 2rem 1.2rem 1rem;
          margin-top: 2.5rem;
