      const homeDiv = document.getElementById("home-page");
      const detailContainer = document.getElementById("detail-page-container");

      function showDetail(key) {
        const data = teamData[key];
        if (!data) return;
        homeDiv.style.display = "none";
        detailContainer.style.display = "block";
        let pointsHtml = "";
        if (data.points && data.points.length) {
          pointsHtml = "<ul>" + data.points.map(p => `<li>${p}</li>`).join("") + "</ul>";
        }
        detailContainer.innerHTML = `
          <div class="detail-page">
            <div class="detail-page-header">
              <div class="detail-page-pic"><img src="${data.img}" onerror="this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(data.name)}&size=110&background=083d5d&color=fff'"></div>
              <div class="detail-page-text"><h1>${data.name}</h1><span class="detail-page-role">${data.role}</span></div>
            </div>
            <div class="detail-page-bio"><p>${data.bio}</p>${pointsHtml}</div>
            <a href="#" class="back-btn" id="backBtn"><i class="fas fa-arrow-left"></i> Back to Team</a>
          </div>
        `;
        const backBtn = document.getElementById("backBtn");
        if (backBtn) backBtn.addEventListener("click", (e) => {
          e.preventDefault();
          homeDiv.style.display = "block";
          detailContainer.style.display = "none";
          detailContainer.innerHTML = "";
          window.history.pushState({}, "", window.location.pathname);
        });
        window.scrollTo({ top: 0, behavior: "smooth" });
      }

      // Attach explore buttons
      document.querySelectorAll(".explore-btn").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.preventDefault();
          const profileId = btn.getAttribute("data-explore");
          if (profileId && teamData[profileId]) {
            showDetail(profileId);
            window.history.pushState({}, "", `?page=${profileId}`);
          }
        });
      });

      // initial check for URL param
      const urlParam = new URLSearchParams(window.location.search).get("page");
      if (urlParam && teamData[urlParam]) showDetail(urlParam);
      else {
        homeDiv.style.display = "block";
        detailContainer.style.display = "none";
      }
    })();

   const menuIcon = document.getElementById("menuIcon");
const menu = document.getElementById("innerCont");

menuIcon.addEventListener("click", () => {
    menu.style.display =
      menu.style.display === "block" ? "none" : "block";
});
