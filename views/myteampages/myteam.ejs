  <style>
    /* ===== CLEAN, MINIMAL STYLES – NO EXTRA CSS, FIXED GRID & BUTTON ALIGNMENT ===== */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #083d5d;
      --accent: #ff6b35;
      --white: #ffffff;
      --shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
    }

    body {
      font-family: "Poppins", system-ui, -apple-system, sans-serif;
      background-color: #f5f7fb;
      color: #1e2f3e;
      line-height: 1.4;
      padding-top: 130px;
      overflow-x: hidden;
    }

    /* main wrapper */
    .content-wrap {
      max-width: 1300px;
      margin: 1rem auto 1.5rem auto;
      padding: 0 1.2rem;
      width: 100%;
    }

    /* headings */
    .section-heading {
      font-size: 1.7rem;
      font-weight: 600;
      color: #003057;
      margin: 1.5rem 0 1rem 0;
      text-align: center;
      position: relative;
    }

    .section-heading::after {
      content: "";
      display: block;
      width: 65px;
      height: 3px;
      background: var(--accent);
      margin: 0.4rem auto 0;
      border-radius: 3px;
    }

    .section-sub {
      font-size: 1.2rem;
      color: var(--primary);
      margin: 1rem 0 0.8rem 0;
      font-weight: 500;
      text-align: center;
    }

    /* GRID – clean wave / responsive layout */
    .profile-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
      gap: 1.2rem;
      margin-bottom: 1rem;
    }

    /* CARD – flex column to make button stick at bottom */
    .profile-card {
      background: var(--white);
      border-radius: 20px;
      box-shadow: 0 6px 14px rgba(0, 20, 40, 0.05);
      padding: 1rem 0.9rem 1rem 0.9rem;
      display: flex;
      flex-direction: column;
      border: 1px solid #e2ecf5;
      transition: all 0.2s ease;
      width: 100%;
      height: 100%;
    }

    .profile-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 14px 22px -10px rgba(8, 61, 93, 0.12);
      border-color: #cbdbe0;
    }

    /* image container */
    .profile-pic {
      display: flex;
      justify-content: center;
      margin-bottom: 0.6rem;
    }

    .pic-frame {
      width: 85px;
      height: 85px;
      border-radius: 50%;
      background: #eef3fc;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 2px solid white;
      outline: 1px solid #cfe0ef;
      box-shadow: 0 4px 8px rgba(0, 0, 0, 0.05);
      overflow: hidden;
    }

    .pic-frame img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      border-radius: 50%;
    }

    /* name + role */
    .profile-name {
      text-align: center;
      margin: 0.2rem 0 0.2rem;
    }

    .profile-name h2 {
      font-size: 1rem;
      font-weight: 650;
      color: #00263b;
      line-height: 1.25;
    }

    .profile-name .role {
      font-size: 0.62rem;
      background: #eef2f9;
      display: inline-block;
      padding: 0.2rem 0.8rem;
      border-radius: 40px;
      color: #1f5a87;
      font-weight: 600;
      margin-top: 5px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }

    /* description – flexible text */
    .profile-description {
      margin: 0.5rem 0 0.6rem;
      background: #fafeff;
      padding: 0.5rem 0.4rem;
      border-radius: 14px;
      border-left: 2px solid var(--accent);
      color: #1f4970;
      font-size: 0.7rem;
      line-height: 1.4;
      text-align: center;
    }

    /* EXPLORE BUTTON – fixed alignment at bottom (margin-top: auto) */
    .explore-btn {
      background: white;
      border: 1.5px solid #1f4973;
      color: #1f4973;
      padding: 0.35rem 1rem;
      border-radius: 40px;
      font-weight: 600;
      font-size: 0.7rem;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      transition: 0.2s;
      width: fit-content;
      margin: 0.6rem auto 0.1rem auto;
      text-decoration: none;
      background: #ffffff;
    }

    .explore-btn i {
      font-size: 0.6rem;
      transition: transform 0.15s;
    }

    .explore-btn:hover {
      background: #1f4973;
      color: white;
      border-color: #1f4973;
      transform: scale(1.02);
    }

    .explore-btn:hover i {
      transform: translateX(3px);
    }

    /* DETAIL PAGE (full bio view) */
    .detail-page {
      max-width: 900px;
      margin: 2rem auto;
      padding: 1.8rem;
      background: white;
      border-radius: 28px;
      box-shadow: 0 20px 35px rgba(0, 30, 60, 0.08);
      border: 1px solid #d4e2f0;
    }

    .detail-page-header {
      display: flex;
      gap: 2rem;
      align-items: center;
      border-bottom: 2px solid #ffd6a4;
      padding-bottom: 1.2rem;
      margin-bottom: 1.5rem;
      flex-wrap: wrap;
    }

    .detail-page-pic {
      width: 110px;
      height: 110px;
      border-radius: 50%;
      background: #eef3fc;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.05);
      border: 3px solid white;
      outline: 1px solid #bcd0e5;
    }

    .detail-page-pic img {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    .detail-page-text h1 {
      font-size: 1.8rem;
      color: #00243d;
    }

    .detail-page-role {
      background: #1f4973;
      color: white;
      padding: 0.2rem 1.2rem;
      border-radius: 50px;
      font-size: 0.85rem;
      display: inline-block;
    }

    .detail-page-bio {
      font-size: 0.95rem;
      line-height: 1.5;
      color: #1f3b58;
      margin: 1.2rem 0;
    }

    .detail-page-bio ul {
      list-style: disc;
      margin-left: 1.2rem;
      margin-top: 0.8rem;
    }

    .detail-page-bio li {
      margin-bottom: 0.4rem;
      font-size: 0.9rem;
    }

    .back-btn {
      display: inline-block;
      margin-top: 1rem;
      background: #eef4fa;
      padding: 0.5rem 1.5rem;
      border-radius: 40px;
      color: #1e4570;
      font-weight: 600;
      text-decoration: none;
      border: 1px solid #bdd2ea;
      font-size: 0.85rem;
      transition: 0.2s;
    }

    .back-btn:hover {
      background: #e2eaf3;
    }

    /* responsive */
    @media (max-width: 680px) {
      .profile-grid {
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 0.9rem;
      }

      .profile-card {
        padding: 0.8rem 0.6rem;
      }

      .pic-frame {
        width: 72px;
        height: 72px;
      }

      .profile-name h2 {
        font-size: 0.9rem;
      }

      .detail-page-header {
        flex-direction: column;
        text-align: center;
        gap: 1rem;
      }

      .detail-page-text h1 {
        font-size: 1.5rem;
      }
    }
    #innerCont{
  display:none;
}

#innerCont.active{
  display:block !important;
  background:red;
}
@media (max-width:768px){

  #innerCont{
    position: fixed;
    top: 80px;
    left: -100%;
    width: 100%;
    height: calc(100vh - 80px);
    background: #fff;
    overflow-y: auto;
    transition: all .3s ease;
    z-index: 9999;
  }

  #innerCont.active{
    left: 0 !important;
    display: block !important;
  }

  .menu-icon{
    cursor:pointer;
  }
}
