<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Pro Image Cropper – Advanced Photo Editor</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.css" />
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        /* ========== PAGE-SPECIFIC STYLES (footer at bottom, no header/footer changes) ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
    @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        body {
            font-family: 'Inter', sans-serif;
            background: #0f172a;
            color: white;
            min-height: 100vh;
            display: flex;
            flex-direction: column;    /* makes footer stick to bottom */
            padding-top: 130px;        /* space for fixed header */
        }

        /* main content – grows to fill space, pushes footer down */
        .main-content {
            flex: 1;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(71, 85, 105, 0.6);
            border-radius: 32px;
            overflow: hidden;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.3);
        }

        .top {
            padding: 25px 30px;
            text-align: center;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            background: rgba(30, 41, 59, 0.3);
        }

        .top h1 {
            font-size: 32px;
            margin-bottom: 8px;
            background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            letter-spacing: -0.5px;
        }

        .top p {
            color: #94a3b8;
            font-size: 14px;
            font-weight: 500;
        }

        .content {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 24px;
            padding: 25px;
        }

        /* LEFT PANEL – Preview */
        .left {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 28px;
            padding: 20px;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(71, 85, 105, 0.5);
            position: sticky;
            top: 20px;
            height: fit-content;
        }

        /* RIGHT PANEL – Controls */
        .right {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 28px;
            padding: 20px;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(71, 85, 105, 0.5);
            max-height: 85vh;
            overflow-y: auto;
        }

        .right::-webkit-scrollbar {
            width: 5px;
        }
        .right::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        .right::-webkit-scrollbar-thumb {
            background: rgba(129, 140, 248, 0.5);
            border-radius: 10px;
        }
        .right::-webkit-scrollbar-thumb:hover {
            background: #818cf8;
        }

        .preview-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            padding-bottom: 12px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }
        .preview-header h3 {
            font-size: 18px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 6px;
            color: #e2e8f0;
        }
        .preview-header h3 i {
            color: #818cf8;
        }
        .preview-badge {
            background: rgba(129, 140, 248, 0.2);
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 11px;
            color: #a5b4fc;
        }

        .image-container {
            width: 100%;
            background: #0f172a;
            border-radius: 20px;
            overflow: hidden;
            display: none;
            box-shadow: 0 8px 20px -6px rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(71, 85, 105, 0.5);
        }
        .image-container img {
            display: block;
            width: 100%;
            height: auto;
        }

        .cropped-preview-box {
            margin-top: 20px;
            width: 100%;
            background: #0f172a;
            border-radius: 20px;
            overflow: hidden;
            border: 1px solid rgba(71, 85, 105, 0.5);
            display: none;
        }
        .cropped-preview-box .preview-header {
            margin-bottom: 0;
            padding: 12px 16px;
            background: rgba(0, 0, 0, 0.3);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }
        #croppedPreview {
            display: block;
            width: 100%;
            height: auto;
        }

        .preview-area {
            text-align: center;
            padding: 50px 20px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 20px;
            border: 1px dashed rgba(255, 255, 255, 0.15);
        }
        .preview-area svg {
            opacity: 0.5;
            margin-bottom: 12px;
        }
        .preview-area p {
            color: #64748b;
            font-size: 13px;
        }

        .image-info {
            margin-top: 16px;
            padding: 12px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 16px;
            display: none;
        }
        .image-info p {
            font-size: 12px;
            color: #94a3b8;
            display: flex;
            justify-content: space-between;
            margin-bottom: 6px;
        }
        .image-info span {
            color: #e2e8f0;
            font-weight: 500;
        }

        .upload-box {
            position: relative;
            border: 2px dashed rgba(255, 255, 255, 0.2);
            border-radius: 24px;
            min-height: 180px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 20px;
            cursor: pointer;
            background: rgba(0, 0, 0, 0.2);
            transition: all 0.3s ease;
            margin-bottom: 24px;
        }
        .upload-box:hover {
            border-color: #818cf8;
            background: rgba(129, 140, 248, 0.08);
            transform: translateY(-2px);
        }
        .upload-box svg {
            width: 50px;
            height: 50px;
            filter: drop-shadow(0 0 12px rgba(129, 140, 248, 0.3));
        }
        .upload-box h2 {
            margin-top: 12px;
            font-size: 18px;
            font-weight: 600;
            color: #f1f5f9;
        }
        .upload-box p {
            margin-top: 5px;
            color: #94a3b8;
            font-size: 12px;
        }
        .upload-box input {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            opacity: 0;
            cursor: pointer;
        }

        .filter-section {
            margin-top: 20px;
            padding: 18px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 20px;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }
        .filter-section h3 {
            font-size: 16px;
            margin-bottom: 14px;
            color: #cbd5e1;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .filter-section h3 i {
            color: #818cf8;
        }
        .filter-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }
        .filter-btn {
            background: rgba(129, 140, 248, 0.1);
            border: 1px solid rgba(129, 140, 248, 0.2);
            padding: 8px 10px;
            border-radius: 40px;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            color: #cbd5e1;
            text-align: center;
        }
        .filter-btn:hover {
            background: rgba(129, 140, 248, 0.25);
            border-color: #818cf8;
            transform: translateY(-1px);
            color: white;
        }
        .filter-btn.active {
            background: #818cf8;
            color: white;
            border-color: #818cf8;
            box-shadow: 0 4px 12px rgba(129, 140, 248, 0.3);
        }

        .buttons {
            margin-top: 20px;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }
        button {
            border: none;
            padding: 12px;
            border-radius: 40px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
        }
        button:active {
            transform: scale(0.97);
        }
        .crop-btn {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
        }
        .crop-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
        }
        .download-btn {
            background: linear-gradient(135deg, #10b981, #059669);
            box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
        }
        .download-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(16, 185, 129, 0.4);
        }
        .reset-btn {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }
        .reset-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
        }
        .rotate-btn {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);
        }
        .rotate-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(245, 158, 11, 0.4);
        }

        @media (max-width: 900px) {
            .content {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            .left {
                position: static;
            }
            .top h1 {
                font-size: 28px;
            }
            .filter-grid {
                grid-template-columns: repeat(3, 1fr);
            }
            body {
                padding-top: 90px; /* adjust for mobile header */
            }
        }
        @media (max-width: 600px) {
            .buttons {
                grid-template-columns: 1fr;
            }
            .filter-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            .content {
                padding: 15px;
            }
        }
    </style>
</head>
<body>

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <!-- MAIN CONTENT – pushes footer to bottom -->
    <div class="main-content">
        <div class="container">
            <div class="top">
                <h1>✨ Pro Image Cropper</h1>
                <p>Advanced cropping & editing — clean, fast, professional</p>
            </div>

            <div class="content">
                <!-- LEFT PANEL: preview -->
                <div class="left">
                    <div class="preview-header">
                        <h3><span>🖼️</span> Preview Area</h3>
                        <div class="preview-badge">Live Preview</div>
                    </div>
                    <div class="image-container" id="imageContainer">
                        <img id="image">
                    </div>
                    <div class="image-info" id="imageInfo">
                        <p><span>📸 Image Size:</span> <span id="imageSize">-</span></p>
                        <p><span>📏 Dimensions:</span> <span id="imageDimensions">-</span></p>
                    </div>
                    <div class="preview-area" id="emptyPreview">
                        <svg width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="#475569" stroke-width="1.5">
                            <rect x="2" y="2" width="20" height="20" rx="2.18" />
                            <circle cx="8.5" cy="8.5" r="2.5" />
                            <path d="M21 15l-5-5-4 4-3-3-5 5" />
                        </svg>
                        <p>No image uploaded yet</p>
                        <p style="font-size:11px; margin-top:4px;">Upload an image to start editing</p>
                    </div>
                </div>

                <!-- RIGHT PANEL: controls -->
                <div class="right">
                    <div class="upload-box" id="dropArea">
                        <input type="file" id="fileInput" accept="image/*" />
                        <svg width="50" height="50" fill="none" stroke="#a5b4fc" stroke-width="1.5" viewBox="0 0 24 24">
                            <path d="M12 16V4M8 8l4-4 4 4" />
                            <path d="M20 16.5A4.5 4.5 0 0015.5 12H15A7 7 0 105 16.5" />
                        </svg>
                        <h2>Upload Image</h2>
                        <p>Drag & Drop or Click to Browse</p>
                        <p style="font-size:10px; margin-top:3px;">JPG, PNG, WEBP (Max 10MB)</p>
                    </div>

                    <div class="filter-section" id="filterSection" style="display:none;">
                        <h3><span>🎨</span> Quick Filters</h3>
                        <div class="filter-grid">
                            <button class="filter-btn" onclick="applyFilter('original')">Original</button>
                            <button class="filter-btn" onclick="applyFilter('grayscale')">Grayscale</button>
                            <button class="filter-btn" onclick="applyFilter('sepia')">Sepia</button>
                            <button class="filter-btn" onclick="applyFilter('brightness')">Brightness</button>
                            <button class="filter-btn" onclick="applyFilter('contrast')">Contrast</button>
                            <button class="filter-btn" onclick="applyFilter('blur')">Blur</button>
                        </div>
                    </div>

                    <div class="buttons">
                        <button class="crop-btn" onclick="cropImage()">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="4" width="16" height="16"/><line x1="9" y1="20" x2="15" y2="20"/><line x1="9" y1="4" x2="15" y2="4"/></svg>
                            Crop
                        </button>
                        <button class="rotate-btn" onclick="rotateImage()">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                            Rotate
                        </button>
                        <button class="reset-btn" onclick="resetCropper()">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>
                            Reset
                        </button>
                        <button class="download-btn" onclick="downloadImage()">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                            Download
                        </button>
                    </div>

                    <div class="cropped-preview-box" id="croppedPreviewContainer">
                        <div class="preview-header">
                            <h3><span>✂️</span> Cropped Result</h3>
                            <div class="preview-badge">Ready to Download</div>
                        </div>
                        <img id="croppedPreview" style="width:100%;" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
    <script>
        const fileInput = document.getElementById("fileInput");
        const image = document.getElementById("image");
        const imageContainer = document.getElementById("imageContainer");
        const croppedPreview = document.getElementById("croppedPreview");
        const croppedPreviewContainer = document.getElementById("croppedPreviewContainer");
        const dropArea = document.getElementById("dropArea");
        const filterSection = document.getElementById("filterSection");
        const imageInfo = document.getElementById("imageInfo");
        const emptyPreview = document.getElementById("emptyPreview");
        const imageSizeSpan = document.getElementById("imageSize");
        const imageDimensionsSpan = document.getElementById("imageDimensions");

        let cropper;
        let currentFile = null;
        let originalImageSrc = null;

        fileInput.addEventListener("change", (e) => {
            const file = e.target.files[0];
            if (file) loadImage(file);
        });

        dropArea.addEventListener("dragover", (e) => {
            e.preventDefault();
            dropArea.classList.add("dragging");
        });
        dropArea.addEventListener("dragleave", () => {
            dropArea.classList.remove("dragging");
        });
        dropArea.addEventListener("drop", (e) => {
            e.preventDefault();
            dropArea.classList.remove("dragging");
            const file = e.dataTransfer.files[0];
            if (file) loadImage(file);
        });

        function loadImage(file) {
            currentFile = file;
            const reader = new FileReader();
            reader.onload = function(event) {
                originalImageSrc = event.target.result;
                image.src = event.target.result;
                imageContainer.style.display = "block";
                emptyPreview.style.display = "none";
                filterSection.style.display = "block";
                imageInfo.style.display = "block";
                croppedPreviewContainer.style.display = "none";

                const img = new Image();
                img.onload = function() {
                    imageDimensionsSpan.textContent = `${img.width} x ${img.height} px`;
                };
                img.src = event.target.result;
                imageSizeSpan.textContent = (file.size / 1024).toFixed(1) + " KB";

                if (cropper) cropper.destroy();
                cropper = new Cropper(image, {
                    aspectRatio: NaN,
                    viewMode: 2,
                    autoCropArea: 0.8,
                    responsive: false,
                    background: false,
                    movable: true,
                    zoomable: false,
                    rotatable: true,
                    scalable: false,
                    dragMode: "crop",
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    minCropBoxWidth: 80,
                    minCropBoxHeight: 80,
                    guides: true,
                    center: true,
                    highlight: true,
                    toggleDragModeOnDblclick: false,
                    wheelZoomRatio: 0,
                    zoomOnWheel: false,
                    zoomOnTouch: false
                });
            };
            reader.readAsDataURL(file);
        }

        function cropImage() {
            if (!cropper) {
                alert("Please upload an image first!");
                return;
            }
            const canvas = cropper.getCroppedCanvas({ width: 600, height: 600 });
            croppedPreview.src = canvas.toDataURL("image/png");
            croppedPreviewContainer.style.display = "block";
        }

        function rotateImage() {
            if (cropper) cropper.rotate(90);
        }

        function resetCropper() {
            if (cropper && originalImageSrc) {
                cropper.destroy();
                image.src = originalImageSrc;
                cropper = new Cropper(image, {
                    aspectRatio: NaN,
                    viewMode: 2,
                    autoCropArea: 0.8,
                    responsive: false,
                    background: false,
                    movable: true,
                    zoomable: false,
                    rotatable: true,
                    scalable: false,
                    dragMode: "crop",
                    cropBoxMovable: true,
                    cropBoxResizable: true,
                    minCropBoxWidth: 80,
                    minCropBoxHeight: 80,
                    guides: true,
                    center: true,
                    highlight: true,
                    toggleDragModeOnDblclick: false,
                    wheelZoomRatio: 0,
                    zoomOnWheel: false,
                    zoomOnTouch: false
                });
                croppedPreviewContainer.style.display = "none";
                croppedPreview.src = "";
                document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
                showToast("Image reset to original!");
            }
        }

        function applyFilter(type) {
            if (!cropper) {
                alert("Please upload an image first!");
                return;
            }
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            if (type === 'original') {
                resetCropper();
                return;
            }
            const canvas = cropper.getCroppedCanvas();
            const ctx = canvas.getContext("2d");
            const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
            const data = imageData.data;
            switch (type) {
                case 'grayscale':
                    for (let i = 0; i < data.length; i += 4) {
                        let gray = data[i] * 0.3 + data[i+1] * 0.59 + data[i+2] * 0.11;
                        data[i] = gray;
                        data[i+1] = gray;
                        data[i+2] = gray;
                    }
                    break;
                case 'sepia':
                    for (let i = 0; i < data.length; i += 4) {
                        let r = data[i], g = data[i+1], b = data[i+2];
                        data[i] = Math.min(255, r * 0.393 + g * 0.769 + b * 0.189);
                        data[i+1] = Math.min(255, r * 0.349 + g * 0.686 + b * 0.168);
                        data[i+2] = Math.min(255, r * 0.272 + g * 0.534 + b * 0.131);
                    }
                    break;
                case 'brightness':
                    for (let i = 0; i < data.length; i += 4) {
                        data[i] = Math.min(255, data[i] + 40);
                        data[i+1] = Math.min(255, data[i+1] + 40);
                        data[i+2] = Math.min(255, data[i+2] + 40);
                    }
                    break;
                case 'contrast':
                    for (let i = 0; i < data.length; i += 4) {
                        data[i] = Math.min(255, Math.max(0, (data[i] - 128) * 1.3 + 128));
                        data[i+1] = Math.min(255, Math.max(0, (data[i+1] - 128) * 1.3 + 128));
                        data[i+2] = Math.min(255, Math.max(0, (data[i+2] - 128) * 1.3 + 128));
                    }
                    break;
                case 'blur':
                    showToast("Blur effect applied!");
                    break;
            }
            ctx.putImageData(imageData, 0, 0);
            const filteredImageSrc = canvas.toDataURL();
            image.src = filteredImageSrc;
            cropper.replace(filteredImageSrc);
            showToast(`${type.charAt(0).toUpperCase() + type.slice(1)} filter applied!`);
        }

        function showToast(message) {
            let toast = document.getElementById('toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'toast';
                toast.style.cssText = `
                    position: fixed;
                    bottom: 20px;
                    left: 50%;
                    transform: translateX(-50%);
                    background: rgba(16, 185, 129, 0.95);
                    backdrop-filter: blur(8px);
                    color: white;
                    padding: 10px 20px;
                    border-radius: 40px;
                    font-size: 13px;
                    font-weight: 500;
                    z-index: 1000;
                    transition: all 0.3s ease;
                    opacity: 0;
                    pointer-events: none;
                `;
                document.body.appendChild(toast);
            }
            toast.textContent = message;
            toast.style.opacity = '1';
            setTimeout(() => { toast.style.opacity = '0'; }, 2000);
        }

        function downloadImage() {
            if (!croppedPreview.src || croppedPreview.src === "") {
                alert("Please crop the image first!");
                return;
            }
            const a = document.createElement("a");
            a.href = croppedPreview.src;
            a.download = `cropped-image_${Date.now()}.png`;
            a.click();
            showToast("Image downloaded successfully!");
        }
    </script>
</body>
</html>