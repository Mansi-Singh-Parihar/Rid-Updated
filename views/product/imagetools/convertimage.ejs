<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Image Format Converter</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        /* ========== RESET & BASE (sticky footer) ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        body {
            font-family: 'Inter', sans-serif;
            background: #0f172a;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .main-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem 1rem;      /* reduced top/bottom padding */
        }

        /* ========== IMAGE CONVERTER PRO STYLES ========== */
        .app-container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .two-columns {
            display: flex;
            gap: 1.2rem;
            min-height: 55vh;           /* was 70vh – reduced height */
            align-items: stretch;
        }

        /* BOTH PANELS – same width & equal height */
        .preview-panel,
        .controls-panel {
            flex: 1;
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 24px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            padding: 1rem;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .controls-panel {
            backdrop-filter: blur(8px);
            background: rgba(0, 0, 0, 0.25);
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.6rem;      /* reduced margin */
            padding-bottom: 0.3rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        }
        .panel-header h3 {
            font-size: 1rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.4rem;
            color: #e2e8f0;
        }
        .badge {
            background: rgba(129, 140, 248, 0.2);
            padding: 0.15rem 0.5rem;
            border-radius: 40px;
            font-size: 0.6rem;
            color: #a5b4fc;
        }

        /* PREVIEW GRID */
        .preview-grid {
            flex: 1;
            overflow-y: auto;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 0.8rem;
            padding-right: 0.2rem;
        }
        .preview-grid::-webkit-scrollbar {
            width: 5px;
        }
        .preview-grid::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        .preview-grid::-webkit-scrollbar-thumb {
            background: rgba(129, 140, 248, 0.5);
            border-radius: 10px;
        }

        /* IMAGE CARD – smaller height (already 180px, fine) */
        .image-card {
            background: rgba(0, 0, 0, 0.35);
            border-radius: 1rem;
            overflow: hidden;
            transition: all 0.2s ease;
            border: 1px solid rgba(71, 85, 105, 0.5);
            display: flex;
            flex-direction: column;
            height: 180px;
        }
        .image-card:hover {
            transform: translateY(-2px);
            border-color: #818cf8;
            box-shadow: 0 6px 12px -6px rgba(0, 0, 0, 0.4);
        }
        .img-wrapper {
            flex: 1;
            background: #0f172a;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .img-wrapper img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .card-info {
            padding: 0.3rem;
            text-align: center;
        }
        .card-name {
            font-size: 0.65rem;
            font-weight: 500;
            color: #e2e8f0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .card-ext {
            font-size: 0.55rem;
            color: #a5b4fc;
            margin-top: 0.15rem;
            background: rgba(129, 140, 248, 0.15);
            display: inline-block;
            padding: 0.05rem 0.3rem;
            border-radius: 30px;
        }
        .card-actions {
            padding: 0.2rem;
            display: flex;
            justify-content: center;
        }
        .download-single {
            background: linear-gradient(135deg, #10b981, #059669);
            border: none;
            border-radius: 40px;
            padding: 0.15rem 0.6rem;
            font-size: 0.6rem;
            font-weight: 600;
            color: white;
            cursor: pointer;
            transition: 0.2s;
        }
        .download-single:hover {
            transform: translateY(-1px);
            filter: brightness(1.05);
        }

        .empty-state {
            text-align: center;
            padding: 1.2rem 1rem;      /* reduced padding */
            color: #64748b;
        }
        .empty-state svg {
            width: 30px;
            height: 30px;
            opacity: 0.5;
            margin-bottom: 0.5rem;
        }
        .empty-state p {
            font-size: 0.7rem;
        }

        /* RIGHT PANEL CONTROLS */
        .right-header h1 {
            font-size: 1.2rem;          /* slightly smaller */
            font-weight: 800;
            background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.3px;
        }
        .right-header p {
            color: #94a3b8;
            font-size: 0.6rem;
            margin-top: 0.15rem;
        }

        .upload-area {
            background: rgba(129, 140, 248, 0.05);
            border: 2px dashed rgba(129, 140, 248, 0.3);
            border-radius: 20px;
            padding: 0.6rem;            /* reduced padding */
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            margin: 0.3rem 0;
        }
        .upload-area:hover {
            background: rgba(129, 140, 248, 0.1);
            border-color: #818cf8;
            transform: translateY(-2px);
        }
        .upload-icon {
            font-size: 1.4rem;
        }
        .upload-title {
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 0.15rem;
            color: #f1f5f9;
        }
        .upload-sub {
            font-size: 0.5rem;
            color: #94a3b8;
            margin-top: 0.05rem;
        }

        .control-group {
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            margin-top: 0.3rem;
        }
        .control-row {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        select, button {
            padding: 0.35rem 0.6rem;
            border-radius: 40px;
            border: none;
            font-size: 0.65rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        select {
            flex: 1;
            background: #1e293b;
            color: white;
            border: 1px solid #475569;
        }
        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            color: white;
        }
        .add-more {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
        }
        .btn-danger {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
        }
        button:hover {
            transform: translateY(-1px);
            filter: brightness(1.05);
        }

        @media (max-width: 900px) {
            .two-columns {
                flex-direction: column;
                min-height: auto;
            }
            .preview-panel,
            .controls-panel {
                flex: none;
                width: 100%;
            }
            .preview-grid {
                grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
            }
        }
    </style>
</head>
<body>

    <!-- HEADER (EJS include) -->
    <%- include("common/header.ejs") %>

    <!-- MAIN CONVERTER CONTENT -->
    <div class="main-content">
        <div class="app-container">
            <div class="two-columns">
                <!-- LEFT PANEL – preview grid -->
                <div class="preview-panel">
                    <div class="panel-header">
                        <h3><span>🖼️</span> Image Gallery</h3>
                        <div class="badge" id="imageCountBadge">0 images</div>
                    </div>
                    <div id="previewGrid" class="preview-grid">
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.5">
                                <rect x="2" y="2" width="20" height="20" rx="2.18"/>
                                <circle cx="8.5" cy="8.5" r="2.5"/>
                                <path d="M21 15l-5-5-4 4-3-3-5 5"/>
                            </svg>
                            <p>No images yet</p>
                            <p style="font-size:0.6rem">Upload images from the right panel</p>
                        </div>
                    </div>
                </div>

                <!-- RIGHT PANEL – controls -->
                <div class="controls-panel">
                    <div class="right-header">
                        <h1>✨ Image Converter Pro</h1>
                        <p>Convert bulk images to PNG, JPG, WEBP or BMP</p>
                    </div>
                    <div class="upload-area" id="uploadArea">
                        <div class="upload-icon">📸</div>
                        <div class="upload-title">Upload Images</div>
                        <div class="upload-sub">Click or drag & drop</div>
                        <input type="file" id="fileInput" multiple accept="image/*" style="display:none">
                    </div>
                    <div class="control-group">
                        <div class="control-row">
                            <select id="formatSelect">
                                <option value="image/png">PNG</option>
                                <option value="image/jpeg">JPG</option>
                                <option value="image/webp">WEBP</option>
                                <option value="image/bmp">BMP</option>
                            </select>
                            <button id="convertBtn" class="btn-primary">🔄 Convert</button>
                        </div>
                        <div class="control-row">
                            <button id="addMoreBtn" class="add-more">➕ Add More</button>
                            <button id="clearBtn" class="btn-danger">🗑️ Clear</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) -->
    <%- include("common/footer.ejs") %>

    <!-- Image Converter JavaScript (unchanged) -->
    <script>
        const fileInput = document.getElementById('fileInput');
        const uploadArea = document.getElementById('uploadArea');
        const addMoreBtn = document.getElementById('addMoreBtn');
        const convertBtn = document.getElementById('convertBtn');
        const clearBtn = document.getElementById('clearBtn');
        const formatSelect = document.getElementById('formatSelect');
        const previewGrid = document.getElementById('previewGrid');
        const imageCountBadge = document.getElementById('imageCountBadge');

        let originalImages = [];
        let convertedImages = [];
        let showingConverted = false;

        function updateUI() {
            const total = originalImages.length;
            imageCountBadge.textContent = total === 1 ? '1 image' : `${total} images`;
        }

        function getExtension(filename) {
            return filename.slice((filename.lastIndexOf(".") - 1 >>> 0) + 2);
        }

        function renderGallery() {
            if (!showingConverted && originalImages.length === 0) {
                previewGrid.innerHTML = `<div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.5">
                        <rect x="2" y="2" width="20" height="20" rx="2.18"/>
                        <circle cx="8.5" cy="8.5" r="2.5"/>
                        <path d="M21 15l-5-5-4 4-3-3-5 5"/>
                    </svg>
                    <p>No images yet</p>
                    <p style="font-size:0.6rem">Upload images from the right panel</p>
                </div>`;
                updateUI();
                return;
            }

            const source = showingConverted ? convertedImages : originalImages;
            if (source.length === 0) {
                previewGrid.innerHTML = `<div class="empty-state">
                    <svg viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="1.5">
                        <rect x="2" y="2" width="20" height="20" rx="2.18"/>
                        <circle cx="8.5" cy="8.5" r="2.5"/>
                        <path d="M21 15l-5-5-4 4-3-3-5 5"/>
                    </svg>
                    <p>No converted images</p>
                    <p style="font-size:0.6rem">Click "Convert" first</p>
                </div>`;
                updateUI();
                return;
            }

            previewGrid.innerHTML = source.map((item, idx) => {
                const name = item.name;
                const ext = getExtension(name).toUpperCase();
                const src = item.dataURL || item.imgElement?.src;
                return `
                    <div class="image-card">
                        <div class="img-wrapper">
                            <img src="${src}" alt="${name}">
                        </div>
                        <div class="card-info">
                            <div class="card-name" title="${name}">${name.length > 24 ? name.slice(0,21)+'...' : name}</div>
                            <div class="card-ext">${ext}</div>
                        </div>
                        ${showingConverted ? `
                        <div class="card-actions">
                            <button class="download-single" data-idx="${idx}">⬇️ Download</button>
                        </div>
                        ` : ''}
                    </div>
                `;
            }).join('');

            if (showingConverted) {
                document.querySelectorAll('.download-single').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        const idx = parseInt(btn.dataset.idx);
                        downloadSingle(idx);
                    });
                });
            }
            updateUI();
        }

        function loadImages(files) {
            const imageFiles = Array.from(files).filter(f => f.type.startsWith('image/'));
            if (imageFiles.length === 0) return;

            let loaded = 0;
            imageFiles.forEach(file => {
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        originalImages.push({
                            name: file.name,
                            imgElement: img,
                            originalSrc: e.target.result
                        });
                        loaded++;
                        if (loaded === imageFiles.length) {
                            showingConverted = false;
                            convertedImages = [];
                            renderGallery();
                        }
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
        }

        function convertAll() {
            if (originalImages.length === 0) {
                alert('No images to convert. Please upload first.');
                return;
            }
            const targetFormat = formatSelect.value;
            const ext = targetFormat.split('/')[1] === 'jpeg' ? 'jpg' : targetFormat.split('/')[1];
            convertedImages = [];

            let completed = 0;
            originalImages.forEach((orig, idx) => {
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = orig.imgElement.width;
                canvas.height = orig.imgElement.height;
                ctx.drawImage(orig.imgElement, 0, 0);
                let dataURL;
                if (targetFormat === 'image/bmp') {
                    dataURL = canvas.toDataURL('image/png');
                } else {
                    dataURL = canvas.toDataURL(targetFormat, 0.92);
                }
                const newName = orig.name.replace(/\.[^/.]+$/, '') + '.' + ext;
                convertedImages.push({ name: newName, dataURL: dataURL });
                completed++;
                if (completed === originalImages.length) {
                    showingConverted = true;
                    renderGallery();
                }
            });
        }

        function downloadSingle(index) {
            const item = convertedImages[index];
            if (!item) return;
            const link = document.createElement('a');
            link.href = item.dataURL;
            link.download = item.name;
            link.click();
        }

        function clearAll() {
            originalImages = [];
            convertedImages = [];
            showingConverted = false;
            renderGallery();
        }

        uploadArea.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', (e) => {
            loadImages(e.target.files);
            fileInput.value = '';
        });
        addMoreBtn.addEventListener('click', () => fileInput.click());
        convertBtn.addEventListener('click', convertAll);
        clearBtn.addEventListener('click', clearAll);

        uploadArea.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadArea.style.background = 'rgba(129,140,248,0.15)';
        });
        uploadArea.addEventListener('dragleave', () => {
            uploadArea.style.background = '';
        });
        uploadArea.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadArea.style.background = '';
            loadImages(e.dataTransfer.files);
        });

        renderGallery();
    </script>

</body>
</html>