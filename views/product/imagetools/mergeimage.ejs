<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Image Merger Tool – Merge with live preview</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
    @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        body {
            font-family: 'Inter', sans-serif;
            background: #0f172a;
            color: white;
            min-height: 100vh;
            padding-top: 130px; /* space for fixed header */
        }

        .main-container {
            max-width: 1100px;
            margin: 0 auto;
            padding: 1rem;
        }

        /* Container now takes only needed height */
        .app {
            display: flex;
            gap: 1rem;
        }

        /* LEFT PANEL */
        .previewSection {
            width: 55%;
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 24px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            display: flex;
            flex-direction: column;
            padding: 1rem;
        }

        .previewHeader h2 {
            font-size: 1.3rem;
            font-weight: 600;
            background: linear-gradient(135deg, #818cf8, #a78bfa);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.6rem;
        }

        /* Reduced canvas wrap height */
        .previewCanvasWrap {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: auto;
            padding: 0.8rem;
            border: 1px solid rgba(71, 85, 105, 0.5);
            min-height: 200px;   /* was 280px */
            max-height: 250px;   /* limits height */
        }

        #previewCanvas {
            background: #0f172a;
            border-radius: 16px;
            max-width: 100%;
            height: auto;
            box-shadow: 0 8px 20px -6px rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        .emptyState {
            text-align: center;
            color: #94a3b8;
        }
        .emptyState div {
            font-size: 2.5rem;
            opacity: 0.6;
        }
        .emptyState h3 {
            margin-top: 0.5rem;
            font-size: 1rem;
            font-weight: 500;
        }
        .emptyState p {
            margin-top: 0.2rem;
            font-size: 0.7rem;
        }

        /* RIGHT PANEL */
        .controlsSection {
            width: 45%;
            padding: 1rem;
            overflow-y: auto;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 24px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            backdrop-filter: blur(8px);
        }

        .header h1 {
            font-size: 1.4rem;
            font-weight: 800;
            background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.3px;
        }
        .header p {
            margin-top: 0.2rem;
            color: #94a3b8;
            font-size: 0.7rem;
        }

        /* Upload area compact */
        .uploader {
            display: block;
            margin-top: 1rem;
            border: 2px dashed rgba(129, 140, 248, 0.3);
            border-radius: 20px;
            padding: 0.8rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            background: rgba(129, 140, 248, 0.03);
        }
        .uploader:hover {
            border-color: #818cf8;
            background: rgba(129, 140, 248, 0.08);
            transform: translateY(-2px);
        }
        .uploadIcon {
            font-size: 1.8rem;
        }
        .uploadTitle {
            margin-top: 0.2rem;
            font-size: 0.9rem;
            font-weight: 600;
            color: #f1f5f9;
        }
        .uploadText {
            margin-top: 0.1rem;
            color: #94a3b8;
            font-size: 0.65rem;
        }
        input[type="file"] {
            display: none;
        }

        .controls {
            margin-top: 1rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        select,
        .numberInput,
        button {
            padding: 0.4rem 0.7rem;
            border: none;
            border-radius: 40px;
            background: #1e293b;
            color: white;
            font-size: 0.7rem;
            font-weight: 500;
            outline: none;
            transition: all 0.2s;
            cursor: pointer;
        }
        select {
            flex: 1;
            min-width: 120px;
            background: #1e293b;
            border: 1px solid #475569;
        }
        .numberInput {
            width: 80px;
            background: #1e293b;
            border: 1px solid #475569;
            text-align: center;
        }
        button {
            background: #334155;
            color: #e2e8f0;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
        }
        button:hover {
            transform: translateY(-1px);
            filter: brightness(1.05);
        }
        .addMoreBtn {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
        }
        .downloadBtn {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            color: white;
        }
        .clearBtn {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
        }

        /* Image grid – smaller cards */
        .grid {
            margin-top: 1rem;
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 0.6rem;
        }
        .card {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 14px;
            overflow: hidden;
            transition: all 0.25s;
            border: 1px solid rgba(71, 85, 105, 0.5);
            backdrop-filter: blur(4px);
        }
        .card:hover {
            transform: translateY(-2px);
            border-color: #818cf8;
        }
        .card img {
            width: 100%;
            height: 80px;
            object-fit: cover;
        }
        .cardFooter {
            padding: 0.3rem;
        }
        .removeBtn {
            width: 100%;
            background: rgba(239, 68, 68, 0.8);
            border: none;
            border-radius: 30px;
            padding: 0.25rem;
            font-size: 0.55rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            color: white;
        }
        .removeBtn:hover {
            background: #ef4444;
        }

        @media (max-width: 1000px) {
            .main-container {
                max-width: 100%;
                padding: 0.5rem;
            }
            .app {
                flex-direction: column;
            }
            .previewSection, .controlsSection {
                width: 100%;
            }
            .previewCanvasWrap {
                min-height: 180px;
                max-height: 200px;
            }
        }
        @media (max-width: 700px) {
            .controls {
                flex-direction: column;
            }
            select, .numberInput, button {
                width: 100%;
            }
            .header h1 {
                font-size: 1.2rem;
            }
            .grid {
                grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            }
            .card img {
                height: 70px;
            }
        }
    </style>
</head>
<body>

    <!-- HEADER (EJS include) -->
    <%- include("common/header.ejs") %>

    <div class="main-container">
        <div class="app">

            <!-- LEFT PREVIEW -->
            <div class="previewSection">
                <div class="previewHeader">
                    <h2>📸 Live Preview</h2>
                </div>
                <div class="previewCanvasWrap">
                    <div class="emptyState" id="emptyState">
                        <div>🖼️</div>
                        <h3>No Images Uploaded</h3>
                        <p>Upload images to see merged preview</p>
                    </div>
                    <canvas id="previewCanvas" style="display:none;"></canvas>
                </div>
            </div>

            <!-- RIGHT PANEL -->
            <div class="controlsSection">
                <div class="header">
                    <h1>✨ Image Merger Tool</h1>
                    <p>Merge multiple images – horizontal, vertical or grid</p>
                </div>

                <label class="uploader" id="dropZone">
                    <div class="uploadIcon">📤</div>
                    <div class="uploadTitle">Upload Images</div>
                    <div class="uploadText">Drag & Drop or Click Here</div>
                    <input type="file" id="fileInput" multiple accept="image/*">
                </label>

                <div class="controls">
                    <select id="mergeType">
                        <option value="horizontal">Horizontal Merge</option>
                        <option value="vertical">Vertical Merge</option>
                        <option value="grid">Grid Merge</option>
                    </select>
                    <input type="number" class="numberInput" id="equalWidth" placeholder="Width" value="300">
                    <input type="number" class="numberInput" id="equalHeight" placeholder="Height" value="300">
                    <button class="addMoreBtn" id="addMoreBtn">➕ Add More</button>
                    <button class="downloadBtn" onclick="downloadMerged()">⬇️ Download</button>
                    <button class="clearBtn" onclick="clearAll()">🗑️ Clear</button>
                </div>

                <div class="grid" id="grid"></div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) -->
    <%- include("common/footer.ejs") %>

    <script>
        const fileInput = document.getElementById("fileInput");
        const dropZone = document.getElementById("dropZone");
        const addMoreBtn = document.getElementById("addMoreBtn");
        const grid = document.getElementById("grid");
        const mergeType = document.getElementById("mergeType");
        const equalWidth = document.getElementById("equalWidth");
        const equalHeight = document.getElementById("equalHeight");
        const canvas = document.getElementById("previewCanvas");
        const ctx = canvas.getContext("2d");
        const emptyState = document.getElementById("emptyState");

        let images = [];

        function handleFiles(files) {
            const fileArray = [...files];
            if (fileArray.length === 0) return;

            fileArray.forEach(file => {
                if (!file.type.startsWith("image/")) return;
                const reader = new FileReader();
                reader.onload = (e) => {
                    const img = new Image();
                    img.onload = () => {
                        images.push(img);
                        renderGrid();
                        renderPreview();
                    };
                    img.src = e.target.result;
                };
                reader.readAsDataURL(file);
            });
            fileInput.value = '';
        }

        fileInput.addEventListener("change", (e) => handleFiles(e.target.files));
        addMoreBtn.addEventListener("click", () => fileInput.click());

        dropZone.addEventListener("dragover", (e) => e.preventDefault());
        dropZone.addEventListener("drop", (e) => {
            e.preventDefault();
            handleFiles(e.dataTransfer.files);
        });

        function renderGrid() {
            grid.innerHTML = "";
            images.forEach((img, idx) => {
                const card = document.createElement("div");
                card.className = "card";
                card.innerHTML = `
                    <img src="${img.src}">
                    <div class="cardFooter">
                        <button class="removeBtn">Remove</button>
                    </div>
                `;
                card.querySelector(".removeBtn").onclick = () => {
                    images.splice(idx, 1);
                    renderGrid();
                    renderPreview();
                };
                grid.appendChild(card);
            });
        }

        function renderPreview() {
            if (images.length === 0) {
                canvas.style.display = "none";
                emptyState.style.display = "block";
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                return;
            }
            canvas.style.display = "block";
            emptyState.style.display = "none";

            const type = mergeType.value;
            const w = parseInt(equalWidth.value) || 300;
            const h = parseInt(equalHeight.value) || 300;

            ctx.clearRect(0, 0, canvas.width, canvas.height);

            if (type === "horizontal") {
                canvas.width = images.length * w;
                canvas.height = h;
                let x = 0;
                images.forEach(img => {
                    ctx.drawImage(img, x, 0, w, h);
                    x += w;
                });
            } 
            else if (type === "vertical") {
                canvas.width = w;
                canvas.height = images.length * h;
                let y = 0;
                images.forEach(img => {
                    ctx.drawImage(img, 0, y, w, h);
                    y += h;
                });
            } 
            else {
                const cols = Math.ceil(Math.sqrt(images.length));
                const rows = Math.ceil(images.length / cols);
                canvas.width = cols * w;
                canvas.height = rows * h;
                images.forEach((img, idx) => {
                    const x = (idx % cols) * w;
                    const y = Math.floor(idx / cols) * h;
                    ctx.drawImage(img, x, y, w, h);
                });
            }
        }

        mergeType.addEventListener("change", renderPreview);
        equalWidth.addEventListener("input", renderPreview);
        equalHeight.addEventListener("input", renderPreview);

        function downloadMerged() {
            if (images.length === 0) {
                alert("Please upload images first.");
                return;
            }
            const link = document.createElement("a");
            link.href = canvas.toDataURL("image/png");
            link.download = "merged-image.png";
            link.click();
        }

        function clearAll() {
            images = [];
            grid.innerHTML = "";
            renderPreview();
        }

        window.downloadMerged = downloadMerged;
        window.clearAll = clearAll;
    </script>

</body>
</html>