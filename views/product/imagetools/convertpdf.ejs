<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Image to PDF Converter</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
    * { font-family: 'Inter', sans-serif; }
        @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
    .app-container {
      max-width: 1400px;
      width: 100%;
      margin: 0 auto;
      padding: 0 1rem;
    }
    
    .main-layout {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    /* Centered content (no images) */
    .centered-content {
      width: 100%;
      max-width: 550px;
      margin: 0 auto;
    }
    
    /* When images are present - side-by-side equal columns */
    .has-images {
      justify-content: space-between;
      gap: 2rem;
    }
    
    .has-images .left-panel {
      flex: 1;
      order: 2;
    }
    
    .has-images .right-panel {
      flex: 1;
      order: 1;
      display: block;
      opacity: 1;
      transform: translateX(0);
      pointer-events: auto;
    }
    
    .has-images .centered-content {
      display: none;
    }
    
    /* Both panels share base styling */
    .left-panel, .right-panel {
      background: rgba(30, 41, 59, 0.5);
      backdrop-filter: blur(16px);
      border-radius: 32px;
      border: 1px solid rgba(71, 85, 105, 0.6);
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.3);
    }
    
    .left-panel {
      display: none;
      position: sticky;
      top: 1rem;
      height: fit-content;
    }
    
    .right-panel {
      display: none;
      height: fit-content;
    }
    
    /* Inner content padding */
    .panel-content {
      padding: 1.8rem;
    }
    
    /* Drop zones */
    .drop-zone {
      transition: all 0.3s ease;
      background: rgba(0, 0, 0, 0.25);
      border-radius: 24px;
      cursor: pointer;
    }
    .has-images .drop-zone {
      padding: 1rem 1.5rem;
    }
    .has-images .drop-zone .drop-icon {
      width: 2rem;
      height: 2rem;
    }
    .has-images .drop-zone .drop-title {
      font-size: 0.875rem;
    }
    .has-images .drop-zone .drop-subtitle {
      font-size: 0.75rem;
    }
    
    .drop-zone.dragover { 
      border-color: #818cf8; 
      background: rgba(129,140,248,0.2); 
    }
    
    /* Header shrink */
    .has-images .centered-header h1 {
      font-size: 1.5rem !important;
    }
    .has-images .centered-header p {
      font-size: 0.875rem !important;
    }
    
    /* Improved preview grid */
    .previews-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.2rem;
      max-height: 65vh;
      overflow-y: auto;
      padding: 0.5rem 0.25rem 0.5rem 0.25rem;
    }
    
    .previews-grid::-webkit-scrollbar {
      width: 6px;
    }
    .previews-grid::-webkit-scrollbar-track {
      background: #1e293b;
      border-radius: 10px;
    }
    .previews-grid::-webkit-scrollbar-thumb {
      background: #475569;
      border-radius: 10px;
    }
    .previews-grid::-webkit-scrollbar-thumb:hover {
      background: #818cf8;
    }
    
    /* Image card */
    .image-card {
      background: rgba(15, 23, 42, 0.7);
      border-radius: 1.2rem;
      overflow: hidden;
      transition: all 0.25s ease;
      border: 1px solid rgba(71, 85, 105, 0.5);
      box-shadow: 0 8px 20px -6px rgba(0,0,0,0.3);
    }
    .image-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 30px -12px rgba(0,0,0,0.4);
      border-color: #818cf8;
    }
    
    .image-wrapper {
      aspect-ratio: 16 / 9;
      width: 100%;
      overflow: hidden;
      background: #0f172a;
      position: relative;
    }
    .image-card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s;
    }
    .image-card:hover img {
      transform: scale(1.03);
    }
    
    .remove-btn {
      position: absolute;
      top: 0.6rem;
      right: 0.6rem;
      background: rgba(239, 68, 68, 0.9);
      border-radius: 9999px;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s;
      opacity: 0;
    }
    .image-card:hover .remove-btn {
      opacity: 1;
    }
    .remove-btn:hover {
      background: #ef4444;
      transform: scale(1.1);
    }
    
    .image-info {
      padding: 0.8rem;
    }
    .image-name {
      font-size: 0.8rem;
      font-weight: 600;
      color: #f1f5f9;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .image-size {
      font-size: 0.7rem;
      color: #94a3b8;
      margin-top: 0.3rem;
    }
    
    /* Buttons and badges */
    .actions-slide {
      animation: slideUp 0.3s ease-out;
    }
    @keyframes slideUp {
      from { opacity: 0; transform: translateY(20px); }
      to { opacity: 1; transform: translateY(0); }
    }
    
    .image-count-badge {
      background: linear-gradient(135deg, #818cf8, #6366f1);
      border-radius: 40px;
      padding: 0.3rem 0.9rem;
      font-size: 0.75rem;
      font-weight: 600;
      box-shadow: 0 2px 8px rgba(99,102,241,0.3);
    }
    
    button {
      transition: all 0.2s ease;
    }
    button:active {
      transform: scale(0.97);
    }
    
    /* Responsive */
    @media (max-width: 768px) {
      .has-images {
        flex-direction: column;
        gap: 1.5rem;
      }
      .has-images .left-panel {
        order: 1;
      }
      .has-images .right-panel {
        order: 2;
      }
      .left-panel {
        position: static;
      }
      .previews-grid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      }
    }
  </style>
</head>
<body>

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <body class="h-full bg-slate-900">
  <div class="h-full w-full overflow-auto flex flex-col items-center p-6">
    <div class="app-container">
      <div class="main-layout" id="mainLayout">
        
        <!-- CENTERED CONTENT (when no images) -->
        <div id="centeredContent" class="centered-content">
          <div class="bg-slate-800/40 rounded-3xl p-8 backdrop-blur-sm border border-slate-700 shadow-xl">
            <header class="centered-header text-center pt-4 pb-6">
              <h1 id="main-title" class="text-3xl font-bold text-white tracking-tight">Image to PDF Converter</h1>
              <p id="subtitle" class="text-slate-400 mt-2">Drag & drop images to create a single PDF</p>
            </header>
            <div id="drop-zone-center" class="drop-zone border-2 border-dashed border-slate-600 rounded-2xl p-10 flex flex-col items-center justify-center gap-4 cursor-pointer transition-all hover:border-indigo-400 hover:bg-slate-800/30">
              <i data-lucide="image-plus" class="w-14 h-14 text-indigo-400 drop-icon"></i>
              <p class="text-slate-300 font-medium text-lg drop-title">Click or drag images here</p>
              <p class="text-slate-500 text-sm drop-subtitle">PNG, JPG, WEBP supported</p>
              <input type="file" id="file-input-center" multiple accept="image/*" class="hidden">
            </div>
          </div>
        </div>
        
        <!-- LEFT PANEL - Controls (appears on right after images) -->
        <div class="left-panel" id="leftPanel">
          <div class="panel-content">
            <header class="text-center pt-2 pb-4">
              <h1 class="text-xl font-bold text-white">Image to PDF</h1>
              <p class="text-slate-400 mt-1 text-sm">Manage your images</p>
            </header>
            <div id="drop-zone-side" class="drop-zone border-2 border-dashed border-slate-600 rounded-2xl p-6 flex flex-col items-center justify-center gap-3 cursor-pointer transition-all hover:border-indigo-400 hover:bg-slate-800/30">
              <i data-lucide="image-plus" class="w-10 h-10 text-indigo-400 drop-icon"></i>
              <p class="text-slate-300 font-medium drop-title">Click or drag images here</p>
              <p class="text-slate-500 text-sm drop-subtitle">Add more images</p>
              <input type="file" id="file-input-side" multiple accept="image/*" class="hidden">
            </div>
            <button id="add-more-btn" class="hidden w-full mt-4 bg-slate-700 hover:bg-slate-600 text-slate-200 font-medium py-2.5 rounded-xl transition-all flex items-center justify-center gap-2">
              <i data-lucide="plus" class="w-5 h-5"></i> Add More Images
            </button>
            <div id="actions" class="hidden flex flex-col gap-3 mt-4">
              <div class="flex justify-between items-center mb-1 pb-2 border-b border-slate-700">
                <span class="text-sm text-slate-400">Total Images</span>
                <span id="image-count" class="image-count-badge">0</span>
              </div>
              <button id="convert-btn" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-xl flex items-center justify-center gap-2 transition-all shadow-lg shadow-indigo-900/30">
                <i data-lucide="file-down" class="w-5 h-5"></i> Convert &amp; Download PDF
              </button>
              <button id="clear-btn" class="w-full bg-red-500/20 hover:bg-red-500/30 text-red-400 font-medium py-3 rounded-xl transition-all flex items-center justify-center gap-2">
                <i data-lucide="trash-2" class="w-5 h-5"></i> Clear All
              </button>
            </div>
          </div>
        </div>
        
        <!-- RIGHT PANEL - Preview Section -->
        <div class="right-panel" id="rightPanel">
          <div class="panel-content">
            <div class="flex justify-between items-center mb-4 pb-2 border-b border-slate-700">
              <h3 class="font-semibold text-lg flex items-center gap-2">
                <i data-lucide="images" class="w-5 h-5 text-indigo-400"></i>
                Image Previews
              </h3>
              <span id="right-panel-count" class="text-sm text-slate-400"></span>
            </div>
            <div id="preview-list" class="previews-grid"></div>
            <div id="empty-previews" class="text-center text-slate-500 py-10">
              <i data-lucide="folder-open" class="w-12 h-12 mx-auto mb-3 opacity-50"></i>
              <p>No images added yet</p>
              <p class="text-sm mt-2">Click the drop zone to add images</p>
            </div>
          </div>
        </div>
        
      </div>
    </div>
    
    <!-- Toast Notification -->
    <div id="toast" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-emerald-500 text-white px-5 py-3 rounded-xl font-medium shadow-lg z-50 whitespace-nowrap backdrop-blur-sm"></div>
  </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
  let images = [];

  const mainLayout = document.getElementById('mainLayout');
  const centeredContent = document.getElementById('centeredContent');
  const leftPanel = document.getElementById('leftPanel');
  const rightPanel = document.getElementById('rightPanel');
  const dropZoneCenter = document.getElementById('drop-zone-center');
  const dropZoneSide = document.getElementById('drop-zone-side');
  const fileInputCenter = document.getElementById('file-input-center');
  const fileInputSide = document.getElementById('file-input-side');
  const previewList = document.getElementById('preview-list');
  const actions = document.getElementById('actions');
  const convertBtn = document.getElementById('convert-btn');
  const clearBtn = document.getElementById('clear-btn');
  const addMoreBtn = document.getElementById('add-more-btn');
  const emptyPreviews = document.getElementById('empty-previews');
  const imageCountSpan = document.getElementById('image-count');
  const rightPanelCount = document.getElementById('right-panel-count');

  function updateUILayout() {
    const hasImages = images.length > 0;
    if (hasImages) {
      mainLayout.classList.add('has-images');
      centeredContent.style.display = 'none';
      leftPanel.style.display = 'block';
      rightPanel.style.display = 'block';
      addMoreBtn.classList.remove('hidden');
      actions.classList.remove('hidden');
      actions.style.display = 'flex';
      actions.classList.add('actions-slide');
      setTimeout(() => actions.classList.remove('actions-slide'), 300);
    } else {
      mainLayout.classList.remove('has-images');
      centeredContent.style.display = 'block';
      leftPanel.style.display = 'none';
      rightPanel.style.display = 'none';
      addMoreBtn.classList.add('hidden');
      actions.classList.add('hidden');
      actions.style.display = 'none';
    }
  }

  function formatFileSize(bytes) {
    if (bytes < 1024) return bytes + ' B';
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
  }

  function handleFiles(files, isAddingMore = false) {
    const newFiles = [...files].filter(file => file.type.startsWith('image/'));
    if (newFiles.length === 0) {
      showToast('Please select valid image files!', 'error');
      return;
    }
    let processed = 0;
    newFiles.forEach(file => {
      const reader = new FileReader();
      reader.onload = e => {
        images.push({ 
          name: file.name, 
          src: e.target.result, 
          size: file.size,
          type: file.type
        });
        processed++;
        if (processed === newFiles.length) {
          renderPreviews();
          showToast(isAddingMore ? `Added ${newFiles.length} more image(s)!` : `${newFiles.length} image(s) added!`);
        }
      };
      reader.readAsDataURL(file);
    });
  }

  function addMoreImages() {
    const tempInput = document.createElement('input');
    tempInput.type = 'file';
    tempInput.multiple = true;
    tempInput.accept = 'image/*';
    tempInput.onchange = (e) => {
      handleFiles(e.target.files, true);
    };
    tempInput.click();
  }
  addMoreBtn.addEventListener('click', addMoreImages);

  window.removeImage = function(index) {
    images.splice(index, 1);
    renderPreviews();
    showToast('Image removed');
  };

  function renderPreviews() {
    const hasImages = images.length > 0;
    if (!hasImages) {
      previewList.innerHTML = '';
      emptyPreviews.classList.remove('hidden');
      updateUILayout();
      imageCountSpan.textContent = '0';
      rightPanelCount.textContent = '';
      lucide.createIcons();
      return;
    }
    emptyPreviews.classList.add('hidden');
    
    previewList.innerHTML = images.map((img, i) => `
      <div class="image-card">
        <div class="image-wrapper">
          <img src="${img.src}" alt="${img.name}">
          <div class="remove-btn" onclick="removeImage(${i})">
            <i data-lucide="x" class="w-4 h-4 text-white"></i>
          </div>
        </div>
        <div class="image-info">
          <div class="image-name" title="${img.name}">${img.name.length > 28 ? img.name.substring(0, 25) + '...' : img.name}</div>
          <div class="image-size">${formatFileSize(img.size)}</div>
        </div>
      </div>
    `).join('');
    
    imageCountSpan.textContent = images.length;
    rightPanelCount.textContent = `${images.length} image${images.length !== 1 ? 's' : ''}`;
    updateUILayout();
    lucide.createIcons();
  }

  function setupDropZone(dropZone, fileInput) {
    dropZone.addEventListener('click', () => fileInput.click());
    dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
    dropZone.addEventListener('drop', e => { 
      e.preventDefault(); 
      dropZone.classList.remove('dragover'); 
      handleFiles(e.dataTransfer.files); 
    });
    fileInput.addEventListener('change', e => handleFiles(e.target.files));
  }
  setupDropZone(dropZoneCenter, fileInputCenter);
  setupDropZone(dropZoneSide, fileInputSide);

  clearBtn.addEventListener('click', () => { 
    if (images.length > 0) {
      images = []; 
      renderPreviews();
      showToast('All images cleared');
    }
  });

  convertBtn.addEventListener('click', async () => {
    if (images.length === 0) {
      showToast('Please add at least one image first!', 'error');
      return;
    }
    convertBtn.disabled = true;
    convertBtn.innerHTML = '<div class="animate-spin rounded-full h-5 w-5 border-2 border-white border-t-transparent mx-auto"></div>';
    try {
      const { jsPDF } = window.jspdf;
      const pdf = new jsPDF({ unit: 'mm', format: 'a4' });
      for (let i = 0; i < images.length; i++) {
        const img = new Image();
        img.src = images[i].src;
        await new Promise((resolve, reject) => {
          img.onload = resolve;
          img.onerror = reject;
        });
        const pdfWidth = pdf.internal.pageSize.getWidth();
        const pdfHeight = pdf.internal.pageSize.getHeight();
        const imgWidth = pdfWidth;
        const imgHeight = (img.height / img.width) * pdfWidth;
        if (i > 0) pdf.addPage();
        const yOffset = imgHeight < pdfHeight ? (pdfHeight - imgHeight) / 2 : 0;
        pdf.addImage(img.src, 'JPEG', 0, yOffset, imgWidth, imgHeight);
      }
      pdf.save(`images_${Date.now()}.pdf`);
      showToast(`✅ PDF created with ${images.length} image(s)!`);
    } catch (error) {
      showToast('Error creating PDF. Please try again.', 'error');
    } finally {
      convertBtn.disabled = false;
      convertBtn.innerHTML = '<i data-lucide="file-down" class="w-5 h-5"></i> Convert & Download PDF';
      lucide.createIcons();
    }
  });

  function showToast(msg, type = 'success') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.classList.remove('hidden', 'bg-emerald-500', 'bg-red-500');
    t.classList.add(type === 'error' ? 'bg-red-500' : 'bg-emerald-500');
    setTimeout(() => t.classList.add('hidden'), 2500);
  }

  lucide.createIcons();
  </script>
</body>
</html>