<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Smart Sentence Restructurer</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        /* ========== PAGE-SPECIFIC STYLES (footer at bottom, no header/footer changes) ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
              @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}

        body {
            font-family: 'Inter', sans-serif;
            background: #0f172a;
            color: #f1f5f9;
            min-height: 100vh;
            display: flex;
            flex-direction: column;    /* footer stays at bottom */
            padding-top: 130px;        /* space for fixed header */
        }

        /* main content – grows to fill space, pushes footer down */
        .main-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        .app-container {
            width: 100%;
            max-width: 1300px;
            margin: 0 auto;
        }

        .two-columns {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .input-panel {
            flex: 1.2;
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .panel-header h2 {
            font-size: 1.4rem;
            font-weight: 700;
            background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.3px;
            margin-bottom: 0.25rem;
        }
        .panel-header p {
            color: #94a3b8;
            font-size: 0.75rem;
        }

        textarea {
            width: 100%;
            height: 280px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(71, 85, 105, 0.5);
            border-radius: 20px;
            padding: 1rem;
            color: #e2e8f0;
            font-size: 0.9rem;
            line-height: 1.5;
            font-family: 'Inter', monospace;
            resize: vertical;
            outline: none;
            transition: 0.2s;
        }
        textarea:focus {
            border-color: #818cf8;
            background: rgba(0, 0, 0, 0.4);
        }

        .button-group {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
        }
        button {
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            border: none;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            background: #334155;
            color: #e2e8f0;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }
        button:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }
        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            color: white;
            box-shadow: 0 2px 8px rgba(99, 102, 241, 0.3);
        }
        .btn-clear {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
        }
        .btn-sample {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
        }
        .btn-voice {
            background: linear-gradient(135deg, #f59e0b, #d97706);
            color: white;
        }
        .listening {
            animation: pulse 1s infinite;
            background: #38bdf8;
        }
        @keyframes pulse {
            0% { opacity: 1; }
            50% { opacity: 0.7; }
            100% { opacity: 1; }
        }

        .results-panel {
            flex: 1;
            background: rgba(0, 0, 0, 0.25);
            border-radius: 32px;
            padding: 1.5rem;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(71, 85, 105, 0.5);
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .results-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .results-header h3 {
            font-size: 1.2rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .badge {
            background: rgba(129, 140, 248, 0.2);
            padding: 0.2rem 0.7rem;
            border-radius: 40px;
            font-size: 0.7rem;
            color: #a5b4fc;
        }
        .results-container {
            flex: 1;
            overflow-y: auto;
            max-height: 450px;
            display: flex;
            flex-direction: column;
            gap: 0.8rem;
        }
        .result-card {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 20px;
            padding: 0.8rem;
            border-left: 4px solid #f59e0b;
        }
        .result-message {
            font-size: 0.85rem;
            font-weight: 500;
            margin-bottom: 0.4rem;
        }
        .result-context {
            font-size: 0.7rem;
            color: #94a3b8;
            margin-top: 0.3rem;
            font-family: monospace;
        }
        .action-buttons {
            margin-top: 0.5rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }
        .fix-btn, .restructure-btn {
            background: #1e293b;
            border: none;
            border-radius: 30px;
            padding: 0.2rem 0.8rem;
            font-size: 0.7rem;
            cursor: pointer;
            color: #a5b4fc;
            transition: 0.2s;
        }
        .fix-btn:hover, .restructure-btn:hover {
            background: #818cf8;
            color: white;
            transform: translateY(-1px);
        }
        .empty-state {
            text-align: center;
            padding: 2rem;
            color: #64748b;
        }
        .loading {
            text-align: center;
            padding: 2rem;
            color: #a5b4fc;
        }

        @media (max-width: 850px) {
            .two-columns { flex-direction: column; }
            body {
                padding-top: 90px;  /* mobile header */
            }
        }
    </style>
</head>
<body>

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <!-- MAIN CONTENT – pushes footer to bottom -->
    <div class="main-content">
        <div class="app-container">
            <div class="two-columns">
                <div class="input-panel">
                    <div class="panel-header">
                        <h2>📝 Smart Sentence Restructurer</h2>
                        <p>Detects word order errors & rearranges words into proper English</p>
                    </div>
                    <textarea id="textInput" placeholder="e.g., 'I am and ram are friends'"></textarea>
                    <div class="button-group">
                        <button id="checkBtn" class="btn-primary">🔍 Check & Suggest</button>
                        <button id="voiceBtn" class="btn-voice">🎤 Voice input</button>
                        <button id="clearBtn" class="btn-clear">🗑️ Clear</button>
                        <button id="sampleBtn" class="btn-sample">📋 Sample</button>
                    </div>
                </div>
                <div class="results-panel">
                    <div class="results-header">
                        <h3><span>✨</span> Corrections & Restructured Sentences</h3>
                        <div class="badge" id="resultBadge">Ready</div>
                    </div>
                    <div id="resultsContainer" class="results-container">
                        <div class="empty-state">Click "Check & Suggest" to analyse your text.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        const textarea = document.getElementById('textInput');
        const checkBtn = document.getElementById('checkBtn');
        const voiceBtn = document.getElementById('voiceBtn');
        const clearBtn = document.getElementById('clearBtn');
        const sampleBtn = document.getElementById('sampleBtn');
        const resultsContainer = document.getElementById('resultsContainer');
        const resultBadge = document.getElementById('resultBadge');

        let lastMatches = [];

        // Speech recognition
        let recognition = null;
        if ('webkitSpeechRecognition' in window || 'SpeechRecognition' in window) {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            recognition = new SpeechRecognition();
            recognition.continuous = false;
            recognition.interimResults = false;
            recognition.lang = 'en-US';
        }

        function setLoading(loading) {
            if (loading) {
                resultsContainer.innerHTML = '<div class="loading">⏳ Analysing grammar & word order...</div>';
                resultBadge.textContent = 'Analysing...';
            } else {
                resultBadge.textContent = 'Ready';
            }
        }

        // Enhanced sentence restructuring with new rules
        function restructureSentence(sentence) {
            let text = sentence.trim();
            
            // Rule 1: "I am and X are Y" → "X and I are Y"
            const matchIAM = text.match(/^I am and (\w+) (?:are|is) (.+)$/i);
            if (matchIAM) {
                const otherName = matchIAM[1];
                const rest = matchIAM[2];
                let newSentence = `${otherName} and I are ${rest}`;
                newSentence = newSentence.charAt(0).toUpperCase() + newSentence.slice(1);
                if (!/[.!?]$/.test(newSentence)) newSentence += '.';
                return newSentence;
            }

            // Rule 2: "I am and X Y" (e.g., "I am and ram friends") → "Ram and I are friends"
            const matchIAM2 = text.match(/^I am and (\w+) (\w+)$/i);
            if (matchIAM2) {
                const otherName = matchIAM2[1];
                const predicate = matchIAM2[2];
                let newSentence = `${otherName} and I are ${predicate}`;
                newSentence = newSentence.charAt(0).toUpperCase() + newSentence.slice(1);
                if (!/[.!?]$/.test(newSentence)) newSentence += '.';
                return newSentence;
            }

            // Rule 3: General "X and I" pattern when "I am" is misused
            if (text.match(/\bI am\b/i) && text.match(/\band\b/i)) {
                const parts = text.split(/\band\b/i);
                if (parts.length >= 2) {
                    let firstPart = parts[0].replace(/I am/i, '').trim();
                    let secondPart = parts[1].trim();
                    const words = secondPart.split(/\s+/);
                    if (words.length >= 2) {
                        const name = words[0];
                        const verb = words[1];
                        const rest = words.slice(2).join(' ');
                        let newSentence = `${name} and I ${verb} ${rest}`;
                        newSentence = newSentence.charAt(0).toUpperCase() + newSentence.slice(1);
                        if (!/[.!?]$/.test(newSentence)) newSentence += '.';
                        return newSentence;
                    }
                }
            }

            // Original rules (verb+article+noun+subject, etc.)
            const words = text.match(/\b\w+\b|[.,!?;]/g) || [];
            if (words.length < 2) return text;

            const verbIndex = words.findIndex(w => w.match(/^(eating|drinking|walking|running|playing)$/i));
            const articleIndex = words.findIndex(w => w.match(/^(a|an|the)$/i));
            const nounIndex = articleIndex + 1;
            const subjectIndex = words.findIndex((w, idx) => idx > nounIndex && !w.match(/[.,!?]/) && w[0] === w[0].toUpperCase() && !w.match(/^(a|an|the|is|are|was|were)$/i));
            
            if (verbIndex !== -1 && articleIndex !== -1 && nounIndex < words.length && subjectIndex !== -1) {
                const verb = words[verbIndex];
                const article = words[articleIndex];
                const noun = words[nounIndex];
                const subject = words[subjectIndex];
                let newSentence = `${subject} is ${verb} ${article} ${noun}.`;
                newSentence = newSentence.charAt(0).toUpperCase() + newSentence.slice(1);
                return newSentence;
            }

            // Fix article "a" before vowel
            text = text.replace(/\ba ([aeiou])/gi, 'an $1');
            text = text.charAt(0).toUpperCase() + text.slice(1);
            if (!/[.!?]$/.test(text)) text += '.';
            return text;
        }

        function applyRestructuring(offset, length) {
            const current = textarea.value;
            const before = current.slice(0, offset);
            const errorSegment = current.slice(offset, offset + length);
            const after = current.slice(offset + length);
            const restructured = restructureSentence(errorSegment);
            const newText = before + restructured + after;
            textarea.value = newText;
            checkGrammar();
        }

        function applyFix(offset, length, replacement) {
            const current = textarea.value;
            const newText = current.slice(0, offset) + replacement + current.slice(offset + length);
            textarea.value = newText;
            checkGrammar();
        }

        async function checkGrammar() {
            const text = textarea.value.trim();
            if (!text) {
                resultsContainer.innerHTML = '<div class="empty-state">📭 No text to check. Write something first.</div>';
                resultBadge.textContent = 'No text';
                return;
            }
            setLoading(true);
            try {
                const params = new URLSearchParams();
                params.append('text', text);
                params.append('language', 'en-US');
                const response = await fetch('https://api.languagetool.org/v2/check', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: params.toString()
                });
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                const data = await response.json();
                lastMatches = data.matches;
                displayResults(lastMatches);
            } catch (err) {
                console.error(err);
                resultsContainer.innerHTML = `<div class="empty-state">⚠️ Connection error. Please try again later.</div>`;
                resultBadge.textContent = 'Error';
            } finally {
                setLoading(false);
            }
        }

        function displayResults(matches) {
            if (!matches || matches.length === 0) {
                resultsContainer.innerHTML = '<div class="empty-state">✅ No issues found! Your text looks good.</div>';
                resultBadge.textContent = 'No issues';
                return;
            }

            const html = matches.map((match, idx) => {
                const offset = match.offset;
                const length = match.length;
                const context = match.context?.text || '';
                const before = context.slice(0, match.context?.offset || 0);
                const errorWord = context.slice(match.context?.offset || 0, (match.context?.offset || 0) + (match.context?.length || 0));
                const after = context.slice((match.context?.offset || 0) + (match.context?.length || 0));
                
                const bestReplacement = match.replacements[0]?.value || '';
                const hasReplacement = !!bestReplacement;

                return `
                    <div class="result-card">
                        <div class="result-message">⚠️ ${match.message}</div>
                        <div class="action-buttons">
                            ${hasReplacement ? `<button class="fix-btn" data-offset="${offset}" data-length="${length}" data-replacement="${bestReplacement.replace(/"/g, '&quot;')}">🔧 Fix: ${bestReplacement}</button>` : ''}
                            <button class="restructure-btn" data-offset="${offset}" data-length="${length}">🔄 Restructure sentence</button>
                        </div>
                        <div class="result-context">… ${before}<strong>${errorWord}</strong>${after} …</div>
                    </div>
                `;
            }).join('');

            resultsContainer.innerHTML = html;
            resultBadge.textContent = `${matches.length} issue${matches.length !== 1 ? 's' : ''}`;

            document.querySelectorAll('.fix-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    applyFix(parseInt(btn.dataset.offset), parseInt(btn.dataset.length), btn.dataset.replacement);
                });
            });
            document.querySelectorAll('.restructure-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    applyRestructuring(parseInt(btn.dataset.offset), parseInt(btn.dataset.length));
                });
            });
        }

        function startVoiceInput() {
            if (!recognition) {
                alert('Speech recognition not supported in this browser.');
                return;
            }
            recognition.start();
            voiceBtn.classList.add('listening');
            voiceBtn.textContent = '🎤 Listening...';
        }
        recognition?.addEventListener('result', (event) => {
            const transcript = event.results[0][0].transcript;
            textarea.value = textarea.value + (textarea.value ? ' ' : '') + transcript;
            voiceBtn.classList.remove('listening');
            voiceBtn.textContent = '🎤 Voice input';
        });
        recognition?.addEventListener('end', () => {
            voiceBtn.classList.remove('listening');
            voiceBtn.textContent = '🎤 Voice input';
        });
        recognition?.addEventListener('error', () => {
            voiceBtn.classList.remove('listening');
            voiceBtn.textContent = '🎤 Voice input';
            alert('Speech recognition error.');
        });

        function clearAll() {
            textarea.value = '';
            resultsContainer.innerHTML = '<div class="empty-state">Click "Check & Suggest" to analyse your text.</div>';
            resultBadge.textContent = 'Ready';
            lastMatches = [];
        }

        function insertSample() {
            textarea.value = `I am and ram are friends. Eating A apple Ram. He go to school yesterday. I have a apple. She don't like coffee.`;
            resultsContainer.innerHTML = '<div class="empty-state">Click "Check & Suggest" to analyse the sample text.</div>';
            resultBadge.textContent = 'Ready';
        }

        checkBtn.addEventListener('click', checkGrammar);
        voiceBtn.addEventListener('click', startVoiceInput);
        clearBtn.addEventListener('click', clearAll);
        sampleBtn.addEventListener('click', insertSample);
    </script>
</body>
</html>