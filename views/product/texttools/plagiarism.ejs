<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Plagiarism Checker</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <!-- TailwindCSS -->
    <script src="https://cdn.tailwindcss.com/3.4.17"></script>
    <!-- Lucide Icons -->
    <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        * { font-family: 'Inter', sans-serif; }
        
              @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        body {
            background-color: #0f172a;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            padding-top: 130px;   /* space for fixed header */
        }
        
        /* main content wrapper pushes footer down */
        .main-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        
        .glass-card {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 28px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            box-shadow: 0 20px 35px -12px rgba(0,0,0,0.3);
            transition: all 0.3s ease;
        }
        
        .plag-textarea {
            background: rgba(0, 0, 0, 0.25);
            border: 1px solid rgba(71, 85, 105, 0.6);
            border-radius: 1.2rem;
            color: #e2e8f0;
            font-size: 0.9rem;
            transition: all 0.2s;
            width: 100%;
        }
        .plag-textarea:focus {
            outline: none;
            border-color: #818cf8;
            box-shadow: 0 0 0 2px rgba(129, 140, 248, 0.2);
        }
        
        .action-btn {
            transition: all 0.2s ease;
        }
        .action-btn:active {
            transform: scale(0.96);
        }
        
        .output-placeholder {
            color: #94a3b8;
        }
        
        .output-expand {
            overflow-y: visible;
            max-height: none;
            word-wrap: break-word;
            white-space: pre-wrap;
        }
        
        .match-highlight {
            background-color: rgba(239, 68, 68, 0.4);
            border-bottom: 1px solid #ef4444;
            border-radius: 4px;
            padding: 0 2px;
        }
        
        @media (max-width: 768px) {
            body { padding-top: 90px; }
        }
    </style>
</head>
<body>

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <div class="main-content">
        <div style="max-width: 780px; width: 100%; margin: 0 auto;">
            <div class="glass-card w-full">
                <!-- Reduced padding from p-5 md:p-6 to p-4 md:p-5 -->
                <div class="p-4 md:p-5">
                    
                    <!-- Header -->
                    <div class="text-center mb-3">
                        <div class="flex justify-center mb-1">
                            <i data-lucide="scroll-text" class="w-8 h-8 text-indigo-400"></i>
                        </div>
                        <h1 class="text-xl md:text-2xl font-bold text-white tracking-tight">Plagiarism Checker</h1>
                        <p class="text-slate-400 mt-1 text-xs md:text-sm">
                            Compare two texts · Detect similarity & matching phrases
                        </p>
                    </div>
                    
                    <!-- Two text areas – reduced gap from gap-4 to gap-3 -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-4">
                        <!-- Left: Your Text -->
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="text-slate-300 text-xs font-semibold flex items-center gap-1">
                                    <i data-lucide="file-text" class="w-3.5 h-3.5 text-indigo-400"></i> Your Text
                                </label>
                                <button id="loadExampleInput" class="text-indigo-400 hover:text-indigo-300 text-xs flex items-center gap-1 bg-slate-800/60 px-2 py-0.5 rounded-full transition-all action-btn">
                                    <i data-lucide="file-code" class="w-3 h-3"></i> Example
                                </button>
                            </div>
                            <!-- rows changed from 4 to 3 -->
                            <textarea id="inputText" rows="3" class="plag-textarea p-3 text-sm" placeholder="Paste your content here..."></textarea>
                        </div>
                        
                        <!-- Right: Source Text -->
                        <div>
                            <div class="flex justify-between items-center mb-1">
                                <label class="text-slate-300 text-xs font-semibold flex items-center gap-1">
                                    <i data-lucide="library" class="w-3.5 h-3.5 text-indigo-400"></i> Source Text
                                </label>
                                <button id="loadExampleSource" class="text-indigo-400 hover:text-indigo-300 text-xs flex items-center gap-1 bg-slate-800/60 px-2 py-0.5 rounded-full transition-all action-btn">
                                    <i data-lucide="file-code" class="w-3 h-3"></i> Example
                                </button>
                            </div>
                            <textarea id="sourceText" rows="3" class="plag-textarea p-3 text-sm" placeholder="Compare against this text..."></textarea>
                        </div>
                    </div>
                    
                    <!-- Check button – reduced margin from mb-5 to mb-4 -->
                    <div class="flex justify-center mb-4">
                        <button id="checkBtn" class="action-btn bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-500 hover:to-indigo-600 text-white font-bold py-2.5 px-8 rounded-full flex items-center gap-2 shadow-lg transition-all text-sm">
                            <i data-lucide="search" class="w-4 h-4"></i>
                            Check Plagiarism
                        </button>
                    </div>
                    
                    <!-- Results section -->
                    <div class="mb-3">
                        <div class="flex justify-between items-center mb-1">
                            <label class="text-slate-300 text-xs font-semibold flex items-center gap-1">
                                <i data-lucide="bar-chart-2" class="w-3.5 h-3.5 text-indigo-400"></i> Similarity Result
                            </label>
                            <button id="copyResultBtn" class="text-indigo-400 hover:text-indigo-300 text-xs flex items-center gap-1 bg-slate-800/60 px-2.5 py-1 rounded-full transition-all action-btn">
                                <i data-lucide="copy" class="w-3 h-3"></i> Copy Result
                            </button>
                        </div>
                        <div id="resultArea" class="plag-textarea p-3 text-sm bg-slate-900/40 text-slate-200 whitespace-pre-wrap break-words output-expand" style="border-color: rgba(71,85,105,0.5); min-height: 100px;">
                            ✨ Click "Check Plagiarism" to compare texts.
                        </div>
                    </div>
                    
                    <!-- Additional actions -->
                    <div class="flex flex-wrap justify-center gap-3 mt-2">
                        <button id="clearAllBtn" class="action-btn bg-red-500/20 hover:bg-red-500/30 text-red-400 font-medium py-1.5 px-4 rounded-lg flex items-center gap-1.5 transition-all text-xs">
                            <i data-lucide="eraser" class="w-3.5 h-3.5"></i> Clear All
                        </button>
                        <button id="swapTextsBtn" class="action-btn bg-slate-700 hover:bg-slate-600 text-slate-200 font-medium py-1.5 px-4 rounded-lg flex items-center gap-1.5 transition-all text-xs">
                            <i data-lucide="arrow-left-right" class="w-3.5 h-3.5"></i> Swap Texts
                        </button>
                    </div>
                    
                    <!-- Character counter hint -->
                    <div class="text-right text-slate-500 text-[0.7rem] mt-4 flex justify-between items-center border-t border-slate-700/50 pt-3">
                        <span class="flex items-center gap-1"><i data-lucide="info" class="w-3 h-3"></i> Detects direct & paraphrased similarity</span>
                        <span id="charCounter" class="font-mono">0 / 0 characters</span>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Toast Notifications -->
        <div id="toastMsg" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-emerald-500 text-white px-4 py-2 rounded-lg font-medium shadow-lg z-50 backdrop-blur-sm text-sm"></div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        // DOM Elements
        const inputTextarea = document.getElementById('inputText');
        const sourceTextarea = document.getElementById('sourceText');
        const checkBtn = document.getElementById('checkBtn');
        const resultArea = document.getElementById('resultArea');
        const copyResultBtn = document.getElementById('copyResultBtn');
        const clearAllBtn = document.getElementById('clearAllBtn');
        const swapTextsBtn = document.getElementById('swapTextsBtn');
        const loadExampleInput = document.getElementById('loadExampleInput');
        const loadExampleSource = document.getElementById('loadExampleSource');
        const charCounterSpan = document.getElementById('charCounter');
        
        function updateCharCounter() {
            const inputLen = inputTextarea.value.length;
            const sourceLen = sourceTextarea.value.length;
            charCounterSpan.textContent = `${inputLen} / ${sourceLen} chars`;
        }
        
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toastMsg');
            toast.textContent = message;
            toast.classList.remove('hidden', 'bg-emerald-500', 'bg-red-500', 'bg-blue-500');
            if (type === 'error') toast.classList.add('bg-red-500');
            else if (type === 'info') toast.classList.add('bg-blue-500');
            else toast.classList.add('bg-emerald-500');
            setTimeout(() => toast.classList.add('hidden'), 2500);
        }
        
        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }
        
        function checkPlagiarism(text1, text2) {
            if (!text1.trim() || !text2.trim()) {
                return { percentage: 0, matches: [], message: "Both texts are required." };
            }
            
            function normalize(str) {
                return str.toLowerCase().replace(/[^\w\s]/g, '').trim();
            }
            
            const normalized1 = normalize(text1);
            const normalized2 = normalize(text2);
            
            const words1 = normalized1.split(/\s+/).filter(w => w.length > 1);
            const words2 = normalized2.split(/\s+/).filter(w => w.length > 1);
            
            if (words1.length === 0 || words2.length === 0) {
                return { percentage: 0, matches: [], message: "Not enough meaningful words." };
            }
            
            const set2 = new Set(words2);
            let matchCount = 0;
            for (let word of words1) {
                if (set2.has(word)) matchCount++;
            }
            
            const uniqueWords = new Set([...words1, ...words2]);
            const similarity = (matchCount / uniqueWords.size) * 100;
            
            const matches = [];
            const text1Lower = normalized1;
            const text2Lower = normalized2;
            
            function getNGrams(str, n) {
                const words = str.split(/\s+/);
                const grams = [];
                for (let i = 0; i <= words.length - n; i++) {
                    grams.push(words.slice(i, i + n).join(' '));
                }
                return grams;
            }
            
            for (let n = 6; n >= 3; n--) {
                const grams1 = getNGrams(text1Lower, n);
                for (let gram of grams1) {
                    if (text2Lower.includes(gram) && !matches.includes(gram) && gram.length > 5) {
                        matches.push(gram);
                    }
                }
            }
            
            matches.sort((a,b) => b.length - a.length);
            const uniqueMatches = [...new Set(matches)].slice(0, 5);
            
            let message = '';
            if (similarity < 20) message = '✅ Low similarity — likely original content.';
            else if (similarity < 50) message = '⚠️ Moderate similarity — some matching phrases found.';
            else if (similarity < 80) message = '🔴 High similarity — significant overlap detected.';
            else message = '🚨 Very high similarity — potential plagiarism.';
            
            return {
                percentage: Math.round(similarity),
                matches: uniqueMatches,
                message: message
            };
        }
        
        function highlightMatches(text, matches) {
            if (!matches.length) return escapeHtml(text);
            let highlighted = escapeHtml(text);
            for (let match of matches) {
                const escapedMatch = match.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
                const regex = new RegExp(`(${escapedMatch})`, 'gi');
                highlighted = highlighted.replace(regex, `<span class="match-highlight">$1</span>`);
            }
            return highlighted;
        }
        
        function runCheck() {
            const userText = inputTextarea.value;
            const sourceText = sourceTextarea.value;
            
            if (!userText.trim()) {
                resultArea.innerHTML = '⚠️ Please enter some text in "Your Text" field.';
                resultArea.classList.add('output-placeholder');
                showToast('Your text is empty', 'error');
                return;
            }
            if (!sourceText.trim()) {
                resultArea.innerHTML = '⚠️ Please enter source text to compare against.';
                resultArea.classList.add('output-placeholder');
                showToast('Source text is empty', 'error');
                return;
            }
            
            const { percentage, matches, message } = checkPlagiarism(userText, sourceText);
            
            let resultHtml = `
                <div class="mb-2 flex items-center gap-2">
                    <span class="text-sm font-semibold">Similarity:</span>
                    <span class="text-lg font-bold ${percentage > 50 ? 'text-red-400' : percentage > 20 ? 'text-yellow-400' : 'text-green-400'}">${percentage}%</span>
                    <span class="text-xs text-slate-400">${message}</span>
                </div>
            `;
            
            if (matches.length > 0) {
                resultHtml += `<div class="mt-3"><span class="text-xs font-semibold text-indigo-400">🔍 Matching phrases found:</span>
                <div class="flex flex-wrap gap-1 mt-1">`;
                matches.forEach(m => {
                    resultHtml += `<span class="bg-red-500/20 text-red-300 text-xs px-2 py-0.5 rounded-full">${escapeHtml(m)}</span>`;
                });
                resultHtml += `</div></div>`;
                
                const highlightedText = highlightMatches(userText, matches);
                resultHtml += `<div class="mt-3 pt-2 border-t border-slate-700/50">
                    <span class="text-xs font-semibold text-slate-300">📝 Your text with highlights:</span>
                    <div class="text-xs mt-1 p-2 bg-slate-800/40 rounded-lg whitespace-pre-wrap">${highlightedText}</div>
                </div>`;
            } else if (percentage > 0) {
                resultHtml += `<div class="mt-3 text-xs text-slate-400">No exact phrase matches, but word-level similarity detected.</div>`;
            } else {
                resultHtml += `<div class="mt-3 text-xs text-slate-400">No significant similarity detected.</div>`;
            }
            
            resultArea.innerHTML = resultHtml;
            resultArea.classList.remove('output-placeholder');
        }
        
        function clearAll() {
            inputTextarea.value = '';
            sourceTextarea.value = '';
            resultArea.innerHTML = '✨ Click "Check Plagiarism" to compare texts.';
            resultArea.classList.add('output-placeholder');
            updateCharCounter();
            showToast('All fields cleared', 'info');
        }
        
        function swapTexts() {
            const temp = inputTextarea.value;
            inputTextarea.value = sourceTextarea.value;
            sourceTextarea.value = temp;
            updateCharCounter();
            showToast('Texts swapped', 'success');
            resultArea.innerHTML = '✨ Swapped. Click check to compare.';
            resultArea.classList.add('output-placeholder');
        }
        
        function loadExampleInputText() {
            inputTextarea.value = `The quick brown fox jumps over the lazy dog. This is a well-known pangram used to display font samples. Many designers use this phrase to test typography.`;
            updateCharCounter();
            showToast('Example loaded in "Your Text"', 'success');
        }
        
        function loadExampleSourceText() {
            sourceTextarea.value = `The fast brown fox leaps over the sleepy dog. This famous pangram is commonly utilized for demonstrating typefaces. Numerous graphic designers employ this sentence for font testing.`;
            updateCharCounter();
            showToast('Example loaded in "Source Text"', 'success');
        }
        
        async function copyResult() {
            const resultText = resultArea.innerText || resultArea.textContent;
            if (resultText === '✨ Click "Check Plagiarism" to compare texts.' || resultText.includes('⚠️')) {
                showToast('Nothing to copy. Run a check first.', 'error');
                return;
            }
            try {
                await navigator.clipboard.writeText(resultText);
                showToast('Result copied to clipboard');
            } catch (err) {
                showToast('Copy failed', 'error');
            }
        }
        
        checkBtn.addEventListener('click', () => {
            runCheck();
            lucide.createIcons();
        });
        clearAllBtn.addEventListener('click', () => {
            clearAll();
            lucide.createIcons();
        });
        swapTextsBtn.addEventListener('click', () => {
            swapTexts();
            lucide.createIcons();
        });
        loadExampleInput.addEventListener('click', () => {
            loadExampleInputText();
            lucide.createIcons();
        });
        loadExampleSource.addEventListener('click', () => {
            loadExampleSourceText();
            lucide.createIcons();
        });
        copyResultBtn.addEventListener('click', () => {
            copyResult();
            lucide.createIcons();
        });
        inputTextarea.addEventListener('input', updateCharCounter);
        sourceTextarea.addEventListener('input', updateCharCounter);
        
        updateCharCounter();
        resultArea.classList.add('output-placeholder');
        lucide.createIcons();
    </script>
</body>
</html>