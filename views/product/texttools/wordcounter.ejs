<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Smart Word Counter</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        /* ========== PAGE-SPECIFIC STYLES (footer at bottom) ========== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

              @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        body {
            font-family: 'Inter', sans-serif;
            background: #0f172a;
            color: #f1f5f9;
            min-height: 100vh;
            display: flex;
            flex-direction: column;    /* footer stays at bottom */
            padding-top: 130px;        /* space for fixed header */
        }

        /* main content – grows to fill space, pushes footer down */
        .main-content {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1.5rem;
        }

        .app-container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
        }

        .two-columns {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        /* LEFT PANEL – stats cards */
        .stats-panel {
            flex: 0.9;
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            padding: 1.8rem;
        }

        .stats-header h2 {
            font-size: 1.6rem;
            font-weight: 700;
            background: linear-gradient(135deg, #818cf8, #a78bfa, #c084fc);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
            -webkit-text-fill-color: transparent;
            letter-spacing: -0.3px;
            margin-bottom: 0.25rem;
        }
        .stats-header p {
            color: #94a3b8;
            font-size: 0.8rem;
            margin-bottom: 1.5rem;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }
        .stat-card {
            background: rgba(0, 0, 0, 0.35);
            border-radius: 20px;
            padding: 1rem;
            border: 1px solid rgba(71, 85, 105, 0.5);
            transition: all 0.2s;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            border-color: #818cf8;
            box-shadow: 0 8px 20px -8px rgba(0, 0, 0, 0.4);
        }
        .stat-label {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #94a3b8;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.3rem;
        }
        .stat-value {
            font-size: 2rem;
            font-weight: 800;
            color: #a5b4fc;
            line-height: 1.2;
        }

        /* RIGHT PANEL – text editor */
        .editor-panel {
            flex: 1.2;
            background: rgba(0, 0, 0, 0.25);
            border-radius: 32px;
            padding: 1.5rem;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(71, 85, 105, 0.5);
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .editor-header h3 {
            font-size: 1.2rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        .editor-header h3 i {
            color: #818cf8;
        }

        textarea {
            width: 100%;
            height: 280px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid rgba(71, 85, 105, 0.5);
            border-radius: 20px;
            padding: 1rem;
            color: #e2e8f0;
            font-size: 0.9rem;
            line-height: 1.5;
            font-family: 'Inter', monospace;
            resize: vertical;
            outline: none;
            transition: 0.2s;
        }
        textarea:focus {
            border-color: #818cf8;
            background: rgba(0, 0, 0, 0.4);
        }

        .button-group {
            display: flex;
            gap: 0.8rem;
            flex-wrap: wrap;
        }
        button {
            padding: 0.5rem 1.2rem;
            border-radius: 40px;
            border: none;
            font-size: 0.8rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            background: #334155;
            color: #e2e8f0;
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }
        button:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }
        .btn-clear {
            background: linear-gradient(135deg, #ef4444, #dc2626);
            color: white;
            box-shadow: 0 2px 8px rgba(239, 68, 68, 0.3);
        }
        .btn-sample {
            background: linear-gradient(135deg, #10b981, #059669);
            color: white;
            box-shadow: 0 2px 8px rgba(16, 185, 129, 0.3);
        }

        .info-note {
            font-size: 0.65rem;
            color: #94a3b8;
            display: flex;
            align-items: center;
            gap: 0.3rem;
            margin-top: 0.3rem;
        }

        @media (max-width: 850px) {
            .two-columns {
                flex-direction: column;
            }
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }
            body {
                padding-top: 90px;   /* mobile header height */
            }
        }
        @media (max-width: 500px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <!-- MAIN CONTENT – pushes footer to bottom -->
    <div class="main-content">
        <div class="app-container">
            <div class="two-columns">

                <!-- LEFT: statistics panel -->
                
                <!-- RIGHT: text editor -->
                <div class="editor-panel">
                    <div class="editor-header">
                        <h3><span>✍️</span> Your Text</h3>
                    </div>
                    <textarea id="textInput" placeholder="Type, paste, or click 'Sample Text'..."></textarea>
                    <div class="button-group">
                        <button id="clearBtn" class="btn-clear">🗑️ Clear text</button>
                        <button id="sampleBtn" class="btn-sample">📋 Insert sample</button>
                    </div>
                    <div class="info-note">
                        ⚡ Every space, sentence, and paragraph is tracked instantly.
                    </div>
                </div>

                <div class="stats-panel">
                    <div class="stats-header">
                        <h2>📊 Live Word Counter</h2>
                        <p>Real‑time analysis · words · characters · sentences · paragraphs</p>
                    </div>
                    <div class="stats-grid">
                        <div class="stat-card">
                            <div class="stat-label">📝 Total Words</div>
                            <div class="stat-value" id="wordCount">0</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">🔤 Characters (with spaces)</div>
                            <div class="stat-value" id="charWithSpaces">0</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">✍️ Characters (no spaces)</div>
                            <div class="stat-value" id="charNoSpaces">0</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">📖 Sentences</div>
                            <div class="stat-value" id="sentenceCount">0</div>
                        </div>
                        <div class="stat-card">
                            <div class="stat-label">📄 Paragraphs</div>
                            <div class="stat-value" id="paragraphCount">0</div>
                        </div>
                    </div>
                </div>


            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        const textarea = document.getElementById('textInput');
        const wordSpan = document.getElementById('wordCount');
        const charWithSpacesSpan = document.getElementById('charWithSpaces');
        const charNoSpacesSpan = document.getElementById('charNoSpaces');
        const sentenceSpan = document.getElementById('sentenceCount');
        const paragraphSpan = document.getElementById('paragraphCount');

        function countSentences(text) {
            const matches = text.match(/[.!?]+(\s|$)/g);
            return matches ? matches.length : 0;
        }

        function countParagraphs(text) {
            const paragraphs = text.split(/\n\s*\n/).filter(p => p.trim().length > 0);
            return paragraphs.length;
        }

        function updateCounts() {
            let text = textarea.value;
            const words = text.trim() === '' ? [] : text.trim().split(/\s+/);
            const wordCount = words.length;
            const charWithSpaces = text.length;
            const charNoSpaces = text.replace(/\s/g, '').length;
            const sentenceCount = countSentences(text);
            const paragraphCount = countParagraphs(text);
            
            wordSpan.textContent = wordCount;
            charWithSpacesSpan.textContent = charWithSpaces;
            charNoSpacesSpan.textContent = charNoSpaces;
            sentenceSpan.textContent = sentenceCount;
            paragraphSpan.textContent = paragraphCount;
        }

        function clearText() {
            textarea.value = '';
            updateCounts();
        }

        function insertSample() {
            const sample = `Watch your words transform into instant statistics — every space, sentence, and paragraph is tracked live.

This tool helps you analyse any piece of text. Write a story, paste an article, or just play with words. The counts update as you type.

Isn't it amazing? Yes, it is!`;
            textarea.value = sample;
            updateCounts();
        }

        textarea.addEventListener('input', updateCounts);
        document.getElementById('clearBtn').addEventListener('click', clearText);
        document.getElementById('sampleBtn').addEventListener('click', insertSample);

        updateCounts();
    </script>
</body>
</html>