<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Speech to Text</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <!-- TailwindCSS -->
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <!-- Lucide Icons -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <!-- Google Fonts: Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
    * { font-family: 'Inter', sans-serif; }
    
          @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
    body {
      background-color: #0f172a;
    }
    
    .glass-card {
      background: rgba(30, 41, 59, 0.5);
      backdrop-filter: blur(16px);
      border-radius: 28px;
      border: 1px solid rgba(71, 85, 105, 0.6);
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.3);
      transition: all 0.3s ease;
    }
    
    .speech-textarea {
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(71, 85, 105, 0.6);
      border-radius: 1.2rem;
      color: #e2e8f0;
      font-size: 0.9rem;
      transition: all 0.2s;
      width: 100%;
    }
    .speech-textarea:focus {
      outline: none;
      border-color: #818cf8;
      box-shadow: 0 0 0 2px rgba(129, 140, 248, 0.2);
    }
    
    .action-btn {
      transition: all 0.2s ease;
    }
    .action-btn:active {
      transform: scale(0.96);
    }
    
    .output-placeholder {
      color: #94a3b8;
    }
    
    .output-expand {
      overflow-y: visible;
      max-height: none;
      word-wrap: break-word;
      white-space: pre-wrap;
    }
    
    /* Pulsing animation */
    @keyframes pulse-ring {
      0% { transform: scale(0.8); opacity: 0.5; }
      100% { transform: scale(1.5); opacity: 0; }
    }
    .recording-pulse {
      position: relative;
    }
    .recording-pulse::after {
      content: '';
      position: absolute;
      top: 50%;
      left: 50%;
      width: 100%;
      height: 100%;
      background: rgba(239, 68, 68, 0.5);
      border-radius: 9999px;
      transform: translate(-50%, -50%);
      animation: pulse-ring 1.2s infinite;
      pointer-events: none;
    }
  </style>
</head>
<body class="h-full bg-slate-900">

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <div class="h-full w-full overflow-auto flex flex-col items-center justify-center p-4">
    <div style="max-width: 680px; width: 100%; margin: 0 auto;">
      
      <div class="glass-card w-full">
        <div class="p-5 md:p-6">
          
          <!-- Header -->
          <div class="text-center mb-4">
            <div class="flex justify-center mb-2">
              <i data-lucide="mic" class="w-9 h-9 text-indigo-400"></i>
            </div>
            <h1 class="text-xl md:text-2xl font-bold text-white tracking-tight">Speech to Text</h1>
            <p class="text-slate-400 mt-1 text-xs md:text-sm">
              Click the microphone and speak · Instant transcription
            </p>
          </div>
          
          <!-- Language selector -->
          <div class="mb-4">
            <label class="block text-slate-300 text-xs font-semibold mb-1 ml-1 flex items-center gap-1">
              <i data-lucide="languages" class="w-3.5 h-3.5 text-indigo-400"></i> Language
            </label>
            <select id="languageSelect" class="bg-slate-800/60 border border-slate-600 rounded-xl text-slate-200 text-sm py-2 px-3 w-full focus:outline-none focus:border-indigo-400 transition">
              <option value="en-US">English (US)</option>
              <option value="en-GB">English (UK)</option>
              <option value="es-ES">Spanish</option>
              <option value="fr-FR">French</option>
              <option value="de-DE">German</option>
              <option value="it-IT">Italian</option>
              <option value="pt-BR">Portuguese (Brazil)</option>
              <option value="hi-IN">Hindi</option>
              <option value="ja-JP">Japanese</option>
              <option value="ko-KR">Korean</option>
              <option value="zh-CN">Chinese (Simplified)</option>
            </select>
          </div>
          
          <!-- Record button -->
          <div class="flex justify-center mb-5">
            <button id="recordBtn" class="relative action-btn bg-gradient-to-r from-indigo-600 to-indigo-500 hover:from-indigo-500 hover:to-indigo-600 text-white font-bold py-3 px-8 rounded-full flex items-center gap-3 shadow-lg transition-all text-base">
              <i data-lucide="mic" class="w-5 h-5"></i>
              <span id="recordBtnText">Start Recording</span>
            </button>
          </div>
          
          <!-- Status message -->
          <div id="statusMsg" class="text-center text-amber-400 text-xs mb-3 bg-slate-800/40 py-1.5 rounded-full mx-auto w-fit px-4">
            ⚫ Ready · Click to start
          </div>
          
          <!-- Transcription output -->
          <div class="mb-4">
            <div class="flex justify-between items-center mb-1">
              <label class="text-slate-300 text-xs font-semibold flex items-center gap-1">
                <i data-lucide="file-text" class="w-3.5 h-3.5 text-indigo-400"></i> Transcription
              </label>
              <div class="flex gap-2">
                <button id="copyTextBtn" class="text-indigo-400 hover:text-indigo-300 text-xs flex items-center gap-1 bg-slate-800/60 px-2.5 py-1 rounded-full transition-all action-btn">
                  <i data-lucide="copy" class="w-3 h-3"></i> Copy
                </button>
                <button id="clearTextBtn" class="text-red-400 hover:text-red-300 text-xs flex items-center gap-1 bg-slate-800/60 px-2.5 py-1 rounded-full transition-all action-btn">
                  <i data-lucide="trash-2" class="w-3 h-3"></i> Clear
                </button>
              </div>
            </div>
            <div id="transcriptArea" class="speech-textarea p-3 text-sm bg-slate-900/40 text-slate-200 whitespace-pre-wrap break-words output-expand" style="border-color: rgba(71,85,105,0.5); min-height: 130px;">
              ✨ Your spoken text will appear here...
            </div>
          </div>
          
          <!-- Bottom hint -->
          <div class="text-right text-slate-500 text-[0.7rem] mt-4 flex justify-between items-center border-t border-slate-700/50 pt-3">
            <span class="flex items-center gap-1"><i data-lucide="info" class="w-3 h-3"></i> Works best with Chrome, Edge, Safari</span>
            <span id="charCounter" class="font-mono">0 characters</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Toast Notifications -->
    <div id="toastMsg" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-emerald-500 text-white px-4 py-2 rounded-lg font-medium shadow-lg z-50 backdrop-blur-sm text-sm"></div>
  </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
    // ----- DOM Elements -----
    const recordBtn = document.getElementById('recordBtn');
    const recordBtnText = document.getElementById('recordBtnText');
    const transcriptArea = document.getElementById('transcriptArea');
    const copyTextBtn = document.getElementById('copyTextBtn');
    const clearTextBtn = document.getElementById('clearTextBtn');
    const statusMsgDiv = document.getElementById('statusMsg');
    const charCounterSpan = document.getElementById('charCounter');
    const languageSelect = document.getElementById('languageSelect');
    
    // ----- Speech Recognition Setup (stable version) -----
    let recognition = null;
    let isRecording = false;
    let finalTranscript = '';
    
    // Check browser support
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (!SpeechRecognition) {
      statusMsgDiv.innerHTML = '❌ Speech recognition not supported. Please use Chrome, Edge, or Safari.';
      statusMsgDiv.classList.add('text-red-400');
      recordBtn.disabled = true;
      recordBtn.style.opacity = '0.5';
      recordBtn.style.cursor = 'not-allowed';
    } else {
      initRecognition();
    }
    
    function initRecognition() {
      recognition = new SpeechRecognition();
      recognition.continuous = true;      // keep listening until stopped
      recognition.interimResults = true;   // show partial results as you speak
      recognition.maxAlternatives = 1;
      recognition.lang = languageSelect.value;
      
      recognition.onstart = () => {
        isRecording = true;
        recordBtnText.innerHTML = '🔴 Recording...';
        recordBtn.classList.add('recording-pulse');
        statusMsgDiv.innerHTML = '🎙️ Listening ... speak now';
        statusMsgDiv.classList.remove('text-amber-400', 'text-red-400');
        statusMsgDiv.classList.add('text-emerald-400');
        languageSelect.disabled = true;
        languageSelect.classList.add('opacity-60');
      };
      
      recognition.onerror = (event) => {
        console.error('Speech error:', event.error);
        let errorMsg = '';
        switch(event.error) {
          case 'not-allowed': 
            errorMsg = 'Microphone access denied. Please allow microphone and refresh.'; 
            break;
          case 'no-speech': 
            errorMsg = 'No speech detected. Try speaking louder or check your mic.'; 
            break;
          case 'audio-capture': 
            errorMsg = 'No microphone found. Please connect a microphone.'; 
            break;
          case 'network': 
            errorMsg = 'Network error. Please check your connection.'; 
            break;
          default: 
            errorMsg = `Error: ${event.error}`;
        }
        statusMsgDiv.innerHTML = `⚠️ ${errorMsg}`;
        statusMsgDiv.classList.add('text-red-400');
        stopRecording();
        showToast(errorMsg, 'error');
      };
      
      recognition.onend = () => {
        if (isRecording) {
          // If ended automatically (e.g., silence timeout), we restart to keep listening? 
          // For better UX, we stop recording and let user restart.
          stopRecordingUI();
          statusMsgDiv.innerHTML = '⏹️ Recording stopped. Click start to continue.';
          statusMsgDiv.classList.add('text-amber-400');
          showToast('Recording stopped', 'info');
        } else {
          statusMsgDiv.innerHTML = '⚫ Ready · Click to start';
          statusMsgDiv.classList.remove('text-emerald-400', 'text-red-400');
          statusMsgDiv.classList.add('text-amber-400');
        }
        languageSelect.disabled = false;
        languageSelect.classList.remove('opacity-60');
      };
      
      recognition.onresult = (event) => {
        let interimTranscript = '';
        for (let i = event.resultIndex; i < event.results.length; i++) {
          const transcriptChunk = event.results[i][0].transcript;
          if (event.results[i].isFinal) {
            finalTranscript += transcriptChunk + ' ';
          } else {
            interimTranscript += transcriptChunk;
          }
        }
        // Display final + interim together
        let displayText = finalTranscript + interimTranscript;
        if (displayText.trim() === '') {
          transcriptArea.innerHTML = '✨ Your spoken text will appear here...';
          transcriptArea.classList.add('output-placeholder');
        } else {
          transcriptArea.innerHTML = escapeHtml(displayText);
          transcriptArea.classList.remove('output-placeholder');
        }
        updateCharCount(displayText);
      };
    }
    
    function updateCharCount(text) {
      const len = text.length;
      charCounterSpan.textContent = `${len} character${len !== 1 ? 's' : ''}`;
    }
    
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }
    
    function getCurrentTranscriptText() {
      let text = transcriptArea.innerText || transcriptArea.textContent;
      if (text === '✨ Your spoken text will appear here...') return '';
      return text;
    }
    
    function stopRecordingUI() {
      if (recognition && isRecording) {
        try {
          recognition.stop();
        } catch(e) {}
      }
      isRecording = false;
      recordBtnText.innerHTML = '🎤 Start Recording';
      recordBtn.classList.remove('recording-pulse');
      languageSelect.disabled = false;
      languageSelect.classList.remove('opacity-60');
    }
    
    function stopRecording() {
      if (recognition && isRecording) {
        recognition.stop();
      }
      isRecording = false;
      recordBtnText.innerHTML = '🎤 Start Recording';
      recordBtn.classList.remove('recording-pulse');
      languageSelect.disabled = false;
      languageSelect.classList.remove('opacity-60');
    }
    
    function startRecording() {
      if (!recognition) {
        showToast('Speech recognition not supported', 'error');
        return;
      }
      
      // Clear any existing recognition instance to avoid conflicts
      if (recognition && isRecording) {
        recognition.stop();
        setTimeout(() => {
          startNewSession();
        }, 100);
      } else {
        startNewSession();
      }
    }
    
    function startNewSession() {
      try {
        // Reset final transcript if user wants fresh recording? 
        // We'll preserve existing transcript to allow appending, but most users expect new recording to overwrite.
        // To match typical behavior: clear previous text when starting a new recording.
        finalTranscript = '';
        transcriptArea.innerHTML = '✨ Your spoken text will appear here...';
        transcriptArea.classList.add('output-placeholder');
        updateCharCount('');
        
        // Re-initialize recognition to ensure clean state
        if (recognition) {
          try { recognition.abort(); } catch(e) {}
        }
        initRecognition();
        recognition.lang = languageSelect.value;
        recognition.start();
        isRecording = true;
        recordBtnText.innerHTML = '🔴 Recording...';
        recordBtn.classList.add('recording-pulse');
        statusMsgDiv.innerHTML = '🎙️ Listening ... speak now';
        statusMsgDiv.classList.remove('text-amber-400', 'text-red-400');
        statusMsgDiv.classList.add('text-emerald-400');
        languageSelect.disabled = true;
        languageSelect.classList.add('opacity-60');
      } catch (error) {
        console.error('Start error:', error);
        showToast('Could not start recording. Check microphone permissions.', 'error');
        stopRecordingUI();
      }
    }
    
    // Toggle record
    recordBtn.addEventListener('click', () => {
      if (isRecording) {
        stopRecording();
        // Show that recording stopped
        statusMsgDiv.innerHTML = '⚫ Ready · Click to start';
        statusMsgDiv.classList.remove('text-emerald-400');
        statusMsgDiv.classList.add('text-amber-400');
      } else {
        startRecording();
      }
    });
    
    // Copy transcript
    copyTextBtn.addEventListener('click', async () => {
      let text = getCurrentTranscriptText();
      if (!text.trim()) {
        showToast('Nothing to copy', 'error');
        return;
      }
      try {
        await navigator.clipboard.writeText(text);
        showToast('Copied to clipboard ✨');
      } catch (err) {
        showToast('Copy failed', 'error');
      }
    });
    
    // Clear transcript
    clearTextBtn.addEventListener('click', () => {
      finalTranscript = '';
      transcriptArea.innerHTML = '✨ Your spoken text will appear here...';
      transcriptArea.classList.add('output-placeholder');
      updateCharCount('');
      showToast('Transcript cleared');
      // If recording, stop it to avoid confusion
      if (isRecording) {
        stopRecording();
        statusMsgDiv.innerHTML = '⚫ Ready · Click to start';
      }
    });
    
    // Language change
    languageSelect.addEventListener('change', () => {
      if (!isRecording) {
        if (recognition) {
          recognition.lang = languageSelect.value;
        }
        showToast(`Language set to ${languageSelect.options[languageSelect.selectedIndex].text}`, 'success');
      } else {
        showToast('Stop recording to change language', 'error');
      }
    });
    
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toastMsg');
      toast.textContent = message;
      toast.classList.remove('hidden', 'bg-emerald-500', 'bg-red-500', 'bg-blue-500');
      if (type === 'error') toast.classList.add('bg-red-500');
      else if (type === 'info') toast.classList.add('bg-blue-500');
      else toast.classList.add('bg-emerald-500');
      setTimeout(() => toast.classList.add('hidden'), 2500);
    }
    
    // Initial setup
    if (recognition) {
      recognition.lang = languageSelect.value;
    }
    transcriptArea.classList.add('output-placeholder');
    updateCharCount('');
    lucide.createIcons();
    
    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
      if (recognition && isRecording) {
        recognition.stop();
      }
    });
  </script>
</body>
</html>