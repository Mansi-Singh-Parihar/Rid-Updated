<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Case Converter</title>
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
    <!-- TailwindCSS (same as original) -->
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <!-- Lucide Icons -->
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <!-- Google Fonts: Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
    * { font-family: 'Inter', sans-serif; }
          @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
    body {
      background-color: #0f172a;
    }
    
    /* Glass card with smaller footprint */
    .glass-card {
      background: rgba(30, 41, 59, 0.5);
      backdrop-filter: blur(16px);
      border-radius: 28px;
      border: 1px solid rgba(71, 85, 105, 0.6);
      box-shadow: 0 20px 35px -12px rgba(0,0,0,0.3);
      transition: all 0.3s ease;
    }
    
    /* Input / output fields – same style but more compact */
    .case-textarea {
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(71, 85, 105, 0.6);
      border-radius: 1.2rem;
      color: #e2e8f0;
      font-size: 0.9rem;
      transition: all 0.2s;
      width: 100%;
    }
    .case-textarea:focus {
      outline: none;
      border-color: #818cf8;
      box-shadow: 0 0 0 2px rgba(129, 140, 248, 0.2);
    }
    
    .action-btn {
      transition: all 0.2s ease;
    }
    .action-btn:active {
      transform: scale(0.96);
    }
    
    .output-placeholder {
      color: #94a3b8;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    
    /* No scrolling – expands naturally */
    .output-expand {
      overflow-y: visible;
      max-height: none;
      word-wrap: break-word;
      white-space: pre-wrap;
    }
  </style>
</head>
<body class="h-full bg-slate-900">

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <div class="h-full w-full overflow-auto flex flex-col items-center justify-center p-4">
    <!-- Container width reduced (smaller box) -->
    <div style="max-width: 680px; width: 100%; margin: 0 auto;">
      
      <div class="glass-card w-full">
        <!-- Reduced padding overall -->
        <div class="p-5 md:p-6">
          
          <!-- Header – slightly smaller icons and text -->
          <div class="text-center mb-4">
            <div class="flex justify-center mb-2">
              <i data-lucide="text" class="w-9 h-9 text-indigo-400"></i>
            </div>
            <h1 class="text-xl md:text-2xl font-bold text-white tracking-tight">Case Converter</h1>
            <p class="text-slate-400 mt-1 text-xs md:text-sm">
              Uppercase · Lowercase · Title Case · Sentence case
            </p>
          </div>
          
          <!-- Input Section – fewer rows for compactness -->
          <div class="mb-4">
            <label class="block text-slate-300 text-xs font-semibold mb-1 ml-1 flex items-center gap-1">
              <i data-lucide="edit-3" class="w-3.5 h-3.5 text-indigo-400"></i> Input Text
            </label>
            <textarea id="inputText" rows="3" class="case-textarea p-3 text-sm" placeholder="Type or paste text...&#10;Example: hello WORLD, this is a Demo"></textarea>
          </div>
          
          <!-- Action Buttons – more compact grid, smaller gap -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-2 mb-5">
            <button id="btnUppercase" class="action-btn bg-indigo-600/90 hover:bg-indigo-600 text-white font-semibold py-2 rounded-lg flex items-center justify-center gap-1.5 shadow-md transition-all text-xs md:text-sm">
              <i data-lucide="arrow-up" class="w-3.5 h-3.5"></i> UPPERCASE
            </button>
            <button id="BtnLowercase" class="action-btn bg-indigo-600/90 hover:bg-indigo-600 text-white font-semibold py-2 rounded-lg flex items-center justify-center gap-1.5 shadow-md transition-all text-xs md:text-sm">
              <i data-lucide="arrow-down" class="w-3.5 h-3.5"></i> lowercase
            </button>
            <button id="btnTitleCase" class="action-btn bg-indigo-600/90 hover:bg-indigo-600 text-white font-semibold py-2 rounded-lg flex items-center justify-center gap-1.5 shadow-md transition-all text-xs md:text-sm">
              <i data-lucide="text-cursor" class="w-3.5 h-3.5"></i> Title Case
            </button>
            <button id="btnSentenceCase" class="action-btn bg-indigo-600/90 hover:bg-indigo-600 text-white font-semibold py-2 rounded-lg flex items-center justify-center gap-1.5 shadow-md transition-all text-xs md:text-sm">
              <i data-lucide="case-sensitive" class="w-3.5 h-3.5"></i> Sentence case
            </button>
          </div>
          
          <!-- Output Section – reduced spacing, no scroll -->
          <div>
            <div class="flex justify-between items-center mb-1">
              <label class="text-slate-300 text-xs font-semibold flex items-center gap-1">
                <i data-lucide="file-output" class="w-3.5 h-3.5 text-indigo-400"></i> Converted Output
              </label>
              <button id="copyOutputBtn" class="text-indigo-400 hover:text-indigo-300 text-xs flex items-center gap-1 bg-slate-800/60 px-2.5 py-1 rounded-full transition-all action-btn">
                <i data-lucide="copy" class="w-3 h-3"></i> Copy
              </button>
            </div>
            <div id="outputArea" class="case-textarea p-3 text-sm bg-slate-900/40 text-slate-200 whitespace-pre-wrap break-words output-expand" style="border-color: rgba(71,85,105,0.5); min-height: 95px;">
              ⚠ Please enter some text to convert.
            </div>
          </div>
          
          <!-- Bottom Actions: Load Sample & Clear All – more compact -->
          <div class="flex flex-wrap justify-center gap-3 mt-5">
            <button id="loadSampleBtn" class="action-btn bg-slate-700 hover:bg-slate-600 text-slate-200 font-medium py-1.5 px-4 rounded-lg flex items-center gap-1.5 transition-all text-xs">
              <i data-lucide="file-text" class="w-3.5 h-3.5"></i> Load Sample
            </button>
            <button id="clearAllBtn" class="action-btn bg-red-500/20 hover:bg-red-500/30 text-red-400 font-medium py-1.5 px-4 rounded-lg flex items-center gap-1.5 transition-all text-xs">
              <i data-lucide="eraser" class="w-3.5 h-3.5"></i> Clear All
            </button>
          </div>
          
          <!-- Character count – smaller footprint -->
          <div class="text-right text-slate-500 text-[0.7rem] mt-4 flex justify-between items-center border-t border-slate-700/50 pt-3">
            <span class="flex items-center gap-1"><i data-lucide="info" class="w-3 h-3"></i> Instant conversion</span>
            <span id="charCounter" class="font-mono">0 characters</span>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Toast Notification (unchanged) -->
    <div id="toastMsg" class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 bg-emerald-500 text-white px-4 py-2 rounded-lg font-medium shadow-lg z-50 backdrop-blur-sm text-sm"></div>
  </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
    // DOM elements
    const inputTextarea = document.getElementById('inputText');
    const outputDiv = document.getElementById('outputArea');
    const btnUppercase = document.getElementById('btnUppercase');
    const btnLowercase = document.getElementById('BtnLowercase');
    const btnTitleCase = document.getElementById('btnTitleCase');
    const btnSentenceCase = document.getElementById('btnSentenceCase');
    const loadSampleBtn = document.getElementById('loadSampleBtn');
    const clearAllBtn = document.getElementById('clearAllBtn');
    const copyOutputBtn = document.getElementById('copyOutputBtn');
    const charCounterSpan = document.getElementById('charCounter');
    
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toastMsg');
      toast.textContent = message;
      toast.classList.remove('hidden', 'bg-emerald-500', 'bg-red-500');
      toast.classList.add(type === 'error' ? 'bg-red-500' : 'bg-emerald-500');
      setTimeout(() => toast.classList.add('hidden'), 2500);
    }
    
    function updateCharCounter() {
      const len = inputTextarea.value.length;
      charCounterSpan.textContent = `${len} character${len !== 1 ? 's' : ''}`;
    }
    
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }
    
    function setOutputText(text) {
      if (!text || text.trim() === '') {
        outputDiv.innerHTML = '⚠ Please enter some text to convert.';
        outputDiv.classList.add('output-placeholder');
      } else {
        outputDiv.innerHTML = escapeHtml(text);
        outputDiv.classList.remove('output-placeholder');
      }
    }
    
    function getCurrentInput() {
      const raw = inputTextarea.value;
      if (!raw.trim()) {
        showToast('Please enter some text first.', 'error');
        return null;
      }
      return raw;
    }
    
    // Conversion functions
    function toUpperCaseTransform() {
      const text = getCurrentInput();
      if (text === null) return;
      setOutputText(text.toUpperCase());
      showToast('UPPERCASE ✓');
    }
    
    function toLowerCaseTransform() {
      const text = getCurrentInput();
      if (text === null) return;
      setOutputText(text.toLowerCase());
      showToast('lowercase ✓');
    }
    
    function toTitleCaseTransform() {
      let text = getCurrentInput();
      if (text === null) return;
      const result = text.toLowerCase().replace(/\b\w/g, (char) => char.toUpperCase());
      setOutputText(result);
      showToast('Title Case ✓');
    }
    
    function toSentenceCaseTransform() {
      let text = getCurrentInput();
      if (text === null) return;
      let lowerText = text.toLowerCase();
      const sentenceCased = lowerText.replace(/(^\s*\w|[.!?]\s*\w)/g, (match) => match.toUpperCase());
      setOutputText(sentenceCased);
      showToast('Sentence case ✓');
    }
    
    function loadSampleText() {
      const sample = `the quick brown fox jumps over the lazy dog.
hello world! this is a DEMO text for case converter.
simple: make it clean.`;
      inputTextarea.value = sample;
      updateCharCounter();
      outputDiv.innerHTML = '⚠ Please enter some text to convert.';
      outputDiv.classList.add('output-placeholder');
      showToast('Sample loaded. Click any button to convert.', 'success');
    }
    
    function clearAll() {
      inputTextarea.value = '';
      updateCharCounter();
      outputDiv.innerHTML = '⚠ Please enter some text to convert.';
      outputDiv.classList.add('output-placeholder');
      showToast('Cleared everything', 'success');
    }
    
    async function copyOutputToClipboard() {
      let outputContent = outputDiv.innerText || outputDiv.textContent;
      if (outputContent === '⚠ Please enter some text to convert.' || outputContent.trim() === '') {
        showToast('Nothing to copy. Convert some text first.', 'error');
        return;
      }
      try {
        await navigator.clipboard.writeText(outputContent);
        showToast('Copied to clipboard!');
      } catch {
        showToast('Copy failed', 'error');
      }
    }
    
    // Attach events
    btnUppercase.addEventListener('click', () => { toUpperCaseTransform(); lucide.createIcons(); });
    btnLowercase.addEventListener('click', () => { toLowerCaseTransform(); lucide.createIcons(); });
    btnTitleCase.addEventListener('click', () => { toTitleCaseTransform(); lucide.createIcons(); });
    btnSentenceCase.addEventListener('click', () => { toSentenceCaseTransform(); lucide.createIcons(); });
    loadSampleBtn.addEventListener('click', () => { loadSampleText(); lucide.createIcons(); });
    clearAllBtn.addEventListener('click', () => { clearAll(); lucide.createIcons(); });
    copyOutputBtn.addEventListener('click', () => { copyOutputToClipboard(); lucide.createIcons(); });
    inputTextarea.addEventListener('input', () => {
      updateCharCounter();
      if (inputTextarea.value.trim() === '') {
        outputDiv.innerHTML = '⚠ Please enter some text to convert.';
        outputDiv.classList.add('output-placeholder');
      }
    });
    
    // Initialize
    updateCharCounter();
    lucide.createIcons();
    outputDiv.innerHTML = '⚠ Please enter some text to convert.';
    outputDiv.classList.add('output-placeholder');
    inputTextarea.value = '';
    updateCharCounter();
    
    // Ensure no scrollbars appear
    window.addEventListener('load', () => {
      lucide.createIcons();
      outputDiv.style.overflowY = 'visible';
      outputDiv.style.maxHeight = 'none';
    });
  </script>
</body>
</html>