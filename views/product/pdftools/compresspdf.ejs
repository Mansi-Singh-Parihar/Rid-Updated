<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>PDF Compressor – Reduce PDF Size</title>
    <!-- Tailwind CSS & Font Awesome -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- pdf-lib & pdf.js -->
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
 <link rel="icon" type="image/png" href="/assets/signup.png">
    <!-- Header / Footer CSS (your existing files) -->
    <link rel="stylesheet" href="/css/common/footer.css">
    <link rel="stylesheet" href="/css/common/header.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
            @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        .glass-panel {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 28px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            box-shadow: 0 15px 30px -10px rgba(0,0,0,0.3);
        }
        .upload-area {
            transition: all 0.2s ease;
        }
        .upload-area:hover {
            border-color: #818cf8;
            background: rgba(129,140,248,0.08);
            transform: translateY(-2px);
        }
        .btn-gradient {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            transition: all 0.2s;
        }
        .btn-gradient:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }
        /* Preview container – a little more height */
        .preview-container {
            height: 260px;            /* increased from 220px */
            overflow-y: auto;
            background: rgba(0,0,0,0.2);
            border-radius: 14px;
            padding: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .preview-canvas {
            max-width: 100%;
            max-height: 240px;        /* increased from 200px */
            object-fit: contain;
            border-radius: 10px;
        }
        .slider {
            width: 100%;
            height: 5px;
            appearance: none;
            -webkit-appearance: none;
            -moz-appearance: none;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            outline: none;
        }
        .slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 16px;
            height: 16px;
            background: #818cf8;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid white;
        }
        .file-info-compact {
            font-size: 0.75rem;
        }
    </style>
</head>
<body class="bg-slate-900 text-white">

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <div class="min-h-screen flex flex-col">
        <div class="flex-1 flex items-center justify-center p-3">
            <div class="w-full max-w-5xl">
                <div class="glass-panel p-4 md:p-5">
                    <div class="text-center mb-3">
                        <i class="fas fa-compress-alt text-indigo-400 text-3xl mb-1"></i>
                        <h1 class="text-xl md:text-2xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">
                            PDF Compressor
                        </h1>
                        <p class="text-slate-400 text-xs mt-0.5">
                            Reduce PDF size – all locally
                        </p>
                    </div>

                    <div class="flex flex-col md:flex-row gap-4">
                        <!-- LEFT PANEL -->
                        <div class="md:w-2/5">
                            <div id="dropZone" class="upload-area border-2 border-dashed border-slate-600 rounded-xl p-3 text-center cursor-pointer transition mb-3">
                                <i class="fas fa-cloud-upload-alt text-2xl text-indigo-400 mb-1"></i>
                                <p class="text-xs font-semibold">Drag & drop PDF</p>
                                <p class="text-slate-400 text-xs">or click to browse</p>
                                <input type="file" id="fileInput" accept=".pdf" class="hidden" />
                            </div>

                            <div id="fileInfo" class="bg-slate-800/30 rounded-xl p-2 mb-3 hidden file-info-compact">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-file-pdf text-red-400 text-sm"></i>
                                    <span id="fileName" class="text-xs font-medium truncate"></span>
                                </div>
                                <div class="text-xs text-slate-400 mt-0.5">
                                    <span id="originalSize"></span> · <span id="pageCount"></span> pages
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="text-xs font-semibold text-slate-300 block mb-1">
                                    <i class="fas fa-image mr-1"></i> Compression Strength
                                </label>
                                <div class="flex items-center gap-2">
                                    <span class="text-xs text-slate-400">Smaller</span>
                                    <input type="range" id="qualitySlider" class="slider flex-1" min="10" max="90" value="60">
                                    <span class="text-xs text-slate-400">Better</span>
                                </div>
                                <p class="text-[11px] text-slate-500 mt-1">Lower = smaller file, lower quality</p>
                            </div>

                            <div class="flex gap-2 mt-2">
                                <button id="compressBtn" class="btn-gradient flex-1 py-1.5 rounded-full text-white font-semibold flex items-center justify-center gap-1 text-sm disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                                    <i class="fas fa-compress-alt text-xs"></i> Compress
                                </button>
                                <button id="clearBtn" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-3 py-1.5 rounded-full flex items-center gap-1 text-sm transition">
                                    <i class="fas fa-trash-alt text-xs"></i> Clear
                                </button>
                            </div>
                        </div>

                        <!-- RIGHT PANEL: preview -->
                        <div class="md:w-3/5">
                            <div class="bg-slate-800/30 rounded-xl p-3 h-full flex flex-col">
                                <div class="flex justify-between items-center mb-2">
                                    <h3 class="text-xs font-semibold text-slate-300">
                                        <i class="fas fa-eye mr-1"></i> <span id="previewTitle">PDF Preview</span>
                                    </h3>
                                    <button id="downloadBtn" class="bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 px-2 py-0.5 rounded-full text-[11px] flex items-center gap-1 transition hidden">
                                        <i class="fas fa-download text-xs"></i> Download
                                    </button>
                                </div>
                                <div id="previewContainer" class="preview-container bg-slate-900/40 rounded-lg">
                                    <i class="fas fa-file-pdf text-4xl text-slate-600 mb-1"></i>
                                    <p class="text-slate-500 text-xs">Upload a PDF to begin.</p>
                                </div>
                                <div class="text-center text-[11px] text-slate-500 mt-2">
                                    <span id="previewInfo"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 text-[11px] text-center text-slate-500 border-t border-slate-700/50 pt-3">
                        <i class="fas fa-laptop-code mr-1"></i> All processing is local — files stay on your device.<br>
                        <span class="text-slate-600">Renders pages as images → smaller PDF. Ideal for scanned docs.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        // DOM elements (same functionality, no changes)
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const fileInfoDiv = document.getElementById('fileInfo');
        const fileNameSpan = document.getElementById('fileName');
        const originalSizeSpan = document.getElementById('originalSize');
        const pageCountSpan = document.getElementById('pageCount');
        const qualitySlider = document.getElementById('qualitySlider');
        const compressBtn = document.getElementById('compressBtn');
        const clearBtn = document.getElementById('clearBtn');
        const downloadBtn = document.getElementById('downloadBtn');
        const previewContainer = document.getElementById('previewContainer');
        const previewTitle = document.getElementById('previewTitle');
        const previewInfoSpan = document.getElementById('previewInfo');

        let currentPdfData = null;
        let totalPages = 0;
        let originalFileSize = 0;
        let compressedBlob = null;

        function showToast(msg, type = 'success') {
            let toast = document.getElementById('compressToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'compressToast';
                toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-4 py-1.5 rounded-full text-white text-xs font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none';
                document.body.appendChild(toast);
            }
            let bg = type === 'error' ? 'bg-red-500' : (type === 'info' ? 'bg-blue-500' : 'bg-emerald-500');
            toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-4 py-1.5 rounded-full text-white text-xs font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none ${bg}`;
            toast.textContent = msg;
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 2500);
        }

        async function showOriginalPreview() {
            if (!currentPdfData) return;
            previewTitle.textContent = 'Original PDF Preview';
            previewContainer.innerHTML = `<div class="flex justify-center items-center h-full"><div class="text-slate-400 text-xs"><i class="fas fa-spinner fa-spin"></i> Loading preview...</div></div>`;
            try {
                const pdfDoc = await pdfjsLib.getDocument({ data: currentPdfData }).promise;
                const page = await pdfDoc.getPage(1);
                const viewport = page.getViewport({ scale: 0.6 });
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                await page.render({ canvasContext: ctx, viewport }).promise;
                previewContainer.innerHTML = '';
                const img = document.createElement('img');
                img.src = canvas.toDataURL();
                img.className = 'preview-canvas';
                previewContainer.appendChild(img);
                previewInfoSpan.textContent = `Page 1 of ${totalPages} (original: ${(originalFileSize/1024).toFixed(1)} KB)`;
                downloadBtn.classList.add('hidden');
            } catch (err) {
                console.error(err);
                previewContainer.innerHTML = `<div class="text-center text-red-400 text-xs"><i class="fas fa-exclamation-triangle"></i> Could not preview PDF.</div>`;
            }
        }

        async function showCompressedPreview(pdfBytes, compressedSize) {
            previewTitle.textContent = 'Compressed PDF Preview';
            previewContainer.innerHTML = `<div class="flex justify-center items-center h-full"><div class="text-slate-400 text-xs"><i class="fas fa-spinner fa-spin"></i> Rendering preview...</div></div>`;
            try {
                const pdfDoc = await pdfjsLib.getDocument({ data: pdfBytes }).promise;
                const page = await pdfDoc.getPage(1);
                const viewport = page.getViewport({ scale: 0.6 });
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                await page.render({ canvasContext: ctx, viewport }).promise;
                previewContainer.innerHTML = '';
                const img = document.createElement('img');
                img.src = canvas.toDataURL();
                img.className = 'preview-canvas';
                previewContainer.appendChild(img);
                const savings = ((originalFileSize - compressedSize) / originalFileSize * 100).toFixed(1);
                previewInfoSpan.textContent = `Compressed: ${(compressedSize/1024).toFixed(1)} KB (${savings}% saved)`;
                downloadBtn.classList.remove('hidden');
            } catch (err) {
                console.error(err);
                previewContainer.innerHTML = `<div class="text-center text-red-400 text-xs"><i class="fas fa-exclamation-triangle"></i> Could not preview compressed PDF.</div>`;
                downloadBtn.classList.add('hidden');
            }
        }

        async function compressPDF() {
            if (!currentPdfData) {
                showToast('No PDF loaded.', 'error');
                return;
            }

            const jpegQuality = parseInt(qualitySlider.value) / 100;
            const scaleFactor = 0.5 + (jpegQuality * 0.5);
            const finalScale = Math.min(1.0, Math.max(0.55, scaleFactor));

            compressBtn.disabled = true;
            compressBtn.innerHTML = '<i class="fas fa-spinner fa-spin text-xs"></i> Compressing...';
            previewContainer.innerHTML = `<div class="text-slate-400 text-xs"><i class="fas fa-spinner fa-spin"></i> Processing ${totalPages} pages...</div>`;
            downloadBtn.classList.add('hidden');

            try {
                const pdfDoc = await pdfjsLib.getDocument({ data: currentPdfData }).promise;
                const newPdf = await PDFLib.PDFDocument.create();

                for (let i = 1; i <= totalPages; i++) {
                    const page = await pdfDoc.getPage(i);
                    const viewport = page.getViewport({ scale: finalScale });
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    canvas.width = viewport.width;
                    canvas.height = viewport.height;
                    await page.render({ canvasContext: ctx, viewport }).promise;
                    const jpegBlob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', jpegQuality));
                    const jpegBytes = await jpegBlob.arrayBuffer();
                    const embeddedImage = await newPdf.embedJpg(jpegBytes);
                    const newPage = newPdf.addPage([embeddedImage.width, embeddedImage.height]);
                    newPage.drawImage(embeddedImage, { x: 0, y: 0, width: embeddedImage.width, height: embeddedImage.height });
                    
                    if (i % 5 === 0 || i === totalPages) {
                        previewContainer.innerHTML = `<div class="text-slate-400 text-xs"><i class="fas fa-spinner fa-spin"></i> Page ${i}/${totalPages}...</div>`;
                    }
                }
                const pdfBytes = await newPdf.save();
                compressedBlob = new Blob([pdfBytes], { type: 'application/pdf' });
                await showCompressedPreview(pdfBytes, compressedBlob.size);
                showToast(`Compression complete! Saved ${((originalFileSize - compressedBlob.size)/1024).toFixed(1)} KB.`, 'success');
            } catch (err) {
                console.error(err);
                showToast('Compression failed.', 'error');
                previewContainer.innerHTML = `<div class="text-center text-red-400 text-xs"><i class="fas fa-exclamation-triangle"></i> Compression failed.</div>`;
            } finally {
                compressBtn.disabled = false;
                compressBtn.innerHTML = '<i class="fas fa-compress-alt"></i> Compress';
            }
        }

        function downloadCompressed() {
            if (!compressedBlob) {
                showToast('No compressed PDF. Please compress first.', 'error');
                return;
            }
            const link = document.createElement('a');
            const url = URL.createObjectURL(compressedBlob);
            link.href = url;
            link.download = `compressed_${new Date().toISOString().slice(0,19).replace(/:/g, '-')}.pdf`;
            link.click();
            URL.revokeObjectURL(url);
            showToast('Download started!', 'success');
        }

        async function loadPDF(file) {
            if (!file || file.type !== 'application/pdf') {
                showToast('Please select a valid PDF file.', 'error');
                return;
            }
            const reader = new FileReader();
            reader.onload = async function(e) {
                currentPdfData = new Uint8Array(e.target.result);
                originalFileSize = currentPdfData.byteLength;
                try {
                    const pdfDoc = await pdfjsLib.getDocument({ data: currentPdfData }).promise;
                    totalPages = pdfDoc.numPages;
                    fileNameSpan.textContent = file.name;
                    originalSizeSpan.textContent = `${(originalFileSize/1024).toFixed(1)} KB`;
                    pageCountSpan.textContent = totalPages;
                    fileInfoDiv.classList.remove('hidden');
                    compressBtn.disabled = false;
                    await showOriginalPreview();
                    showToast(`PDF loaded: ${totalPages} pages, ${(originalFileSize/1024).toFixed(1)} KB`, 'success');
                } catch (err) {
                    console.error(err);
                    showToast('Could not read PDF.', 'error');
                    clearAll();
                }
            };
            reader.onerror = () => showToast('Error reading file', 'error');
            reader.readAsArrayBuffer(file);
        }

        function clearAll() {
            currentPdfData = null;
            totalPages = 0;
            originalFileSize = 0;
            compressedBlob = null;
            fileInfoDiv.classList.add('hidden');
            compressBtn.disabled = true;
            downloadBtn.classList.add('hidden');
            previewContainer.innerHTML = `<i class="fas fa-file-pdf text-4xl text-slate-600 mb-2"></i>
                                          <p class="text-slate-500 text-xs">Upload a PDF to begin.</p>`;
            previewTitle.textContent = 'PDF Preview';
            previewInfoSpan.textContent = '';
            fileInput.value = '';
            showToast('Cleared', 'info');
        }

        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
            const file = e.dataTransfer.files[0];
            if (file && file.type === 'application/pdf') loadPDF(file);
            else showToast('Please drop a valid PDF file.', 'error');
        });
        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length) loadPDF(e.target.files[0]);
            fileInput.value = '';
        });

        clearBtn.addEventListener('click', clearAll);
        compressBtn.addEventListener('click', compressPDF);
        downloadBtn.addEventListener('click', downloadCompressed);

        clearAll();
    </script>
</body>
</html>