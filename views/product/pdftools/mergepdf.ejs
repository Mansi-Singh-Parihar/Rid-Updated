<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>PDF Merger – Preview & Download</title>
    <!-- Tailwind CSS & Font Awesome -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- pdf-lib & pdf.js -->
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Header / Footer CSS (your existing files) -->
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
     <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass-panel {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.3);
        }
            @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        .upload-area {
            transition: all 0.2s ease;
        }
        .upload-area:hover {
            border-color: #818cf8;
            background: rgba(129,140,248,0.08);
            transform: translateY(-2px);
        }
        .btn-gradient {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            transition: all 0.2s;
        }
        .btn-gradient:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }
        .file-item {
            transition: all 0.2s;
            cursor: pointer;
        }
        .file-item:hover, .file-item.selected {
            background: rgba(129,140,248,0.2);
            border-left: 3px solid #818cf8;
        }
        .drag-handle { cursor: grab; }
        .drag-handle:active { cursor: grabbing; }
        .file-list-scroll {
            max-height: 360px;
            overflow-y: auto;
        }
        .file-list-scroll::-webkit-scrollbar {
            width: 5px;
        }
        .file-list-scroll::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
        }
        .file-list-scroll::-webkit-scrollbar-thumb {
            background: rgba(129,140,248,0.5);
            border-radius: 10px;
        }
        .thumbnail-canvas {
            width: 50px;
            height: auto;
            background: white;
            border-radius: 6px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }
        .preview-canvas {
            max-width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }
        .preview-container {
            min-height: 380px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body class="bg-slate-900 text-white">

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <div class="min-h-screen flex flex-col">
        <div class="flex-1 flex items-center justify-center p-4">
            <div class="w-full max-w-6xl">
                <div class="glass-panel p-6 md:p-8">
                    <div class="text-center mb-6">
                        <i class="fas fa-file-pdf text-red-400 text-4xl mb-2"></i>
                        <h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-red-400 to-indigo-400 bg-clip-text text-transparent">
                            PDF Merger
                        </h1>
                        <p class="text-slate-400 text-sm mt-2">
                            Combine PDFs – preview each file, then merge, preview result & download.
                        </p>
                    </div>

                    <div class="flex flex-col md:flex-row gap-6">
                        <!-- LEFT PANEL -->
                        <div class="md:w-2/5">
                            <div id="dropZone" class="upload-area border-2 border-dashed border-slate-600 rounded-2xl p-4 text-center cursor-pointer transition mb-4">
                                <i class="fas fa-cloud-upload-alt text-3xl text-indigo-400 mb-2"></i>
                                <p class="text-sm font-semibold">Drag & drop PDF files</p>
                                <p class="text-slate-400 text-xs mt-1">or click to browse</p>
                                <input type="file" id="fileInput" accept=".pdf" multiple class="hidden" />
                            </div>
                            <div>
                                <div class="flex justify-between items-center mb-2">
                                    <h3 class="text-sm font-semibold text-slate-300"><i class="fas fa-list mr-1"></i> Files to merge</h3>
                                    <span id="fileCount" class="text-xs text-slate-400">0 files</span>
                                </div>
                                <div id="fileList" class="file-list-scroll rounded-lg bg-slate-800/30 p-2 min-h-[200px]">
                                    <div class="text-slate-500 text-center p-4">No files added yet.</div>
                                </div>
                                <p class="text-xs text-slate-500 mt-2 flex items-center gap-1">
                                    <i class="fas fa-arrows-alt"></i> Drag ☰ to reorder • Click a file to preview
                                </p>
                            </div>
                            <div class="flex gap-3 mt-4">
                                <button id="mergeBtn" class="btn-gradient flex-1 py-2 rounded-full text-white font-semibold flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                                    <i class="fas fa-compress-alt"></i> Merge & Preview Result
                                </button>
                                <button id="clearBtn" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-4 py-2 rounded-full flex items-center gap-2 transition">
                                    <i class="fas fa-trash-alt"></i> Clear
                                </button>
                            </div>
                        </div>

                        <!-- RIGHT PANEL -->
                        <div class="md:w-3/5">
                            <div class="bg-slate-800/30 rounded-2xl p-4 h-full flex flex-col">
                                <div class="flex justify-between items-center mb-3">
                                    <h3 class="text-sm font-semibold text-slate-300">
                                        <i class="fas fa-eye mr-1"></i> <span id="previewTitle">File Preview</span>
                                    </h3>
                                    <!-- Download button: hidden by default, shown after merge -->
                                    <button id="downloadMergedBtn" class="bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 px-3 py-1 rounded-full text-xs flex items-center gap-1 transition hidden">
                                        <i class="fas fa-download"></i> Download Merged PDF
                                    </button>
                                </div>
                                <div id="previewContainer" class="preview-container flex-1 bg-slate-900/40 rounded-xl p-4 min-h-[380px]">
                                    <i class="fas fa-file-pdf text-5xl text-slate-600 mb-3"></i>
                                    <p class="text-slate-500 text-sm">Select a PDF from the list to preview.</p>
                                </div>
                                <div class="text-center text-xs text-slate-500 mt-3">
                                    <span id="previewInfo"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-6 text-xs text-center text-slate-500 border-t border-slate-700/50 pt-4">
                        <i class="fas fa-laptop-code mr-1"></i> All processing is local — your files never leave your device.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        // DOM elements
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const fileListDiv = document.getElementById('fileList');
        const mergeBtn = document.getElementById('mergeBtn');
        const clearBtn = document.getElementById('clearBtn');
        const downloadBtn = document.getElementById('downloadMergedBtn');
        const fileCountSpan = document.getElementById('fileCount');
        const previewContainer = document.getElementById('previewContainer');
        const previewTitle = document.getElementById('previewTitle');
        const previewInfoSpan = document.getElementById('previewInfo');

        let filesArray = [];        // { name, file, pageCount, thumbnailURL, pdfData }
        let selectedFileIndex = null;
        let mergedBlob = null;       // store merged PDF blob

        function showToast(msg, type = 'success') {
            let toast = document.getElementById('mergeToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'mergeToast';
                toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none';
                document.body.appendChild(toast);
            }
            let bg = type === 'error' ? 'bg-red-500' : (type === 'info' ? 'bg-blue-500' : 'bg-emerald-500');
            toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none ${bg}`;
            toast.textContent = msg;
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 2500);
        }

        async function generatePreviewData(file) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                reader.onload = async function(e) {
                    const typedarray = new Uint8Array(e.target.result);
                    try {
                        const pdfDoc = await pdfjsLib.getDocument({ data: typedarray }).promise;
                        const pageCount = pdfDoc.numPages;
                        const page = await pdfDoc.getPage(1);
                        const viewport = page.getViewport({ scale: 0.3 });
                        const canvas = document.createElement('canvas');
                        const ctx = canvas.getContext('2d');
                        canvas.width = viewport.width;
                        canvas.height = viewport.height;
                        await page.render({ canvasContext: ctx, viewport }).promise;
                        resolve({ pageCount, thumbnailURL: canvas.toDataURL(), pdfData: typedarray });
                    } catch (err) {
                        resolve({ pageCount: 0, thumbnailURL: null, pdfData: null });
                    }
                };
                reader.onerror = () => resolve({ pageCount: 0, thumbnailURL: null, pdfData: null });
                reader.readAsArrayBuffer(file);
            });
        }

        async function showFilePreview(index) {
            if (index < 0 || index >= filesArray.length) return;
            const item = filesArray[index];
            previewTitle.textContent = `Preview: ${item.name}`;
            previewContainer.innerHTML = `<div class="text-slate-400"><i class="fas fa-spinner fa-spin"></i> Loading preview...</div>`;
            try {
                const pdfDoc = await pdfjsLib.getDocument({ data: item.pdfData }).promise;
                const pageCount = pdfDoc.numPages;
                const page = await pdfDoc.getPage(1);
                const viewport = page.getViewport({ scale: 1.0 });
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                await page.render({ canvasContext: ctx, viewport }).promise;
                previewContainer.innerHTML = '';
                const img = document.createElement('img');
                img.src = canvas.toDataURL();
                img.className = 'preview-canvas max-w-full max-h-[400px] object-contain rounded-lg shadow-lg';
                previewContainer.appendChild(img);
                previewInfoSpan.textContent = `Page 1 of ${pageCount} (${item.name})`;
                downloadBtn.classList.add('hidden');   // hide download button when viewing individual file
            } catch (err) {
                previewContainer.innerHTML = `<div class="text-center text-red-400"><i class="fas fa-exclamation-triangle"></i> Could not preview this PDF.</div>`;
            }
        }

        async function showMergedPreview(pdfBytes, totalPages) {
            previewTitle.textContent = 'Preview: Merged PDF';
            previewContainer.innerHTML = `<div class="text-slate-400"><i class="fas fa-spinner fa-spin"></i> Rendering merged preview...</div>`;
            try {
                const pdfDoc = await pdfjsLib.getDocument({ data: pdfBytes }).promise;
                const page = await pdfDoc.getPage(1);
                const viewport = page.getViewport({ scale: 1.0 });
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                await page.render({ canvasContext: ctx, viewport }).promise;
                previewContainer.innerHTML = '';
                const img = document.createElement('img');
                img.src = canvas.toDataURL();
                img.className = 'preview-canvas max-w-full max-h-[400px] object-contain rounded-lg shadow-lg';
                previewContainer.appendChild(img);
                previewInfoSpan.textContent = `${totalPages} page${totalPages !== 1 ? 's' : ''} total (merged result)`;
                // Show download button after merge preview
                downloadBtn.classList.remove('hidden');
            } catch (err) {
                previewContainer.innerHTML = `<div class="text-center text-red-400"><i class="fas fa-exclamation-triangle"></i> Could not preview merged PDF.</div>`;
                downloadBtn.classList.add('hidden');
            }
        }

        function renderFileList() {
            if (filesArray.length === 0) {
                fileListDiv.innerHTML = '<div class="text-slate-500 text-center p-4">No files added yet.</div>';
                fileCountSpan.textContent = '0 files';
                mergeBtn.disabled = true;
                previewContainer.innerHTML = `<i class="fas fa-file-pdf text-5xl text-slate-600 mb-3"></i><p class="text-slate-500 text-sm">No files. Upload PDFs to begin.</p>`;
                previewTitle.textContent = 'File Preview';
                previewInfoSpan.textContent = '';
                downloadBtn.classList.add('hidden');
                return;
            }
            fileListDiv.innerHTML = '';
            filesArray.forEach((item, idx) => {
                const div = document.createElement('div');
                div.className = `file-item flex items-center gap-3 bg-slate-800/50 rounded-lg p-2 mb-2 border border-slate-700/50 ${selectedFileIndex === idx ? 'selected' : ''}`;
                div.setAttribute('data-index', idx);
                div.draggable = true;

                const drag = document.createElement('div');
                drag.className = 'drag-handle cursor-grab text-slate-400';
                drag.innerHTML = '<i class="fas fa-grip-vertical"></i>';
                drag.draggable = true;

                const thumb = document.createElement('div');
                if (item.thumbnailURL) {
                    const img = document.createElement('img');
                    img.src = item.thumbnailURL;
                    img.className = 'thumbnail-canvas w-10 h-auto rounded border border-slate-600';
                    thumb.appendChild(img);
                } else {
                    thumb.innerHTML = '<div class="w-10 h-14 bg-slate-700 rounded flex items-center justify-center"><i class="fas fa-file-pdf text-xs text-slate-400"></i></div>';
                }

                const info = document.createElement('div');
                info.className = 'flex-1';
                info.innerHTML = `<div class="text-sm font-medium truncate max-w-[150px]">${escapeHtml(item.name)}</div>
                                  <div class="text-xs text-slate-400 flex gap-2 mt-1">
                                      <span>${(item.file.size/1024).toFixed(0)} KB</span>
                                      <span>${item.pageCount} pg</span>
                                  </div>`;
                const remove = document.createElement('button');
                remove.className = 'text-red-400 hover:text-red-300 transition';
                remove.innerHTML = '<i class="fas fa-times-circle"></i>';
                remove.onclick = (e) => { e.stopPropagation(); removeFile(idx); };

                div.appendChild(drag);
                div.appendChild(thumb);
                div.appendChild(info);
                div.appendChild(remove);
                div.addEventListener('click', () => setSelectedFile(idx));
                div.addEventListener('dragstart', handleDragStart);
                div.addEventListener('dragenter', handleDragEnter);
                div.addEventListener('dragover', handleDragOver);
                div.addEventListener('dragend', handleDragEnd);
                div.addEventListener('drop', handleDrop);
                fileListDiv.appendChild(div);
            });
            fileCountSpan.textContent = `${filesArray.length} file${filesArray.length !== 1 ? 's' : ''}`;
            mergeBtn.disabled = false;
        }

        function escapeHtml(str) { return str.replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' }[m])); }

        let dragSrcIndex = null;
        function handleDragStart(e) {
            const t = e.target.closest('.file-item');
            if (t) { dragSrcIndex = parseInt(t.dataset.index); e.dataTransfer.setData('text/plain', dragSrcIndex); t.style.opacity = '0.4'; }
        }
        function handleDragEnter(e) {
            const t = e.target.closest('.file-item');
            if (t && t.dataset.index != dragSrcIndex) t.classList.add('bg-indigo-500/20','border-indigo-400');
        }
        function handleDragOver(e) { e.preventDefault(); e.dataTransfer.dropEffect = 'move'; }
        function handleDragEnd(e) {
            document.querySelectorAll('.file-item').forEach(i => { i.style.opacity = ''; i.classList.remove('bg-indigo-500/20','border-indigo-400'); });
            dragSrcIndex = null;
        }
        function handleDrop(e) {
            e.preventDefault();
            const t = e.target.closest('.file-item');
            if (t && dragSrcIndex !== null) {
                const dest = parseInt(t.dataset.index);
                if (dest !== dragSrcIndex) {
                    const moved = filesArray[dragSrcIndex];
                    filesArray.splice(dragSrcIndex,1);
                    filesArray.splice(dest,0,moved);
                    if (selectedFileIndex === dragSrcIndex) selectedFileIndex = dest;
                    else if (selectedFileIndex > dragSrcIndex && selectedFileIndex <= dest) selectedFileIndex--;
                    else if (selectedFileIndex < dragSrcIndex && selectedFileIndex >= dest) selectedFileIndex++;
                    renderFileList();
                    if (selectedFileIndex !== null) showFilePreview(selectedFileIndex);
                }
            }
            document.querySelectorAll('.file-item').forEach(i => i.classList.remove('bg-indigo-500/20','border-indigo-400'));
            dragSrcIndex = null;
        }

        function setSelectedFile(idx) {
            selectedFileIndex = idx;
            renderFileList();
            showFilePreview(idx);
        }

        async function addFiles(newFiles) {
            const pdfs = Array.from(newFiles).filter(f => f.type === 'application/pdf');
            if (!pdfs.length) { showToast('No valid PDFs', 'error'); return; }
            let added = 0;
            for (const f of pdfs) {
                if (filesArray.some(ex => ex.name === f.name && ex.file.size === f.size)) {
                    showToast(`"${f.name}" already added`, 'info');
                    continue;
                }
                added++;
                const { pageCount, thumbnailURL, pdfData } = await generatePreviewData(f);
                filesArray.push({ name: f.name, file: f, pageCount, thumbnailURL, pdfData });
            }
            if (added) {
                renderFileList();
                if (!selectedFileIndex && filesArray.length) setSelectedFile(0);
                else if (selectedFileIndex !== null) showFilePreview(selectedFileIndex);
                showToast(`${added} PDF(s) added`, 'success');
            }
        }

        function removeFile(idx) {
            filesArray.splice(idx,1);
            if (selectedFileIndex === idx) {
                if (filesArray.length) selectedFileIndex = 0;
                else selectedFileIndex = null;
            } else if (selectedFileIndex !== null && selectedFileIndex > idx) selectedFileIndex--;
            renderFileList();
            if (filesArray.length && selectedFileIndex !== null) showFilePreview(selectedFileIndex);
            else if (!filesArray.length) {
                previewContainer.innerHTML = `<i class="fas fa-file-pdf text-5xl text-slate-600 mb-3"></i><p class="text-slate-500 text-sm">No files. Upload PDFs to begin.</p>`;
                previewTitle.textContent = 'File Preview';
                previewInfoSpan.textContent = '';
                downloadBtn.classList.add('hidden');
            }
            showToast('File removed', 'info');
        }

        function clearAll() {
            filesArray = [];
            selectedFileIndex = null;
            mergedBlob = null;
            renderFileList();
            previewContainer.innerHTML = `<i class="fas fa-file-pdf text-5xl text-slate-600 mb-3"></i><p class="text-slate-500 text-sm">No files. Upload PDFs to begin.</p>`;
            previewTitle.textContent = 'File Preview';
            previewInfoSpan.textContent = '';
            downloadBtn.classList.add('hidden');
            showToast('Cleared all', 'info');
        }

        async function mergeAndPreview() {
            if (!filesArray.length) { showToast('No files to merge', 'error'); return; }
            mergeBtn.disabled = true;
            mergeBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Merging...';
            previewContainer.innerHTML = `<div class="text-slate-400"><i class="fas fa-spinner fa-spin"></i> Creating merged PDF...</div>`;
            downloadBtn.classList.add('hidden');   // hide download button until merge completes
            try {
                const mergedPdf = await PDFLib.PDFDocument.create();
                let totalPages = 0;
                for (const item of filesArray) {
                    const doc = await PDFLib.PDFDocument.load(item.pdfData.buffer);
                    totalPages += doc.getPageCount();
                    const pages = await mergedPdf.copyPages(doc, doc.getPageIndices());
                    pages.forEach(p => mergedPdf.addPage(p));
                }
                const pdfBytes = await mergedPdf.save();
                mergedBlob = new Blob([pdfBytes], { type: 'application/pdf' });
                await showMergedPreview(pdfBytes, totalPages);
                showToast('Merge complete! You can now download the merged PDF.', 'success');
            } catch (err) {
                console.error(err);
                showToast('Merge failed. Check PDFs are valid.', 'error');
                previewContainer.innerHTML = `<div class="text-center text-red-400"><i class="fas fa-exclamation-triangle"></i> Merge failed.</div>`;
                downloadBtn.classList.add('hidden');
            } finally {
                mergeBtn.disabled = false;
                mergeBtn.innerHTML = '<i class="fas fa-compress-alt"></i> Merge & Preview Result';
            }
        }

        function downloadMerged() {
            if (!mergedBlob) { showToast('No merged PDF. Please merge first.', 'error'); return; }
            const link = document.createElement('a');
            const url = URL.createObjectURL(mergedBlob);
            link.href = url;
            link.download = `merged_${new Date().toISOString().slice(0,19).replace(/:/g, '-')}.pdf`;
            link.click();
            URL.revokeObjectURL(url);
            showToast('Download started!', 'success');
        }

        // Event listeners
        dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('border-indigo-400','bg-indigo-500/10'); });
        dropZone.addEventListener('dragleave', () => dropZone.classList.remove('border-indigo-400','bg-indigo-500/10'));
        dropZone.addEventListener('drop', e => { e.preventDefault(); dropZone.classList.remove('border-indigo-400','bg-indigo-500/10'); addFiles(e.dataTransfer.files); });
        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', e => { addFiles(e.target.files); fileInput.value = ''; });
        clearBtn.addEventListener('click', clearAll);
        mergeBtn.addEventListener('click', mergeAndPreview);
        downloadBtn.addEventListener('click', downloadMerged);
        renderFileList();
    </script>
</body>
</html>