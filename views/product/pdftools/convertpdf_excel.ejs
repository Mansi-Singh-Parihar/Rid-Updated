<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>PDF to Excel Converter</title>
    <!-- Tailwind CSS & Font Awesome -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- pdf.js & SheetJS (XLSX) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Header / Footer CSS (your existing files) -->
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
     <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        /* additional custom styles */
        body {
            font-family: 'Inter', sans-serif;
        }
            @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        .glass-panel {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.3);
        }
        .preview-box {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 20px;
            padding: 1rem;
            max-height: 250px;
            overflow-y: auto;
            font-family: monospace;
            font-size: 0.8rem;
            white-space: pre-wrap;
            word-break: break-word;
        }
        .preview-box::-webkit-scrollbar {
            width: 5px;
        }
        .preview-box::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        .preview-box::-webkit-scrollbar-thumb {
            background: rgba(129, 140, 248, 0.5);
            border-radius: 10px;
        }
        .btn-gradient {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            transition: all 0.2s;
        }
        .btn-gradient:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }
        .upload-area {
            transition: all 0.2s ease;
        }
        .upload-area:hover {
            border-color: #818cf8;
            background: rgba(129, 140, 248, 0.08);
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="bg-slate-900 text-white">

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <!-- Main content – flex column to push footer down -->
    <div class="min-h-screen flex flex-col">
        <div class="flex-1 flex items-center justify-center p-4">
            <div class="w-full max-w-3xl">
                <div class="glass-panel p-6 md:p-8">
                    <!-- Header of the tool -->
                    <div class="text-center mb-6">
                        <i class="fas fa-file-pdf text-indigo-400 text-4xl mb-2"></i>
                        <h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">
                            PDF to Excel Converter
                        </h1>
                        <p class="text-slate-400 text-sm mt-2">
                            Extract all text from your PDF and save it as a ready‑to‑use Excel file (XLSX).
                        </p>
                    </div>

                    <!-- Drag & Drop Upload Area -->
                    <div id="dropZone" class="upload-area border-2 border-dashed border-slate-600 rounded-2xl p-6 text-center cursor-pointer transition">
                        <i class="fas fa-cloud-upload-alt text-4xl text-indigo-400 mb-3"></i>
                        <p class="text-lg font-semibold">Drag & drop a PDF file here</p>
                        <p class="text-slate-400 text-sm mt-1">or click to browse</p>
                        <input type="file" id="fileInput" accept=".pdf" class="hidden" />
                    </div>

                    <!-- Preview of extracted text -->
                    <div class="mt-6">
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="text-sm font-semibold text-slate-300"><i class="fas fa-eye mr-1"></i> Extracted Text Preview</h3>
                            <span id="status" class="text-xs text-slate-400">No file loaded</span>
                        </div>
                        <div id="preview" class="preview-box">
                            <span class="text-slate-500">Your extracted text will appear here...</span>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-wrap gap-3 mt-6">
                        <button id="convertBtn" class="btn-gradient flex-1 py-2 rounded-full text-white font-semibold flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                            <i class="fas fa-file-excel"></i> Convert to Excel
                        </button>
                        <button id="clearBtn" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-4 py-2 rounded-full flex items-center gap-2 transition">
                            <i class="fas fa-trash-alt"></i> Clear
                        </button>
                    </div>

                    <!-- Info note -->
                    <div class="mt-5 text-xs text-center text-slate-500 border-t border-slate-700/50 pt-4">
                        <i class="fas fa-laptop-code mr-1"></i> Everything runs locally in your browser — your files never leave your device.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        // DOM elements
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const convertBtn = document.getElementById('convertBtn');
        const clearBtn = document.getElementById('clearBtn');
        const previewDiv = document.getElementById('preview');
        const statusSpan = document.getElementById('status');

        let currentFile = null;
        let extractedText = '';     // will hold the full plain text

        // Helper: show toast notification (simple)
        function showToast(msg, type = 'info') {
            let toast = document.getElementById('customToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'customToast';
                toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none';
                document.body.appendChild(toast);
            }
            let bg = 'bg-emerald-500';
            if (type === 'error') bg = 'bg-red-500';
            if (type === 'info') bg = 'bg-blue-500';
            toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none ${bg}`;
            toast.textContent = msg;
            toast.style.opacity = '1';
            setTimeout(() => {
                toast.style.opacity = '0';
            }, 2500);
        }

        // Main PDF processing: extract text using pdf.js
        async function extractTextFromPDF(file) {
            return new Promise((resolve, reject) => {
                const fileReader = new FileReader();
                fileReader.onload = async function() {
                    const typedarray = new Uint8Array(this.result);
                    try {
                        // Load the PDF document
                        const loadingTask = pdfjsLib.getDocument({ data: typedarray });
                        const pdf = await loadingTask.promise;
                        let fullText = '';
                        // Loop through all pages
                        for (let i = 1; i <= pdf.numPages; i++) {
                            const page = await pdf.getPage(i);
                            const textContent = await page.getTextContent();
                            // Collect text items and join them
                            const pageText = textContent.items.map(item => item.str).join(' ');
                            fullText += pageText + '\n\n';  // add paragraph separation
                        }
                        resolve(fullText.trim());
                    } catch (err) {
                        reject(err);
                    }
                };
                fileReader.onerror = () => reject(new Error('Failed to read file'));
                fileReader.readAsArrayBuffer(file);
            });
        }

        // Update preview and enable convert button
        function updatePreview(text, fileName = null) {
            extractedText = text;
            if (text && text.length > 0) {
                // show first 500 chars in preview
                let short = text.length > 800 ? text.substring(0, 800) + '…' : text;
                previewDiv.innerHTML = short.replace(/\n/g, '<br>');
                statusSpan.innerText = `✅ Ready – ${text.length} characters extracted`;
                convertBtn.disabled = false;
                if (fileName) statusSpan.innerText = `📄 ${fileName} – ${text.length} chars ready`;
            } else {
                previewDiv.innerHTML = '<span class="text-slate-500">No text could be extracted. The PDF might be image‑based or empty.</span>';
                statusSpan.innerText = '⚠️ No extractable text';
                convertBtn.disabled = true;
            }
        }

        // Load PDF file from user input
        async function loadPDF(file) {
            if (!file || file.type !== 'application/pdf') {
                showToast('Please select a valid PDF file.', 'error');
                return;
            }
            currentFile = file;
            statusSpan.innerText = '⏳ Extracting text, please wait...';
            previewDiv.innerHTML = '<span class="text-slate-400">Extracting text from PDF…</span>';
            convertBtn.disabled = true;

            try {
                const text = await extractTextFromPDF(file);
                if (text && text.length > 0) {
                    updatePreview(text, file.name);
                } else {
                    updatePreview('', file.name);
                }
            } catch (err) {
                console.error(err);
                showToast('Error reading PDF. Make sure it’s not corrupted or password‑protected.', 'error');
                statusSpan.innerText = '❌ Extraction failed';
                previewDiv.innerHTML = '<span class="text-slate-500">An error occurred while reading the PDF.</span>';
                convertBtn.disabled = true;
            }
        }

        // Convert the extracted text to an Excel file using SheetJS
        function convertToExcel() {
            if (!extractedText || extractedText.length === 0) {
                showToast('No text to convert. Please load a PDF first.', 'error');
                return;
            }
            // Split text into rows by newlines (preserve line breaks as rows)
            const lines = extractedText.split(/\r?\n/);
            const data = lines.map(line => [line]);  // each line as a single cell in column A
            // Create a new workbook and worksheet
            const wb = XLSX.utils.book_new();
            const ws = XLSX.utils.aoa_to_sheet(data);
            // Adjust column width for better readability
            ws['!cols'] = [{ wch: 80 }];
            XLSX.utils.book_append_sheet(wb, ws, 'Extracted_Text');
            // Generate Excel file and trigger download
            XLSX.writeFile(wb, `converted_${currentFile ? currentFile.name.replace('.pdf', '') : 'document'}.xlsx`);
            showToast('Excel file downloaded successfully!', 'success');
        }

        // Clear everything
        function clearAll() {
            currentFile = null;
            extractedText = '';
            previewDiv.innerHTML = '<span class="text-slate-500">Your extracted text will appear here...</span>';
            statusSpan.innerText = 'No file loaded';
            convertBtn.disabled = true;
            fileInput.value = '';
        }

        // --- Drag & Drop handling ---
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
            const file = e.dataTransfer.files[0];
            if (file && file.type === 'application/pdf') {
                loadPDF(file);
            } else {
                showToast('Please drop a valid PDF file.', 'error');
            }
        });
        dropZone.addEventListener('click', () => {
            fileInput.click();
        });
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                loadPDF(e.target.files[0]);
            }
        });

        // Button listeners
        convertBtn.addEventListener('click', convertToExcel);
        clearBtn.addEventListener('click', clearAll);

        // Initialize pdf.js worker (needed for newer versions)
        if (typeof pdfjsLib !== 'undefined') {
            pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
        }

        // Optional: show friendly message if PDF.js fails to load
        window.addEventListener('load', () => {
            console.log('PDF to Excel converter ready');
        });
    </script>
</body>
</html>