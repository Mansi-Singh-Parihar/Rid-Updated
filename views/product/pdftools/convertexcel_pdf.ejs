<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Excel to PDF Converter</title>
    <!-- Tailwind CSS & Font Awesome -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- SheetJS (XLSX) + html2pdf.js -->
    <script src="https://cdn.sheetjs.com/xlsx-0.20.2/package/dist/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Header / Footer CSS (your existing files) -->
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
     <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
            @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        .glass-panel {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            box-shadow: 0 25px 45px -12px rgba(0, 0, 0, 0.3);
        }
        .preview-container {
            background: rgba(0, 0, 0, 0.3);
            border-radius: 20px;
            padding: 1rem;
            max-height: 300px;
            overflow: auto;
        }
        .preview-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 0.75rem;
        }
        .preview-table th, .preview-table td {
            border: 1px solid rgba(71, 85, 105, 0.5);
            padding: 6px 8px;
            text-align: left;
            color: #e2e8f0;
        }
        .preview-table th {
            background: rgba(129, 140, 248, 0.2);
            font-weight: 600;
        }
        .upload-area {
            transition: all 0.2s ease;
        }
        .upload-area:hover {
            border-color: #818cf8;
            background: rgba(129, 140, 248, 0.08);
            transform: translateY(-2px);
        }
        .btn-gradient {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            transition: all 0.2s;
        }
        .btn-gradient:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }
        /* scrollbar */
        .preview-container::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }
        .preview-container::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.05);
            border-radius: 10px;
        }
        .preview-container::-webkit-scrollbar-thumb {
            background: rgba(129, 140, 248, 0.5);
            border-radius: 10px;
        }
    </style>
</head>
<body class="bg-slate-900 text-white">

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <!-- Main content – flex column to push footer down -->
    <div class="min-h-screen flex flex-col">
        <div class="flex-1 flex items-center justify-center p-4">
            <div class="w-full max-w-5xl">
                <div class="glass-panel p-6 md:p-8">
                    <!-- Tool Header -->
                    <div class="text-center mb-6">
                        <i class="fas fa-file-excel text-emerald-400 text-4xl mb-2"></i>
                        <h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-emerald-400 to-indigo-400 bg-clip-text text-transparent">
                            Excel to PDF Converter
                        </h1>
                        <p class="text-slate-400 text-sm mt-2">
                            Convert your spreadsheets to clean, printable PDF documents.
                        </p>
                    </div>

                    <!-- Upload Area -->
                    <div id="dropZone" class="upload-area border-2 border-dashed border-slate-600 rounded-2xl p-6 text-center cursor-pointer transition">
                        <i class="fas fa-cloud-upload-alt text-4xl text-emerald-400 mb-3"></i>
                        <p class="text-lg font-semibold">Drag & drop an Excel file (.xlsx, .xls)</p>
                        <p class="text-slate-400 text-sm mt-1">or click to browse</p>
                        <input type="file" id="fileInput" accept=".xlsx, .xls, .csv" class="hidden" />
                    </div>

                    <!-- Sheet selector (if multiple sheets) -->
                    <div id="sheetSelectorDiv" class="mt-4 hidden">
                        <label class="text-sm text-slate-300 block mb-1"><i class="fas fa-layer-group mr-1"></i> Select sheet:</label>
                        <select id="sheetSelect" class="bg-slate-800 border border-slate-600 rounded-full px-4 py-2 text-sm w-full md:w-auto"></select>
                    </div>

                    <!-- Preview Table -->
                    <div class="mt-5">
                        <div class="flex justify-between items-center mb-2">
                            <h3 class="text-sm font-semibold text-slate-300"><i class="fas fa-eye mr-1"></i> Preview (first rows)</h3>
                            <span id="status" class="text-xs text-slate-400">No file loaded</span>
                        </div>
                        <div id="previewContainer" class="preview-container">
                            <div class="text-slate-500 text-center p-4">Your Excel data preview will appear here...</div>
                        </div>
                    </div>

                    <!-- Action Buttons -->
                    <div class="flex flex-wrap gap-3 mt-6">
                        <button id="convertBtn" class="btn-gradient flex-1 py-2 rounded-full text-white font-semibold flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                            <i class="fas fa-file-pdf"></i> Convert to PDF
                        </button>
                        <button id="clearBtn" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-4 py-2 rounded-full flex items-center gap-2 transition">
                            <i class="fas fa-trash-alt"></i> Clear
                        </button>
                    </div>

                    <!-- Info note -->
                    <div class="mt-5 text-xs text-center text-slate-500 border-t border-slate-700/50 pt-4">
                        <i class="fas fa-laptop-code mr-1"></i> Everything runs locally in your browser — no data upload.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        // DOM elements
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const convertBtn = document.getElementById('convertBtn');
        const clearBtn = document.getElementById('clearBtn');
        const previewContainer = document.getElementById('previewContainer');
        const statusSpan = document.getElementById('status');
        const sheetSelectorDiv = document.getElementById('sheetSelectorDiv');
        const sheetSelect = document.getElementById('sheetSelect');

        let workbook = null;        // XLSX workbook object
        let currentSheetName = '';
        let currentSheetData = [];   // array of arrays (rows)

        // Helper: show toast notification
        function showToast(msg, type = 'info') {
            let toast = document.getElementById('customToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'customToast';
                toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none';
                document.body.appendChild(toast);
            }
            let bg = 'bg-emerald-500';
            if (type === 'error') bg = 'bg-red-500';
            if (type === 'info') bg = 'bg-blue-500';
            toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none ${bg}`;
            toast.textContent = msg;
            toast.style.opacity = '1';
            setTimeout(() => {
                toast.style.opacity = '0';
            }, 2500);
        }

        // Parse uploaded file using SheetJS
        function loadExcel(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                const data = new Uint8Array(e.target.result);
                try {
                    workbook = XLSX.read(data, { type: 'array' });
                    const sheetNames = workbook.SheetNames;
                    if (sheetNames.length === 0) {
                        throw new Error('No sheets found');
                    }
                    // Populate sheet selector
                    sheetSelect.innerHTML = '';
                    sheetNames.forEach(name => {
                        const opt = document.createElement('option');
                        opt.value = name;
                        opt.textContent = name;
                        sheetSelect.appendChild(opt);
                    });
                    sheetSelectorDiv.classList.remove('hidden');
                    // Load first sheet
                    currentSheetName = sheetNames[0];
                    loadSheet(currentSheetName);
                    statusSpan.innerText = `✅ ${file.name} — ${sheetNames.length} sheet(s)`;
                    convertBtn.disabled = false;
                } catch (err) {
                    console.error(err);
                    showToast('Could not read Excel file. Make sure it is valid.', 'error');
                    statusSpan.innerText = '❌ Invalid file';
                    convertBtn.disabled = true;
                    previewContainer.innerHTML = '<div class="text-slate-500 text-center p-4">Failed to parse file.</div>';
                }
            };
            reader.onerror = () => {
                showToast('Error reading file', 'error');
            };
            reader.readAsArrayBuffer(file);
        }

        // Load a specific sheet by name and render preview
        function loadSheet(sheetName) {
            if (!workbook) return;
            const sheet = workbook.Sheets[sheetName];
            // Convert sheet to JSON (array of arrays)
            const data = XLSX.utils.sheet_to_json(sheet, { header: 1, defval: '' });
            currentSheetData = data;
            renderPreview(data);
        }

        // Render first few rows as an HTML table
        function renderPreview(data) {
            if (!data || data.length === 0) {
                previewContainer.innerHTML = '<div class="text-slate-500 text-center p-4">Sheet is empty.</div>';
                return;
            }
            const maxRows = 15; // show first 15 rows
            const rowsToShow = data.slice(0, maxRows);
            if (rowsToShow.length === 0) rowsToShow.push(['(empty)']);

            let html = '<table class="preview-table">';
            // Header row (first row if exists)
            if (rowsToShow.length > 0) {
                html += '<thead><tr>';
                const firstRow = rowsToShow[0];
                for (let i = 0; i < firstRow.length; i++) {
                    html += `<th>${escapeHtml(String(firstRow[i] || ''))}</th>`;
                }
                html += '</tr></thead><tbody>';
                // Data rows (from row 1 onward)
                for (let i = 1; i < rowsToShow.length; i++) {
                    const row = rowsToShow[i];
                    html += '<tr>';
                    for (let j = 0; j < row.length; j++) {
                        html += `<td>${escapeHtml(String(row[j] || ''))}</td>`;
                    }
                    // fill missing columns
                    if (row.length < rowsToShow[0].length) {
                        for (let j = row.length; j < rowsToShow[0].length; j++) {
                            html += '<td></td>';
                        }
                    }
                    html += '</tr>';
                }
                html += '</tbody>';
            }
            html += '</table>';
            if (data.length > maxRows) {
                html += `<div class="text-xs text-slate-400 mt-2">+ ${data.length - maxRows} more rows not shown</div>`;
            }
            previewContainer.innerHTML = html;
        }

        // Helper to escape HTML
        function escapeHtml(str) {
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }

        // Generate PDF from current sheet data using html2pdf.js
        async function convertToPDF() {
            if (!currentSheetData || currentSheetData.length === 0) {
                showToast('No data to convert. Please load an Excel file first.', 'error');
                return;
            }

            // Create a temporary div that will contain the full table for PDF rendering
            const pdfDiv = document.createElement('div');
            pdfDiv.style.padding = '20px';
            pdfDiv.style.fontFamily = 'Inter, sans-serif';
            pdfDiv.style.backgroundColor = 'white';
            pdfDiv.style.color = '#0f172a';
            pdfDiv.style.width = '100%';
            pdfDiv.style.maxWidth = '1200px';
            pdfDiv.style.margin = '0 auto';

            // Add title
            const title = document.createElement('h1');
            title.textContent = `Excel Sheet: ${currentSheetName}`;
            title.style.fontSize = '24px';
            title.style.fontWeight = 'bold';
            title.style.marginBottom = '20px';
            title.style.color = '#1e293b';
            pdfDiv.appendChild(title);

            // Create full table
            const table = document.createElement('table');
            table.style.width = '100%';
            table.style.borderCollapse = 'collapse';
            table.style.fontSize = '12px';

            // Header row
            const thead = document.createElement('thead');
            const headerRow = document.createElement('tr');
            if (currentSheetData.length > 0) {
                const firstRow = currentSheetData[0];
                for (let i = 0; i < firstRow.length; i++) {
                    const th = document.createElement('th');
                    th.textContent = firstRow[i] !== undefined ? String(firstRow[i]) : '';
                    th.style.border = '1px solid #cbd5e1';
                    th.style.padding = '8px';
                    th.style.backgroundColor = '#f1f5f9';
                    th.style.fontWeight = '600';
                    headerRow.appendChild(th);
                }
                thead.appendChild(headerRow);
                table.appendChild(thead);
            }

            // Body rows
            const tbody = document.createElement('tbody');
            for (let i = 1; i < currentSheetData.length; i++) {
                const row = currentSheetData[i];
                const tr = document.createElement('tr');
                for (let j = 0; j < row.length; j++) {
                    const td = document.createElement('td');
                    td.textContent = row[j] !== undefined ? String(row[j]) : '';
                    td.style.border = '1px solid #cbd5e1';
                    td.style.padding = '6px';
                    tr.appendChild(td);
                }
                // fill empty cells if needed
                if (currentSheetData[0] && row.length < currentSheetData[0].length) {
                    for (let j = row.length; j < currentSheetData[0].length; j++) {
                        const td = document.createElement('td');
                        td.textContent = '';
                        td.style.border = '1px solid #cbd5e1';
                        td.style.padding = '6px';
                        tr.appendChild(td);
                    }
                }
                tbody.appendChild(tr);
            }
            table.appendChild(tbody);
            pdfDiv.appendChild(table);

            // Optional: add footer with generation date
            const footer = document.createElement('div');
            footer.style.marginTop = '20px';
            footer.style.fontSize = '10px';
            footer.style.color = '#64748b';
            footer.style.textAlign = 'center';
            footer.textContent = `Generated by Excel to PDF Converter • ${new Date().toLocaleString()}`;
            pdfDiv.appendChild(footer);

            // Use html2pdf to generate PDF
            const opt = {
                margin: [0.5, 0.5, 0.5, 0.5],
                filename: `${currentSheetName.replace(/[\\/]/g, '_')}_export.pdf`,
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, letterRendering: true, useCORS: false },
                jsPDF: { unit: 'in', format: 'a4', orientation: 'landscape' }
            };
            try {
                showToast('Generating PDF, please wait...', 'info');
                await html2pdf().set(opt).from(pdfDiv).save();
                showToast('PDF downloaded successfully!', 'success');
            } catch (err) {
                console.error(err);
                showToast('PDF generation failed', 'error');
            }
        }

        // Clear everything
        function clearAll() {
            workbook = null;
            currentSheetData = [];
            currentSheetName = '';
            previewContainer.innerHTML = '<div class="text-slate-500 text-center p-4">Your Excel data preview will appear here...</div>';
            statusSpan.innerText = 'No file loaded';
            convertBtn.disabled = true;
            fileInput.value = '';
            sheetSelectorDiv.classList.add('hidden');
            sheetSelect.innerHTML = '';
        }

        // Event listeners for file selection
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
            const file = e.dataTransfer.files[0];
            if (file && (file.name.endsWith('.xlsx') || file.name.endsWith('.xls') || file.name.endsWith('.csv'))) {
                loadExcel(file);
            } else {
                showToast('Please drop a valid Excel file (.xlsx, .xls, .csv).', 'error');
            }
        });
        dropZone.addEventListener('click', () => {
            fileInput.click();
        });
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                loadExcel(e.target.files[0]);
            }
        });

        // Sheet selection change
        sheetSelect.addEventListener('change', (e) => {
            const newSheet = e.target.value;
            if (newSheet && workbook) {
                currentSheetName = newSheet;
                loadSheet(newSheet);
            }
        });

        convertBtn.addEventListener('click', convertToPDF);
        clearBtn.addEventListener('click', clearAll);
    </script>
</body>
</html>