<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>PDF Splitter – Extract Pages</title>
    <!-- Tailwind CSS & Font Awesome -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- pdf-lib & pdf.js -->
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.min.js"></script>
    <script>
        pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/2.16.105/pdf.worker.min.js';
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Header / Footer CSS (your existing files) -->
    <link rel="stylesheet" href="/css/common/header.css">
    <link rel="stylesheet" href="/css/common/footer.css">
     <link rel="icon" type="image/png" href="/assets/signup.png">
    <style>
        body { font-family: 'Inter', sans-serif; }
            @media (max-width: 768px) {
    .menu {
        position: fixed;
        top: 77px;
        left: 0;
        width: 100%;
        height: calc(100vh - 90px);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(15px);
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-start;
        display: none;
        padding: 30px 20px 20px;
        overflow-y: auto;
        z-index: 999;
        transform: translateX(-100%);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }
}
        .glass-panel {
            background: rgba(30, 41, 59, 0.5);
            backdrop-filter: blur(16px);
            border-radius: 32px;
            border: 1px solid rgba(71, 85, 105, 0.6);
            box-shadow: 0 25px 45px -12px rgba(0,0,0,0.3);
        }
        .upload-area {
            transition: all 0.2s ease;
        }
        .upload-area:hover {
            border-color: #818cf8;
            background: rgba(129,140,248,0.08);
            transform: translateY(-2px);
        }
        .btn-gradient {
            background: linear-gradient(135deg, #6366f1, #818cf8);
            transition: all 0.2s;
        }
        .btn-gradient:hover {
            transform: translateY(-2px);
            filter: brightness(1.05);
        }
        .preview-container {
            min-height: 380px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .preview-canvas {
            max-width: 100%;
            height: auto;
            border-radius: 12px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }
        .range-input {
            background: rgba(0,0,0,0.3);
            border: 1px solid rgba(71,85,105,0.5);
            border-radius: 20px;
            padding: 0.6rem 1rem;
            color: white;
            width: 100%;
            outline: none;
        }
        .range-input:focus {
            border-color: #818cf8;
        }
    </style>
</head>
<body class="bg-slate-900 text-white">

    <!-- HEADER (EJS include) – unchanged -->
    <%- include("common/header.ejs") %>

    <div class="min-h-screen flex flex-col">
        <div class="flex-1 flex items-center justify-center p-4">
            <div class="w-full max-w-6xl">
                <div class="glass-panel p-6 md:p-8">
                    <div class="text-center mb-6">
                        <i class="fas fa-cut text-indigo-400 text-4xl mb-2"></i>
                        <h1 class="text-2xl md:text-3xl font-bold bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">
                            PDF Splitter
                        </h1>
                        <p class="text-slate-400 text-sm mt-2">
                            Extract specific pages from a PDF – preview, split, and download.
                        </p>
                    </div>

                    <div class="flex flex-col md:flex-row gap-6">
                        <!-- LEFT PANEL -->
                        <div class="md:w-2/5">
                            <!-- Upload Area -->
                            <div id="dropZone" class="upload-area border-2 border-dashed border-slate-600 rounded-2xl p-4 text-center cursor-pointer transition mb-4">
                                <i class="fas fa-cloud-upload-alt text-3xl text-indigo-400 mb-2"></i>
                                <p class="text-sm font-semibold">Drag & drop a PDF file</p>
                                <p class="text-slate-400 text-xs mt-1">or click to browse</p>
                                <input type="file" id="fileInput" accept=".pdf" class="hidden" />
                            </div>

                            <!-- File info -->
                            <div id="fileInfo" class="bg-slate-800/30 rounded-xl p-3 mb-4 hidden">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-file-pdf text-red-400"></i>
                                    <span id="fileName" class="text-sm font-medium truncate"></span>
                                </div>
                                <div class="text-xs text-slate-400 mt-1">
                                    <span id="pageCount"></span> pages
                                </div>
                            </div>

                            <!-- Page Range Input -->
                            <div class="mb-4">
                                <label class="text-sm font-semibold text-slate-300 block mb-1">
                                    <i class="fas fa-code-branch mr-1"></i> Pages to extract
                                </label>
                                <input type="text" id="pageRange" class="range-input" placeholder="e.g., 1-3,5,7-9,12" disabled>
                                <p class="text-xs text-slate-500 mt-1">Use commas and hyphens (e.g., 1-3,5,7-9)</p>
                            </div>

                            <!-- Action Buttons -->
                            <div class="flex gap-3 mt-4">
                                <button id="splitBtn" class="btn-gradient flex-1 py-2 rounded-full text-white font-semibold flex items-center justify-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                                    <i class="fas fa-scissors"></i> Split & Preview
                                </button>
                                <button id="clearBtn" class="bg-red-500/20 hover:bg-red-500/30 text-red-400 px-4 py-2 rounded-full flex items-center gap-2 transition">
                                    <i class="fas fa-trash-alt"></i> Clear
                                </button>
                            </div>
                        </div>

                        <!-- RIGHT PANEL: preview -->
                        <div class="md:w-3/5">
                            <div class="bg-slate-800/30 rounded-2xl p-4 h-full flex flex-col">
                                <div class="flex justify-between items-center mb-3">
                                    <h3 class="text-sm font-semibold text-slate-300">
                                        <i class="fas fa-eye mr-1"></i> <span id="previewTitle">PDF Preview</span>
                                    </h3>
                                    <button id="downloadBtn" class="bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-400 px-3 py-1 rounded-full text-xs flex items-center gap-1 transition hidden">
                                        <i class="fas fa-download"></i> Download Split PDF
                                    </button>
                                </div>
                                <div id="previewContainer" class="preview-container flex-1 bg-slate-900/40 rounded-xl p-4 min-h-[380px]">
                                    <i class="fas fa-file-pdf text-5xl text-slate-600 mb-3"></i>
                                    <p class="text-slate-500 text-sm">Upload a PDF to begin.</p>
                                </div>
                                <div class="text-center text-xs text-slate-500 mt-3">
                                    <span id="previewInfo"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-6 text-xs text-center text-slate-500 border-t border-slate-700/50 pt-4">
                        <i class="fas fa-laptop-code mr-1"></i> All processing is local — your files never leave your device.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER (EJS include) – unchanged -->
    <%- include("common/footer.ejs") %>

    <script>
        // DOM elements
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const fileInfoDiv = document.getElementById('fileInfo');
        const fileNameSpan = document.getElementById('fileName');
        const pageCountSpan = document.getElementById('pageCount');
        const pageRangeInput = document.getElementById('pageRange');
        const splitBtn = document.getElementById('splitBtn');
        const clearBtn = document.getElementById('clearBtn');
        const downloadBtn = document.getElementById('downloadBtn');
        const previewContainer = document.getElementById('previewContainer');
        const previewTitle = document.getElementById('previewTitle');
        const previewInfoSpan = document.getElementById('previewInfo');

        let currentPdfData = null;      // Uint8Array of the uploaded PDF
        let currentPdfDoc = null;        // pdf.js document object
        let totalPages = 0;
        let splitBlob = null;             // store split PDF blob for download

        // Helper: show toast
        function showToast(msg, type = 'success') {
            let toast = document.getElementById('splitToast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'splitToast';
                toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none';
                document.body.appendChild(toast);
            }
            let bg = type === 'error' ? 'bg-red-500' : (type === 'info' ? 'bg-blue-500' : 'bg-emerald-500');
            toast.className = `fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-5 py-2 rounded-full text-white text-sm font-medium shadow-lg transition-opacity duration-300 opacity-0 pointer-events-none ${bg}`;
            toast.textContent = msg;
            toast.style.opacity = '1';
            setTimeout(() => toast.style.opacity = '0', 2500);
        }

        // Parse page range string into array of page numbers (1-indexed)
        function parsePageRange(rangeStr, maxPages) {
            const pages = new Set();
            const parts = rangeStr.split(',');
            for (let part of parts) {
                part = part.trim();
                if (part.includes('-')) {
                    const [start, end] = part.split('-').map(Number);
                    if (isNaN(start) || isNaN(end) || start < 1 || end > maxPages || start > end) {
                        return null;
                    }
                    for (let i = start; i <= end; i++) pages.add(i);
                } else {
                    const p = Number(part);
                    if (isNaN(p) || p < 1 || p > maxPages) return null;
                    pages.add(p);
                }
            }
            return Array.from(pages).sort((a,b) => a-b);
        }

        // Show preview of first page of the uploaded PDF
        async function showOriginalPreview() {
            if (!currentPdfData) return;
            previewTitle.textContent = 'Original PDF Preview';
            previewContainer.innerHTML = `<div class="text-slate-400"><i class="fas fa-spinner fa-spin"></i> Loading preview...</div>`;
            try {
                const pdfDoc = await pdfjsLib.getDocument({ data: currentPdfData }).promise;
                const page = await pdfDoc.getPage(1);
                const viewport = page.getViewport({ scale: 1.0 });
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                await page.render({ canvasContext: ctx, viewport }).promise;
                previewContainer.innerHTML = '';
                const img = document.createElement('img');
                img.src = canvas.toDataURL();
                img.className = 'preview-canvas max-w-full max-h-[400px] object-contain rounded-lg shadow-lg';
                previewContainer.appendChild(img);
                previewInfoSpan.textContent = `Page 1 of ${totalPages}`;
                downloadBtn.classList.add('hidden');
            } catch (err) {
                console.error(err);
                previewContainer.innerHTML = `<div class="text-center text-red-400"><i class="fas fa-exclamation-triangle"></i> Could not preview PDF.</div>`;
            }
        }

        // Show preview of the split result (first page)
        async function showSplitPreview(pdfBytes, pageCount) {
            previewTitle.textContent = 'Split PDF Preview';
            previewContainer.innerHTML = `<div class="text-slate-400"><i class="fas fa-spinner fa-spin"></i> Rendering split preview...</div>`;
            try {
                const pdfDoc = await pdfjsLib.getDocument({ data: pdfBytes }).promise;
                const page = await pdfDoc.getPage(1);
                const viewport = page.getViewport({ scale: 1.0 });
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');
                canvas.width = viewport.width;
                canvas.height = viewport.height;
                await page.render({ canvasContext: ctx, viewport }).promise;
                previewContainer.innerHTML = '';
                const img = document.createElement('img');
                img.src = canvas.toDataURL();
                img.className = 'preview-canvas max-w-full max-h-[400px] object-contain rounded-lg shadow-lg';
                previewContainer.appendChild(img);
                previewInfoSpan.textContent = `${pageCount} page${pageCount !== 1 ? 's' : ''} (split result)`;
                downloadBtn.classList.remove('hidden');
            } catch (err) {
                console.error(err);
                previewContainer.innerHTML = `<div class="text-center text-red-400"><i class="fas fa-exclamation-triangle"></i> Could not preview split PDF.</div>`;
                downloadBtn.classList.add('hidden');
            }
        }

        // Load uploaded PDF
        async function loadPDF(file) {
            if (!file || file.type !== 'application/pdf') {
                showToast('Please select a valid PDF file.', 'error');
                return;
            }
            const reader = new FileReader();
            reader.onload = async function(e) {
                currentPdfData = new Uint8Array(e.target.result);
                try {
                    const pdfDoc = await pdfjsLib.getDocument({ data: currentPdfData }).promise;
                    totalPages = pdfDoc.numPages;
                    currentPdfDoc = pdfDoc;
                    // Update UI
                    fileNameSpan.textContent = file.name;
                    pageCountSpan.textContent = totalPages;
                    fileInfoDiv.classList.remove('hidden');
                    pageRangeInput.disabled = false;
                    splitBtn.disabled = false;
                    // Show preview
                    await showOriginalPreview();
                    showToast(`PDF loaded: ${totalPages} pages`, 'success');
                } catch (err) {
                    console.error(err);
                    showToast('Could not read PDF. It may be corrupted or password-protected.', 'error');
                    clearAll();
                }
            };
            reader.onerror = () => showToast('Error reading file', 'error');
            reader.readAsArrayBuffer(file);
        }

        // Split PDF based on page range
        async function splitPDF() {
            if (!currentPdfData) {
                showToast('No PDF loaded.', 'error');
                return;
            }
            const rangeText = pageRangeInput.value.trim();
            if (!rangeText) {
                showToast('Please enter page range(s).', 'error');
                return;
            }
            const pagesToExtract = parsePageRange(rangeText, totalPages);
            if (!pagesToExtract || pagesToExtract.length === 0) {
                showToast(`Invalid page range. Pages must be between 1 and ${totalPages}.`, 'error');
                return;
            }

            splitBtn.disabled = true;
            splitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Splitting...';
            previewContainer.innerHTML = `<div class="text-slate-400"><i class="fas fa-spinner fa-spin"></i> Creating split PDF...</div>`;
            downloadBtn.classList.add('hidden');

            try {
                // Load original PDF with pdf-lib
                const originalPdf = await PDFLib.PDFDocument.load(currentPdfData);
                const newPdf = await PDFLib.PDFDocument.create();
                // Copy selected pages (page numbers are 1-indexed, pdf-lib uses 0-index)
                for (const pageNum of pagesToExtract) {
                    const [copiedPage] = await newPdf.copyPages(originalPdf, [pageNum - 1]);
                    newPdf.addPage(copiedPage);
                }
                const pdfBytes = await newPdf.save();
                splitBlob = new Blob([pdfBytes], { type: 'application/pdf' });
                await showSplitPreview(pdfBytes, pagesToExtract.length);
                showToast(`Successfully extracted ${pagesToExtract.length} page(s).`, 'success');
            } catch (err) {
                console.error(err);
                showToast('Split failed. Please try again.', 'error');
                previewContainer.innerHTML = `<div class="text-center text-red-400"><i class="fas fa-exclamation-triangle"></i> Split failed.</div>`;
            } finally {
                splitBtn.disabled = false;
                splitBtn.innerHTML = '<i class="fas fa-scissors"></i> Split & Preview';
            }
        }

        function downloadSplit() {
            if (!splitBlob) {
                showToast('No split PDF available. Please split first.', 'error');
                return;
            }
            const link = document.createElement('a');
            const url = URL.createObjectURL(splitBlob);
            link.href = url;
            link.download = `split_pages_${new Date().toISOString().slice(0,19).replace(/:/g, '-')}.pdf`;
            link.click();
            URL.revokeObjectURL(url);
            showToast('Download started!', 'success');
        }

        function clearAll() {
            currentPdfData = null;
            currentPdfDoc = null;
            totalPages = 0;
            splitBlob = null;
            fileInfoDiv.classList.add('hidden');
            pageRangeInput.value = '';
            pageRangeInput.disabled = true;
            splitBtn.disabled = true;
            downloadBtn.classList.add('hidden');
            previewContainer.innerHTML = `<i class="fas fa-file-pdf text-5xl text-slate-600 mb-3"></i>
                                          <p class="text-slate-500 text-sm">Upload a PDF to begin.</p>`;
            previewTitle.textContent = 'PDF Preview';
            previewInfoSpan.textContent = '';
            fileInput.value = '';
            showToast('Cleared', 'info');
        }

        // Drag & drop events
        dropZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            dropZone.classList.add('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('dragleave', () => {
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
        });
        dropZone.addEventListener('drop', (e) => {
            e.preventDefault();
            dropZone.classList.remove('border-indigo-400', 'bg-indigo-500/10');
            const file = e.dataTransfer.files[0];
            if (file && file.type === 'application/pdf') loadPDF(file);
            else showToast('Please drop a valid PDF file.', 'error');
        });
        dropZone.addEventListener('click', () => fileInput.click());
        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length) loadPDF(e.target.files[0]);
            fileInput.value = '';
        });

        clearBtn.addEventListener('click', clearAll);
        splitBtn.addEventListener('click', splitPDF);
        downloadBtn.addEventListener('click', downloadSplit);

        // Initial state
        clearAll();
    </script>
</body>
</html>